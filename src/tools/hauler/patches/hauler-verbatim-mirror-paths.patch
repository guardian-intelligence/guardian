Serve mirror repo paths verbatim instead of docker-normalizing them.

Store annotations are already host-stripped when artifacts are added
(registry.k8s.io/pause -> "pause@sha256:..."). RewriteRefToRegistry
round-trips that through go-containerregistry's name.ParseReference, whose
docker normalization prefixes bare single-segment paths with "library/"
(pause -> library/pause). A containerd registry mirror for
registry.k8s.io/pause requests GET /v2/pause/manifests/..., so every
single-segment repo on a non-docker.io registry 404s from the served
mirror. Keep the path textual: split off the digest or tag and preserve the
repository path exactly as stored.

diff --git a/pkg/content/registry.go b/pkg/content/registry.go
index edf8138..ad605c5 100644
--- a/pkg/content/registry.go
+++ b/pkg/content/registry.go
@@ -85,22 +85,24 @@ func (t *RegistryTarget) Pusher(ctx context.Context, ref string) (remotes.Pusher
 	return t.resolver.Pusher(ctx, ref)
 }
 
-// RewriteRefToRegistry rewrites sourceRef to use targetRegistry as its host, preserving the
-// repository path and tag or digest. For example:
-//
-//	"index.docker.io/library/nginx:latest" + "localhost:5000" → "localhost:5000/library/nginx:latest"
+// RewriteRefToRegistry rewrites sourceRef to use targetRegistry as its host,
+// preserving the repository path and tag or digest VERBATIM. Callers pass the
+// store's already-host-stripped ref annotations (e.g. "pause@sha256:..." or
+// "pause:3.10.1"), so no re-parsing is done: go-containerregistry's docker
+// normalization would prefix bare single-segment paths with "library/"
+// (pause -> library/pause), which breaks containerd registry-mirror path
+// expectations — a mirror request for registry.k8s.io/pause is GET /v2/pause.
+// Example: "alpine/k8s:1.33.4" + "localhost:5000" -> "localhost:5000/alpine/k8s:1.33.4".
 func RewriteRefToRegistry(sourceRef string, targetRegistry string) (string, error) {
-	ref, err := goname.ParseReference(sourceRef)
-	if err != nil {
-		return "", fmt.Errorf("parsing reference %q: %w", sourceRef, err)
+	if sourceRef == "" {
+		return "", fmt.Errorf("empty source reference")
 	}
-	repo := strings.TrimPrefix(ref.Context().RepositoryStr(), "/")
-	switch r := ref.(type) {
-	case goname.Tag:
-		return fmt.Sprintf("%s/%s:%s", targetRegistry, repo, r.TagStr()), nil
-	case goname.Digest:
-		return fmt.Sprintf("%s/%s@%s", targetRegistry, repo, r.DigestStr()), nil
-	default:
-		return fmt.Sprintf("%s/%s:latest", targetRegistry, repo), nil
+	if at := strings.Index(sourceRef, "@"); at != -1 {
+		return fmt.Sprintf("%s/%s@%s", targetRegistry, strings.TrimPrefix(sourceRef[:at], "/"), sourceRef[at+1:]), nil
 	}
+	repo, tag := sourceRef, "latest"
+	if colon := strings.LastIndex(sourceRef, ":"); colon > strings.LastIndex(sourceRef, "/") {
+		repo, tag = sourceRef[:colon], sourceRef[colon+1:]
+	}
+	return fmt.Sprintf("%s/%s:%s", targetRegistry, strings.TrimPrefix(repo, "/"), tag), nil
 }
