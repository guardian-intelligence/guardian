genrule(
    name = "restic",
    srcs = select({
        "@platforms//os:macos": ["@restic_darwin_arm64_bz2//file"],
        "//conditions:default": ["@restic_linux_amd64_bz2//file"],
    }),
    outs = ["restic_bin"],
    cmd = """
bunzip2 -c "$(SRCS)" > "$@" && chmod +x "$@"
""",
    executable = True,
    visibility = ["//visibility:public"],
)
