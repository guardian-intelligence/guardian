# Golden runner image pins. Shell-sourced by build.sh; every artifact is
# fetched from the version pinned here and rejected unless its sha256
# matches. The image id (and so the platform_image_id scope dimension)
# derives from this file's hash, the guestd binary, and the repo commit, so
# any edit here mints a new image identity.

# actions/runner-images release used as the compatibility contract. The tag is
# human-readable provenance; the immutable commit is what the builder fetches.
RUNNER_IMAGES_REF="ubuntu24/20260714.240"
RUNNER_IMAGES_VERSION="20260714.240.1"
RUNNER_IMAGES_COMMIT="676e8d40d35f6789e61b4f052602f5e62c538183"

# Canonical server cloud image beneath the QEMU runner-images build. This is
# the release current when the runner-images release above was produced.
UBUNTU_SERIAL="20260705"
UBUNTU_SHA256="ffe6203da54deeb6db5d2a98a83f9ec8e55f149d3f7ba622e1abe5fa966ee3d6"

# Packer and its QEMU builder. Packer is downloaded and checksum-verified;
# `packer init` installs exactly this plugin version.
PACKER_VERSION="1.15.4"
PACKER_SHA256="15f97a6a99645c7d5308c609973b5280837b38e112beac413ccbce80da927cf1"
PACKER_QEMU_PLUGIN_VERSION="1.1.6"
PACKER_QEMU_PLUGIN_SHA256="4b336cdddbbc91e30eb54ad6d5ca62f02edcce70c1cf54667104d33c25c1b9b5"

# GitHub retires runner versions on ~30-day windows, so this pin has an
# external cadence floor: a stale image silently stops being assigned jobs.
# sha256 is the linux-x64 asset's, from the release notes checksum table.
# renovate: datasource=github-releases depName=actions/runner
RUNNER_VERSION="2.336.0"
RUNNER_SHA256="4ef2f25285f0ae4477f1fe1e346db76d2f3ebf03824e2ddd1973a2819bf6c8cf"
RUNNER_SOURCE_COMMIT="7d737449ef346f6524f75688d0c9c95fa10ba10a"
RUNNER_SOURCE_SHA256="1cf80e2754373ba66566f6d8e5be525c44bd835e953aa207ecceedbe669bdc28"
DOTNET_SDK_VERSION="8.0.421"
DOTNET_SDK_SHA512="3bee18a8706f169178a2609cce7d31a4ec3e21ae0758c2387b9a0756dbc267342b60cf00024c76fe91518e49617b241f8ebf1e52cb3fa5644da5966b76589b22"

# CRIU is the process checkpoint format contract. Pin both the release tag's
# peeled commit and GitHub's tag archive bytes; a version string alone is not
# a reproducible restore boundary.
CRIU_VERSION="4.2"
CRIU_COMMIT="3c7d4fa013297b431da48eff821db7f2e8b90c27"
CRIU_SHA256="0c6e51af878e63df7391e6dffbbe5f0ced429bc9f1e5a603020bfd2503065c39"

# tini is the checkpointed PID-namespace init. A native reaper keeps the
# process image independent of guestd's Go runtime and survives CRIU restore.
TINI_VERSION="0.19.0-1"
