+        private async Task PublishPostflightAssignmentAsync(
+            string requestId,
+            Pipelines.AgentJobRequestMessage jobMessage,
+            RunnerSettings settings,
+            CancellationToken cancellationToken)
+        {
+            string GitHubContext(string key)
+            {
+                if (jobMessage.ContextData != null &&
+                    jobMessage.ContextData.TryGetValue("github", out var context) &&
+                    context is Pipelines.ContextData.DictionaryContextData github &&
+                    github.TryGetValue(key, out var value) &&
+                    value is Pipelines.ContextData.StringContextData text &&
+                    !string.IsNullOrEmpty(text.Value))
+                {
+                    return text.Value;
+                }
+
+                throw new InvalidOperationException($"Postflight assignment is missing github.{key}");
+            }
+
+            string SystemVariable(string key)
+            {
+                if (jobMessage.Variables != null &&
+                    jobMessage.Variables.TryGetValue(key, out var variable) &&
+                    variable != null &&
+                    !variable.IsSecret &&
+                    !string.IsNullOrEmpty(variable.Value))
+                {
+                    return variable.Value;
+                }
+
+                throw new InvalidOperationException($"Postflight assignment is missing {key}");
+            }
+
+            string JobContextNumber(string key)
+            {
+                if (jobMessage.ContextData != null &&
+                    jobMessage.ContextData.TryGetValue("job", out var context) &&
+                    context is Pipelines.ContextData.DictionaryContextData job &&
+                    job.TryGetValue(key, out var value) &&
+                    value is Pipelines.ContextData.NumberContextData number &&
+                    number.Value > 0)
+                {
+                    return Convert.ToInt64(number.Value).ToString(CultureInfo.InvariantCulture);
+                }
+
+                throw new InvalidOperationException($"Postflight assignment is missing job.{key}");
+            }
+
+            var startInfo = new ProcessStartInfo("/usr/local/bin/guestd")
+            {
+                UseShellExecute = false,
+            };
+            foreach (var argument in new[]
+            {
+                "runner-assigned",
+                requestId,
+                jobMessage.JobId.ToString("D"),
+                JobContextNumber("check_run_id"),
+                settings.AgentName,
+                GitHubContext("run_id"),
+                GitHubContext("run_attempt"),
+                GitHubContext("repository"),
+                SystemVariable("system.github.job"),
+                jobMessage.JobDisplayName,
+            })
+            {
+                if (string.IsNullOrEmpty(argument))
+                {
+                    throw new InvalidOperationException("Postflight assignment contains an empty identity field");
+                }
+                startInfo.ArgumentList.Add(argument);
+            }
+
+            Trace.Info($"Publishing Postflight request '{requestId}' and job '{jobMessage.JobId}' before Runner.Worker dispatch");
+            using var gate = Process.Start(startInfo) ?? throw new InvalidOperationException("Failed to start Postflight assignment gate");
+            try
+            {
+                await gate.WaitForExitAsync(cancellationToken);
+            }
+            catch
+            {
+                if (!gate.HasExited)
+                {
+                    gate.Kill(entireProcessTree: true);
+                }
+                throw;
+            }
+            if (gate.ExitCode != 0)
+            {
+                throw new InvalidOperationException($"Postflight assignment gate exited {gate.ExitCode}");
+            }
+            Trace.Info($"Published Postflight request '{requestId}' before Runner.Worker dispatch");
+        }
+
