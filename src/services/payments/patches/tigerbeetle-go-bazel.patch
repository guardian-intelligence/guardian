diff --git a/BUILD.bazel b/BUILD.bazel
new file mode 100644
index 0000000..d163308
--- /dev/null
+++ b/BUILD.bazel
@@ -0,0 +1,25 @@
+load("@io_bazel_rules_go//go:def.bzl", "go_library")
+
+go_library(
+    name = "go_default_library",
+    srcs = [
+        "bindings.go",
+        "errors.go",
+        "tb_client.go",
+        "uint128.go",
+    ],
+    cgo = True,
+    cdeps = select({
+        "@io_bazel_rules_go//go/platform:linux_amd64": ["//native:tb_client_linux_amd64"],
+        "//conditions:default": [],
+    }),
+    copts = [
+        "-g",
+        "-Wall",
+    ],
+    importpath = "github.com/tigerbeetle/tigerbeetle-go",
+    visibility = ["//visibility:public"],
+    deps = [
+        "//native:go_default_library",
+    ],
+)
