# Edge gateway: SNI routing on host :80/:443 via the cilium-envoy DaemonSet
# (docs/architecture/gateway.md). Manifest-only — no image; guardian renders
# and applies these objects when site.yaml sets gateway.enabled, and applying
# the Gateway IS the per-site conversion (Envoy binds the host ports). The
# Gateway lives in its own namespace: the listener is a platform resource
# decoupled from app lifecycle; apps attach routes in their own namespaces
# (same-namespace backendRefs, so no ReferenceGrant), which is why this
# component applies LAST — every route's namespace must already exist.
apiVersion: v1
kind: Namespace
metadata:
  name: gateway
---
apiVersion: gateway.networking.k8s.io/v1
kind: Gateway
metadata:
  name: edge
  namespace: gateway
  labels:
    platform.guardian.dev/gateway: edge
spec:
  gatewayClassName: cilium
  listeners:
{{- if .Site.Aisucks.Domain}}
    # Product TLS passthrough: Envoy never decrypts; aisucks keeps in-process
    # certmagic and key custody.
    - name: tls-aisucks
      hostname: "{{.Site.Aisucks.Domain}}"
      port: 443
      protocol: TLS
      tls:
        mode: Passthrough
      allowedRoutes:
        namespaces: { from: All }
{{- end}}
{{- range $i, $d := .Site.Status.Domains}}
    - name: tls-status-{{$i}}
      hostname: "{{$d}}"
      port: 443
      protocol: TLS
      tls:
        mode: Passthrough
      allowedRoutes:
        namespaces: { from: All }
{{- end}}
{{- if .Site.OCI.Domain}}
    # Platform TLS termination: Envoy holds the public cert and forwards
    # cleartext HTTP to the in-cluster platform backend.
    - name: https-oci
      hostname: "{{.Site.OCI.Domain}}"
      port: 443
      protocol: HTTPS
      tls:
        mode: Terminate
        certificateRefs:
          - name: oci-guardianintelligence-org-tls
      allowedRoutes:
        namespaces: { from: All }
{{- end}}
    # :80 — healthz + the HTTPS redirect, implemented by backends. Platform
    # certificates use DNS-01; product passthrough services may still use
    # their own ACME challenge handling behind this listener.
    - name: http
      port: 80
      protocol: HTTP
      allowedRoutes:
        namespaces: { from: All }
{{- if .Site.Aisucks.Domain}}
---
# One TLSRoute per SNI hostname. v1alpha2 is the pin of record: Cilium 1.19
# consumes TLSRoute at v1alpha2 only (gateway-api-crds-inline.yaml header —
# do NOT bump to v1 outside a Cilium upgrade).
apiVersion: gateway.networking.k8s.io/v1alpha2
kind: TLSRoute
metadata:
  name: aisucks
  namespace: aisucks
spec:
  parentRefs:
    - name: edge
      namespace: gateway
      sectionName: tls-aisucks
  hostnames:
    - "{{.Site.Aisucks.Domain}}"
  rules:
    - backendRefs:
        - name: aisucks
          port: 443
{{- end}}
---
# No `hostnames`: :80 must answer raw-IP Host headers too — the gatus
# no-domain fallback probes http://<node IP>/healthz, and ACME HTTP-01 /
# operator curls must not depend on Host. The app's :80 mux already does
# acme-challenge precedence, /healthz, /livez, and the redirect. Do NOT add
# hostnames here without revisiting the gatus raw-IP branch
# (gatus.yaml.tmpl's $base).
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: aisucks-http
  namespace: aisucks
spec:
  parentRefs:
    - name: edge
      namespace: gateway
      sectionName: http
  rules:
    - backendRefs:
        - name: aisucks
          port: 80
{{- if .Site.Status.Domains}}
---
# Status hostnames -> the status Service (the backendRef the status manifest
# declares; src/status/k8s/status.yaml.tmpl). Passthrough like aisucks:
# certmagic in the status pod keeps key custody, issuance via TLS-ALPN-01.
apiVersion: gateway.networking.k8s.io/v1alpha2
kind: TLSRoute
metadata:
  name: status
  namespace: status
spec:
  parentRefs:
{{- range $i, $_ := .Site.Status.Domains}}
    - name: edge
      namespace: gateway
      sectionName: tls-status-{{$i}}
{{- end}}
  hostnames:
{{- range .Site.Status.Domains}}
    - "{{.}}"
{{- end}}
  rules:
    - backendRefs:
        - name: status
          port: 443
{{- end}}
{{- if .Site.OCI.Domain}}
---
apiVersion: cert-manager.io/v1
kind: ClusterIssuer
metadata:
  name: letsencrypt-production
spec:
  acme:
    email: im.shovonhasan@gmail.com
    server: https://acme-v02.api.letsencrypt.org/directory
    privateKeySecretRef:
      name: letsencrypt-production-account-key
    solvers:
      - dns01:
          cloudflare:
            apiTokenSecretRef:
              name: cloudflare-guardianintelligence-org-dns-token
              key: api-token
        selector:
          dnsZones:
            - guardianintelligence.org
---
apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: oci-guardianintelligence-org-tls
  namespace: gateway
spec:
  secretName: oci-guardianintelligence-org-tls
  dnsNames:
    - "{{.Site.OCI.Domain}}"
  issuerRef:
    name: letsencrypt-production
    kind: ClusterIssuer
---
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: guardian-oci
  namespace: guardian-oci
spec:
  parentRefs:
    - name: edge
      namespace: gateway
      sectionName: https-oci
  hostnames:
    - "{{.Site.OCI.Domain}}"
  rules:
    - backendRefs:
        - name: oci-placeholder
          port: 80
{{- end}}
