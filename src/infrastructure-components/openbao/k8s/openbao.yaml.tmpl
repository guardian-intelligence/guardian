apiVersion: v1
kind: Namespace
metadata:
  name: openbao
  labels:
    # hostPath volumes are forbidden at Talos's default "baseline" PSA level.
    pod-security.kubernetes.io/enforce: privileged
---
apiVersion: v1
kind: Service
metadata:
  name: openbao
  namespace: openbao
spec:
  clusterIP: None
  selector:
    app: openbao
  ports:
    - name: api
      port: 8200
    - name: cluster
      port: 8201
---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: openbao
  namespace: openbao
spec:
  serviceName: openbao
  replicas: 1
  selector:
    matchLabels:
      app: openbao
  template:
    metadata:
      labels:
        app: openbao
    spec:
      containers:
        - name: openbao
          image: {{ .Image }}
          ports:
            - name: api
              containerPort: 8200
            - name: cluster
              containerPort: 8201
          env:
            - name: POD_IP
              valueFrom:
                fieldRef:
                  fieldPath: status.podIP
            - name: BAO_RAFT_NODE_ID
              valueFrom:
                fieldRef:
                  fieldPath: metadata.name
            - name: BAO_API_ADDR
              value: "http://$(POD_IP):8200"
            - name: BAO_CLUSTER_ADDR
              value: "https://$(POD_IP):8201"
          readinessProbe:
            # Sealed and uninitialized are healthy states for a fresh node;
            # init/unseal/restore are operator actions, not liveness.
            httpGet:
              path: /v1/sys/health?standbyok=true&sealedcode=204&uninitcode=204
              port: 8200
            initialDelaySeconds: 2
            periodSeconds: 5
          volumeMounts:
            - name: data
              mountPath: /openbao/data
      volumes:
        - name: data
          hostPath:
            # /var is the writable persistent tree on Talos; survives pod
            # churn and OS upgrades. ZFS LocalPV replaces this later.
            path: /var/lib/openbao
            type: DirectoryOrCreate
