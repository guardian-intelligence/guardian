# VictoriaMetrics: the single-node TSDB at the center of the observability
# stack. Everything that scrapes or pushes metrics (the collector, alerting)
# writes here; nothing else stores time series. This manifest also OWNS the
# observability Namespace — victoria-metrics is the first observability
# component applied, and every later component (collector, ClickHouse, ...)
# assumes the namespace already exists.
#
# Storage is an EPHEMERAL hostPath: a wipe drill reinstalls the node and the
# history goes with it. That is acceptable — VictoriaMetrics is a refillable
# view of the systems it watches, not a system of record. vmbackup→R2 comes
# later if losing history starts to hurt.
apiVersion: v1
kind: Namespace
metadata:
  name: observability
  labels:
    pod-security.kubernetes.io/enforce: privileged
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: victoria-metrics
  namespace: observability
spec:
  replicas: 1
  # Recreate, not RollingUpdate: VictoriaMetrics flock()s its storage
  # directory, and on a single node both old and new pods would mount the
  # same hostPath — the new pod would sit crash-looping on the lock while
  # the old one drains. A short metrics gap during deploys is fine.
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: victoria-metrics
  template:
    metadata:
      labels:
        app: victoria-metrics
    spec:
      # Pod network, NOT hostNetwork: the firewall default-blocks new host
      # ports, and Cilium's socket-LB makes the ClusterIP reachable even
      # from the host netns, so nothing needs a host listener here.
      containers:
        - name: victoria-metrics
          image: {{.Image}}
          args:
            # 13 months, not 12: a year-over-year comparison always has the
            # whole comparison month on both ends (bare number = months).
            - -retentionPeriod=13
            - -storageDataPath=/storage
            # Absolute cache cap rather than -memory.allowedPercent: percent
            # is computed from the detected (cgroup) memory total, which
            # silently moves whenever the container limit is tuned. 256MiB of
            # caches under a 512Mi limit leaves headroom for ingestion
            # buffers and GC; the box belongs to postgres and the app.
            - -memory.allowedBytes=256MiB
          ports:
            - name: http
              containerPort: 8428
          readinessProbe:
            httpGet:
              path: /health
              port: 8428
            initialDelaySeconds: 2
            periodSeconds: 5
          resources:
            requests:
              cpu: 100m
              memory: 128Mi
            limits:
              memory: 512Mi
          volumeMounts:
            - name: storage
              mountPath: /storage
      volumes:
        - name: storage
          hostPath:
            path: /var/lib/victoria-metrics
            type: DirectoryOrCreate
---
apiVersion: v1
kind: Service
metadata:
  name: victoria-metrics
  namespace: observability
spec:
  selector:
    app: victoria-metrics
  ports:
    - name: http
      port: 8428
      targetPort: 8428
