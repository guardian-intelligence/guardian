{{- if .Site.OCI.Domain}}
apiVersion: v1
kind: Namespace
metadata:
  name: guardian-oci
  labels:
    pod-security.kubernetes.io/enforce: privileged
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: zot
  namespace: guardian-oci
data:
  config.json: |
    {
      "distSpecVersion": "1.1.1",
      "storage": {
        "rootDirectory": "/var/lib/zot"
      },
      "http": {
        "address": "0.0.0.0",
        "port": "5000",
        "auth": {
          "failDelay": 2,
          "htpasswd": {
            "path": "/zot-auth/htpasswd"
          }
        },
        "accessControl": {
          "repositories": {
            "**": {
              "anonymousPolicy": ["read"],
              "policies": [
                {
                  "users": ["guardian-release"],
                  "actions": ["read", "create", "update", "delete"]
                }
              ]
            }
          }
        }
      },
      "log": {
        "level": "info"
      },
      "extensions": {
        "search": {
          "enable": true
        },
        "ui": {
          "enable": true
        }
      }
    }
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: zot
  namespace: guardian-oci
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: zot
  template:
    metadata:
      labels:
        app: zot
    spec:
      securityContext:
        seccompProfile:
          type: RuntimeDefault
      containers:
        - name: zot
          image: {{.Image}}
          command: ["/usr/local/bin/zot-linux-amd64"]
          args: ["serve", "/zot-config/config.json"]
          ports:
            - name: http
              containerPort: 5000
          securityContext:
            allowPrivilegeEscalation: false
            capabilities:
              drop:
                - ALL
          resources:
            requests:
              cpu: 100m
              memory: 128Mi
            limits:
              memory: 512Mi
          readinessProbe:
            httpGet:
              path: /v2/
              port: http
            initialDelaySeconds: 2
            periodSeconds: 5
          livenessProbe:
            httpGet:
              path: /v2/
              port: http
            initialDelaySeconds: 10
            periodSeconds: 10
          volumeMounts:
            - name: config
              mountPath: /zot-config
              readOnly: true
            - name: auth
              mountPath: /zot-auth
              readOnly: true
            - name: storage
              mountPath: /var/lib/zot
      volumes:
        - name: config
          configMap:
            name: zot
            items:
              - key: config.json
                path: config.json
        - name: auth
          secret:
            secretName: zot-publisher
            items:
              - key: htpasswd
                path: htpasswd
        - name: storage
          hostPath:
            path: /var/lib/guardian/zot
            type: DirectoryOrCreate
---
apiVersion: v1
kind: Service
metadata:
  name: zot
  namespace: guardian-oci
spec:
  selector:
    app: zot
  ports:
    - name: http
      port: 5000
      targetPort: http
---
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: zot
  namespace: guardian-oci
spec:
  parentRefs:
    - name: edge
      namespace: gateway
      sectionName: https-oci
  hostnames:
    - "{{.Site.OCI.Domain}}"
  rules:
    - backendRefs:
        - name: zot
          port: 5000
{{- end}}
