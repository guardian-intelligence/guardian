{{- if .Site.OCI.Domain}}
# Crossplane-managed OpenBao projection for zot publisher credentials.
# Guardian creates/checks the OpenBao data and auth role during bootstrap;
# provider-kubernetes owns the Kubernetes resources that ESO reconciles.
apiVersion: kubernetes.crossplane.io/v1alpha2
kind: Object
metadata:
  name: zot-publisher-namespace
spec:
  providerConfigRef:
    name: platform
  forProvider:
    manifest:
      apiVersion: v1
      kind: Namespace
      metadata:
        name: guardian-oci
        labels:
          pod-security.kubernetes.io/enforce: privileged
          platform.guardian.dev/layer: platform
---
apiVersion: kubernetes.crossplane.io/v1alpha2
kind: Object
metadata:
  name: zot-publisher-external-secrets-service-account
spec:
  references:
    - dependsOn:
        apiVersion: kubernetes.crossplane.io/v1alpha2
        kind: Object
        name: zot-publisher-namespace
  providerConfigRef:
    name: platform
  forProvider:
    manifest:
      apiVersion: v1
      kind: ServiceAccount
      metadata:
        name: external-secrets-guardian-oci
        namespace: guardian-oci
        labels:
          platform.guardian.dev/layer: platform
---
apiVersion: kubernetes.crossplane.io/v1alpha2
kind: Object
metadata:
  name: zot-publisher-secret-store
spec:
  references:
    - dependsOn:
        apiVersion: kubernetes.crossplane.io/v1alpha2
        kind: Object
        name: zot-publisher-namespace
    - dependsOn:
        apiVersion: kubernetes.crossplane.io/v1alpha2
        kind: Object
        name: zot-publisher-external-secrets-service-account
  providerConfigRef:
    name: platform
  forProvider:
    manifest:
      apiVersion: external-secrets.io/v1
      kind: SecretStore
      metadata:
        name: openbao
        namespace: guardian-oci
        labels:
          platform.guardian.dev/layer: platform
      spec:
        provider:
          vault:
            server: http://openbao.openbao.svc:8200
            path: kv
            version: v2
            auth:
              kubernetes:
                mountPath: kubernetes
                role: guardian-oci-secrets
                serviceAccountRef:
                  name: external-secrets-guardian-oci
                  audiences:
                    - openbao
---
apiVersion: kubernetes.crossplane.io/v1alpha2
kind: Object
metadata:
  name: zot-publisher-external-secret
spec:
  references:
    - dependsOn:
        apiVersion: kubernetes.crossplane.io/v1alpha2
        kind: Object
        name: zot-publisher-secret-store
  providerConfigRef:
    name: platform
  forProvider:
    manifest:
      apiVersion: external-secrets.io/v1
      kind: ExternalSecret
      metadata:
        name: zot-publisher
        namespace: guardian-oci
        labels:
          platform.guardian.dev/layer: platform
      spec:
        refreshInterval: 1h
        secretStoreRef:
          name: openbao
          kind: SecretStore
        target:
          name: zot-publisher
          creationPolicy: Owner
          template:
            type: Opaque
        data:
          - secretKey: username
            remoteRef:
              key: guardian/{{.Site.Cluster.Name}}/oci/zot-publisher
              property: username
          - secretKey: password
            remoteRef:
              key: guardian/{{.Site.Cluster.Name}}/oci/zot-publisher
              property: password
          - secretKey: htpasswd
            remoteRef:
              key: guardian/{{.Site.Cluster.Name}}/oci/zot-publisher
              property: htpasswd
{{- end}}
