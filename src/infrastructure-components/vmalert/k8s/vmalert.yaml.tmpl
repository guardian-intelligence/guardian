# vmalert: PromQL rule evaluation for the observability hot plane. Evaluates
# the guardian rule group against VictoriaMetrics every 15s and fires to
# Alertmanager, which owns grouping/routing (so lockstep storms page once).
# Pod network only: it dials ClusterIPs and its :8880 UI is reached by
# kubectl port-forward, so the ingress firewall never sees it. The
# observability Namespace object is owned by the victoria-metrics manifest;
# this file assumes it exists. remoteWrite/remoteRead point back at VM so
# ALERTS state survives a vmalert restart instead of resetting `for:` timers.
#
# Templating note: TWO template languages share this file. guardian renders
# the .yaml.tmpl with Go text/template (missingkey=error) FIRST, and vmalert
# annotation templating uses the same delimiters — so the entire rules
# document below is wrapped in one Go raw-string block and reaches the
# cluster verbatim. Never add a Site value inside that block; it would not
# be rendered.
apiVersion: v1
kind: ConfigMap
metadata:
  name: vmalert-rules
  namespace: observability
data:
  guardian.rules.yaml: |
{{`    groups:
      - name: guardian
        # Group interval inherits -evaluationInterval=15s; flap resistance
        # comes from the per-rule for: durations, not slower evaluation.
        rules:
          # THE cross-site death-detection rule. A site-local stack cannot
          # report its own node's death, so each site's blackbox probes the
          # OTHER sites' public healthz (environment products.aisucks.watch) and this
          # fires when a sibling looks dead from outside its failure domain.
          # for: 2m rides out one flaky probe round without sitting on a
          # real outage.
          - alert: SiteProbeFailed
            expr: probe_success == 0
            for: 2m
            labels:
              severity: page
            annotations:
              summary: 'Sibling site down: probe of {{ $labels.instance }} (job {{ $labels.job }}) failing for 2m from this site'

          # 14 days is half the ACME renewal window: if cert-manager or a
          # remaining product-owned issuer has not renewed by then, renewal is
          # broken, not merely pending. for: 1h so a renewal landing
          # mid-evaluation clears it without a page.
          - alert: SiteCertExpiringSoon
            expr: probe_ssl_earliest_cert_expiry - time() < 14*86400
            for: 1h
            labels:
              severity: page
            annotations:
              summary: 'TLS cert for {{ $labels.instance }} expires in under 14 days; ACME renewal is likely broken'

          # The boot-loop class. The 2026-06-11 zfs boot-loop was visible as
          # lockstep restart counts across every pod for a day before a human
          # noticed; this turns that signature into a page in 20 minutes.
          # Lockstep restarts across pods page once via Alertmanager grouping.
          - alert: PodRestartStorm
            expr: increase(kube_pod_container_status_restarts_total[15m]) > 3
            for: 5m
            labels:
              severity: page
            annotations:
              summary: 'Restart storm: {{ $labels.namespace }}/{{ $labels.pod }} container {{ $labels.container }} restarted {{ $value }} times in 15m'

          # The wedged-not-crashing class: a pod that stops being ready but
          # never restarts produces zero restart-count signal. min by()
          # collapses kube-state-metrics' per-uid series; the unless arm
          # exempts completed pods (backup Jobs sit not-ready forever by
          # design). for: 10m outlasts normal deploy churn.
          - alert: PodNotReady
            expr: >-
              min by (namespace, pod) (kube_pod_status_ready{condition="true"}) == 0
              unless on (namespace, pod) (kube_pod_status_phase{phase="Succeeded"} == 1)
            for: 10m
            labels:
              severity: page
            annotations:
              summary: 'Pod not ready: {{ $labels.namespace }}/{{ $labels.pod }} unready for 10m without recovering'

          # VM shares one NVMe with postgres, ClickHouse, and the app. 50GiB
          # is weeks of headroom at our ingest rate: the fix while this fires
          # is a TTL/budget tweak, not triage of data already lost. for: 30m
          # ignores transient dips from compaction/merges.
          - alert: VMDiskLow
            expr: vm_free_disk_space_bytes < 50*1024*1024*1024
            for: 30m
            labels:
              severity: page
            annotations:
              summary: 'VictoriaMetrics disk low on {{ $labels.instance }}: {{ $value }} bytes free (< 50GiB) for 30m'

          # A dead exporter or app /metrics listener makes every rule above
          # it silently blind: dashboards flatline and nothing else notices.
          # for: 10m tolerates pod replacement during a deploy.
          - alert: ScrapeTargetDown
            expr: up == 0
            for: 10m
            labels:
              severity: page
            annotations:
              summary: 'Scrape target down: {{ $labels.job }} at {{ $labels.instance }} unreachable for 10m'

          # Silent truncation is the failure mode this stack exists to kill:
          # a collector quietly dropping points makes every other rule here
          # lie. Split into drop/export-failure rules because the fixes
          # differ (memory_limiter pressure vs a dead/refusing backend).
          # Names verified against the PINNED collector (v0.154): the old
          # obsreport processor_dropped_* metrics no longer exist, and the
          # manually-configured :8888 reader adds Prometheus _total suffixes.
          # memory_limiter backpressure surfaces as receiver refusal.
          - alert: CollectorDroppingData
            expr: rate(otelcol_receiver_refused_metric_points_total[5m]) > 0
            for: 10m
            labels:
              severity: page
            annotations:
              summary: 'OTel collector {{ $labels.instance }} receiver {{ $labels.receiver }} refusing metric points (memory_limiter backpressure)'

          - alert: CollectorExportFailing
            expr: rate(otelcol_exporter_send_failed_metric_points_total[5m]) > 0
            for: 10m
            labels:
              severity: page
            annotations:
              summary: 'OTel collector {{ $labels.instance }} exporter {{ $labels.exporter }} failing to send metric points'

          # The silent-5xx class. healthz's 503 during a DB outage is
          # intended signaling owned by PodNotReady, so healthz is excluded —
          # by its mux pattern "GET /healthz" (both listeners emit exactly
          # that; the handler label is never a raw path), which is the value
          # TestMetricsSurfacePinned pins. Any other 5xx today is invisible
          # unless a blackbox probe happens to trip it. The app pre-creates
          # the 5xx series at start precisely so this expression's emptiness
          # means health, not absence-of-data.
          - alert: AppErrorRate
            expr: sum(rate(aisucks_http_requests_total{code=~"5..",handler!="GET /healthz"}[5m])) > 0
            for: 5m
            labels:
              severity: page
            annotations:
              summary: 'App 5xx outside healthz: {{ $value }} errors/s sustained for 5m'

          # Company site scaffold: the public-http scrape job supplies
          # app="company-site" on the series, but the metric name is still
          # owned by the app binary until the TanStack server standardizes the
          # web runtime metric catalog.
          - alert: CompanySiteErrorRate
            expr: sum(rate(company_site_http_requests_total{code=~"5..",handler!="GET /healthz"}[5m])) > 0
            for: 5m
            labels:
              severity: page
            annotations:
              summary: 'Company site 5xx outside healthz: {{ $value }} errors/s sustained for 5m'`}}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: vmalert
  namespace: observability
spec:
  replicas: 1
  selector:
    matchLabels:
      app: vmalert
  template:
    metadata:
      labels:
        app: vmalert
    spec:
      containers:
        - name: vmalert
          image: {{.Image}}
          args:
            - -datasource.url=http://victoria-metrics.observability.svc:8428
            - -notifier.url=http://alertmanager.observability.svc:9093
            # Rules ConfigMap edits propagate without a pod restart: kubelet
            # syncs the volume and vmalert re-reads changed rule files.
            - -configCheckInterval=60s
            - -remoteWrite.url=http://victoria-metrics.observability.svc:8428
            - -remoteRead.url=http://victoria-metrics.observability.svc:8428
            - -rule=/etc/vmalert/guardian.rules.yaml
            - -evaluationInterval=15s
          ports:
            - name: http
              containerPort: 8880
          # Hot-plane sizing: rule eval over a handful of series is tiny.
          # The memory limit is a hard cap so a pathological query can never
          # compete with postgres/the app for the box.
          resources:
            requests:
              cpu: 20m
              memory: 48Mi
            limits:
              memory: 128Mi
          readinessProbe:
            httpGet:
              path: /health
              port: 8880
            initialDelaySeconds: 2
            periodSeconds: 5
          volumeMounts:
            - name: rules
              mountPath: /etc/vmalert
      volumes:
        - name: rules
          configMap:
            name: vmalert-rules
