# ClickHouse: the logs/traces ledger of the observability stack. Pod network
# only — reachability is the ClusterIP Service below; nothing here touches the
# host netns, so the node ingress firewall never sees these ports. The
# "observability" Namespace object is owned by the victoria-metrics manifest;
# this manifest assumes it already exists.
#
# The otel schema is NOT created here: k8s/ddl/0001_otel.sql is vendored DDL
# docs/runbooks/ledger.md applies by hand, and the collector runs with
# create_schema: false — the schema is a reviewed, versioned fact, not
# whatever an exporter upgrade decides.
#
# The clickhouse-admin Secret (key: password) is projected from OpenBao by
# External Secrets Operator. Do not create it by hand; `guardian up`
# configures the Bao path and waits for the projected Kubernetes Secret before
# applying ClickHouse.
apiVersion: v1
kind: ConfigMap
metadata:
  name: clickhouse-config
  namespace: observability
data:
  # Dropped into /etc/clickhouse-server/config.d/ where it merges over the
  # image's stock config.xml.
  guardian.xml: |
    <clickhouse>
      <!-- 4 GiB hard server-wide cap, equal to the pod memory limit: the
           ledger must never contend with postgres or the app for the box.
           ClickHouse fails the offending query with MEMORY_LIMIT_EXCEEDED
           before the cgroup OOM-killer gets involved — a failed query is
           the intended failure mode, a killed pod is not. -->
      <max_server_memory_usage>4294967296</max_server_memory_usage>
      <!-- Pod IP only; the ClusterIP Service is the only consumer-visible
           address. -->
      <listen_host>0.0.0.0</listen_host>
      <!-- Console-only logging: kubectl logs (and eventually the collector
           scraping pod stdout) is the log path. Remove the file sinks so
           nothing accumulates under /var/log inside the container. -->
      <logger>
        <console>1</console>
        <log remove="remove"/>
        <errorlog remove="remove"/>
      </logger>
    </clickhouse>
  # Dropped into /etc/clickhouse-server/users.d/. The default user is the
  # ONLY user: the image ships it with an empty password and this override
  # replaces that with the Bao-projected clickhouse-admin Secret, injected
  # as an env var by the Deployment (from_env resolves at server start).
  guardian-users.xml: |
    <clickhouse>
      <users>
        <default>
          <password from_env="CLICKHOUSE_ADMIN_PASSWORD"/>
        </default>
      </users>
    </clickhouse>
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: clickhouse
  namespace: observability
spec:
  replicas: 1
  # Recreate, not RollingUpdate: ClickHouse locks its data directory and a
  # surged second pod against the same hostPath would crashloop until the
  # old one died. Single-node stack; a deploy blip is acceptable here.
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: clickhouse
  template:
    metadata:
      labels:
        app: clickhouse
    spec:
      containers:
        - name: clickhouse
          image: {{.Image}}
          env:
            - name: CLICKHOUSE_ADMIN_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: clickhouse-admin
                  key: password
          ports:
            - name: http
              containerPort: 8123
            - name: native
              containerPort: 9000
          readinessProbe:
            httpGet:
              path: /ping
              port: 8123
            initialDelaySeconds: 5
            periodSeconds: 5
          resources:
            requests:
              cpu: 500m
              memory: 1Gi
            limits:
              # Matches max_server_memory_usage above. Telemetry storage is a
              # tenant on the app's box, never a peer of postgres/the app.
              memory: 4Gi
          volumeMounts:
            - name: data
              mountPath: /var/lib/clickhouse
            # subPath mounts: a ConfigMap edit needs a pod restart to land,
            # which every deploy does anyway. subPath (not whole-dir mounts)
            # keeps the image's stock config.d/users.d contents alongside.
            - name: config
              mountPath: /etc/clickhouse-server/config.d/guardian.xml
              subPath: guardian.xml
            - name: config
              mountPath: /etc/clickhouse-server/users.d/guardian-users.xml
              subPath: guardian-users.xml
      volumes:
        - name: data
          hostPath:
            # EPHEMERAL: /var survives reboots but dies in wipe drills
            # (`guardian down` STATE,EPHEMERAL wipe). R2 backups are the
            # durable record for telemetry, same posture as postgres. The
            # idle ZFS data disk is the better future home once a pool
            # exists on the node.
            path: /var/lib/clickhouse-data
            type: DirectoryOrCreate
        - name: config
          configMap:
            name: clickhouse-config
---
apiVersion: v1
kind: Service
metadata:
  name: clickhouse
  namespace: observability
spec:
  selector:
    app: clickhouse
  ports:
    # 8123: HTTP interface — runbook curl checks and ad-hoc queries.
    - name: http
      port: 8123
    # 9000: native protocol — the otel collector's clickhouse exporter.
    - name: native
      port: 9000
