# Postgres for aisucks: single-node StatefulSet, data on the node's
# persistent tree (same hostPath pattern as seed-registry). The aisucks-db
# Secret (keys: password, url) is created once per site by the operator —
# same manual-secret philosophy as OpenBao init; see the release runbook.
apiVersion: v1
kind: Namespace
metadata:
  name: aisucks
  labels:
    # hostPath volumes are forbidden at Talos's default "baseline" PSA level.
    pod-security.kubernetes.io/enforce: privileged
---
apiVersion: v1
kind: Service
metadata:
  name: postgres
  namespace: aisucks
spec:
  clusterIP: None
  selector:
    app: postgres
  ports:
    - name: pg
      port: 5432
---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: postgres
  namespace: aisucks
spec:
  serviceName: postgres
  replicas: 1
  selector:
    matchLabels:
      app: postgres
  template:
    metadata:
      labels:
        app: postgres
    spec:
      containers:
        - name: postgres
          image: {{.Image}}
          env:
            - name: POSTGRES_USER
              value: aisucks
            - name: POSTGRES_DB
              value: aisucks
            - name: POSTGRES_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: aisucks-db
                  key: password
            - name: PGDATA
              value: /var/lib/postgresql/data/pgdata
          ports:
            - name: pg
              containerPort: 5432
          resources:
            requests:
              cpu: 250m
              memory: 512Mi
            limits:
              memory: 2Gi
          readinessProbe:
            exec:
              command: ["pg_isready", "-U", "aisucks"]
            initialDelaySeconds: 3
            periodSeconds: 5
          volumeMounts:
            - name: data
              mountPath: /var/lib/postgresql/data
      volumes:
        - name: data
          hostPath:
            # /var is the writable persistent tree on Talos; survives pod
            # churn and reboots. `guardian down` (STATE,EPHEMERAL wipe)
            # destroys it — prod data protection is the R2 dump CronJob.
            path: /var/lib/aisucks-postgres
            type: DirectoryOrCreate
