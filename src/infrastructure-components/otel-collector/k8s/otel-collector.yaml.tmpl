# OTel Collector: the metrics spine, plus — on ledger sites
# (clickhouse.enabled) — the log/event tee into the per-site ClickHouse
# (filelog + k8sobjects → clickhouse exporter; docs/runbooks/ledger.md).
# Every ledger addition in this file branches on that flag so a non-ledger
# site renders byte-identical to the metrics-only spine. One collector per
# node scrapes every exporter and remote-writes to the site's
# VictoriaMetrics. It runs
# hostNetwork because most of its targets only exist in the host netns on
# loopback (aisucks :9090, hubble :9965, kubelet :10250, its own :8888) —
# the Talos ingress firewall does not police loopback, so scraping localhost
# needs no firewall change and exposes nothing. ClusterIP targets
# (kube-state-metrics, blackbox-exporter, victoria-metrics) still resolve
# and route from the host netns via Cilium socket-LB + ClusterFirstWithHostNet.
#
# The observability Namespace (privileged PSA) is owned by the
# victoria-metrics manifest; this component assumes it exists.
apiVersion: v1
kind: ServiceAccount
metadata:
  name: otel-collector
  namespace: observability
---
# Kubelet authorizes scrapes of /metrics/cadvisor via SubjectAccessReview:
# the bearer token's subject needs get on nodes/metrics. Pods get/list/watch
# is for the prometheus receiver's PublicHttpService pod discovery; most
# remaining targets are static.
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: otel-collector
rules:
  # Almost every scrape target is a static_config; the only API-authorized
  # path is the kubelet's /metrics/cadvisor, which authorizes as get on
  # nodes/metrics.
  - apiGroups: [""]
    resources:
      - nodes/metrics
    verbs: ["get"]
  # Pod discovery for PublicHttpService metrics. Pod-network public services
  # opt in with platform.guardian.dev/metrics-scrape=true; host-network
  # legacy surfaces keep explicit loopback scrape jobs below.
  - apiGroups: [""]
    resources:
      - pods
    verbs: ["get", "list", "watch"]
{{- if .Site.Clickhouse.Enabled}}
  # k8sobjects receiver: watch mode does an initial list then watches.
  # Events only — the ledger remembers what etcd forgets after 1h. Modern
  # Events live in events.k8s.io; core "" covers v1 Events like guardian's
  # Converged marker.
  - apiGroups: ["", "events.k8s.io"]
    resources:
      - events
    verbs: ["get", "list", "watch"]
{{- end}}
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: otel-collector
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: otel-collector
subjects:
  - kind: ServiceAccount
    name: otel-collector
    namespace: observability
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: otel-collector-config
  namespace: observability
data:
  config.yaml: |
{{- if .Site.Clickhouse.Enabled}}
    extensions:
      # filelog checkpoints: survive pod restarts so logs are neither
      # re-ingested nor dropped across a deploy. hostPath, EPHEMERAL —
      # same wipe-drill posture as the ledger itself.
      file_storage:
        directory: /var/lib/otel-collector
{{- end}}
    # NO OTLP receivers in this release: under hostNetwork they would bind
    # real host ports (4317/4318) on the public NIC — dead weight behind the
    # default-block firewall and a standing invitation to "just open a
    # port". They arrive with the app OTel SDK (the M5 remainder), bound to
    # loopback like everything else here.
    receivers:
      prometheus:
        config:
          global:
            scrape_interval: 15s
            # Stamp every series with the site so dashboards and recording
            # rules stay portable when per-site metrics are later federated.
            external_labels:
              cluster: "{{.Site.Cluster.Name}}"
          scrape_configs:
            # Pod-network public HTTP services: discover every opted-in pod
            # and scrape <podIP>:<metrics-port>. This is the generic
            # Server -> VictoriaMetrics path for TanStack/Nitro servers and
            # other public web surfaces behind PublicHttpService.
            - job_name: public-http
              kubernetes_sd_configs:
                - role: pod
              relabel_configs:
                - source_labels: [__meta_kubernetes_pod_label_platform_guardian_dev_metrics_scrape]
                  regex: "true"
                  action: keep
                # Surge pods have no IP yet; an empty address would scrape
                # ":9090" (the collector's own host netns) — drop them until
                # they are running and addressable.
                - source_labels: [__meta_kubernetes_pod_phase]
                  regex: Running
                  action: keep
                # $${1}/$${2}: the collector's confmap resolver expands ${...}
                # as env-var syntax before prometheus ever sees the config;
                # $$ escapes it so prometheus receives literal capture refs.
                - source_labels:
                    - __meta_kubernetes_pod_ip
                    - __meta_kubernetes_pod_label_platform_guardian_dev_metrics_port
                  separator: ":"
                  regex: (.+):(.+)
                  target_label: __address__
                  replacement: $${1}:$${2}
                - source_labels: [__meta_kubernetes_namespace]
                  target_label: namespace
                - source_labels: [__meta_kubernetes_pod_label_app]
                  target_label: app
                - source_labels: [__meta_kubernetes_pod_label_platform_guardian_dev_slo_surface]
                  target_label: slo_surface
                - source_labels: [__meta_kubernetes_pod_name]
                  target_label: instance
{{- if not .Site.Aisucks.PodNetwork}}
            # Legacy hostNetwork aisucks: scrape loopback from the
            # host-network collector. This disappears when all public HTTP
            # services are pod-networked and labeled for the generic job.
            - job_name: aisucks
              static_configs:
                - targets: ["127.0.0.1:9090"]
{{- end}}
            # Hubble metrics: hostPort 9965 from the Cilium agent (set in
            # src/infrastructure-components/cilium/values.yaml). The agent's
            # own prometheus endpoint (:9962) is NOT in this render —
            # values.yaml never sets prometheus.enabled, so the vendored
            # configmap has no prometheus-serve-addr; scraping it would only
            # produce up=0 noise. Add the job when Cilium is regenerated
            # with agent metrics on (a wipe drill, per the values.yaml note).
            - job_name: hubble
              static_configs:
                - targets: ["127.0.0.1:9965"]
            - job_name: kube-state-metrics
              static_configs:
                - targets: ["kube-state-metrics.observability.svc:8080"]
{{- /* One probe target per cross-site watch URL; the relabel trio sends
       the actual request to the blackbox exporter with the URL as the
       ?target param. Skip the job entirely when nothing is watched (dev). */}}
{{- if or .Site.Aisucks.Watch .Site.Status.Monitor}}
            - job_name: blackbox
              metrics_path: /probe
              params:
                module: [http_2xx]
              static_configs:
                - targets:
{{- range .Site.Aisucks.Watch}}
                    - "{{.}}"
{{- end}}
{{- /* Status hostnames join the probe set only behind status.monitor
       (default OFF): a pre-DNS hostname would emit probe_success == 0 and
       vmalert's SiteProbeFailed pages on 2m of that. Flip per site after
       DNS resolves and the Gateway routes the hostname. */}}
{{- if .Site.Status.Monitor}}
{{- range .Site.Status.Domains}}
                    - "https://{{.}}/healthz"
{{- end}}
{{- end}}
              relabel_configs:
                - source_labels: [__address__]
                  target_label: __param_target
                - source_labels: [__param_target]
                  target_label: instance
                - target_label: __address__
                  replacement: blackbox-exporter.observability.svc:9115
{{- end}}
            # Container CPU/memory from the kubelet's embedded cAdvisor.
            # The kubelet serving cert is self-signed on Talos, hence
            # insecure_skip_verify; auth is the mounted SA token + the
            # nodes/metrics RBAC above. Loopback, so unfirewalled.
            - job_name: cadvisor
              scheme: https
              metrics_path: /metrics/cadvisor
              bearer_token_file: /var/run/secrets/kubernetes.io/serviceaccount/token
              tls_config:
                insecure_skip_verify: true
              static_configs:
                - targets: ["127.0.0.1:10250"]
            - job_name: otelcol-self
              static_configs:
                - targets: ["127.0.0.1:8888"]
            - job_name: victoria-metrics-self
              static_configs:
                - targets: ["victoria-metrics.observability.svc:8428"]
{{- if .Site.Clickhouse.Enabled}}
      filelog:
        include: [/var/log/pods/*/*/*.log]
        # Never ingest our own stdout: an export error would log a line we
        # then try to export — bounded, but a standing noise loop.
        exclude: [/var/log/pods/observability_otel-collector*/*/*.log]
        storage: file_storage
        # Required by the container operator's add_metadata_from_filepath
        # (the path IS the metadata source); without it every entry fails
        # with "log.file.path is missing" and the pipeline ships nothing.
        include_file_path: true
        operators:
          # The container operator (M5: "container parser, no
          # k8sattributes"): parses containerd CRI format, reassembles
          # partial lines, and lifts k8s.{namespace,pod,container}.name +
          # k8s.pod.uid from the file path into resource attributes — no
          # API-server round trip, no extra RBAC.
          - type: container
      k8sobjects:
        auth_type: serviceAccount
        objects:
          - name: events
            mode: watch
{{- end}}
    processors:
      # memory_limiter must be FIRST in the pipeline so backpressure hits
      # the receivers before allocation, not after. The cap + spike pair
      # sits under the container memory limit with headroom for the runtime
      # (ledger sites carry two extra receivers and an exporter queue, so
      # both tiers move together: 384+96 under 512Mi vs 256+64 under 384Mi).
      memory_limiter:
        check_interval: 1s
{{- if .Site.Clickhouse.Enabled}}
        limit_mib: 384
        spike_limit_mib: 96
{{- else}}
        limit_mib: 256
        spike_limit_mib: 64
{{- end}}
      batch: {}
{{- if .Site.Clickhouse.Enabled}}
      # Stamp site identity; the otel_logs MATERIALIZED columns key on these.
      resource/site:
        attributes:
          - key: k8s.cluster.name
            value: "{{.Site.Cluster.Name}}"
            action: upsert
          - key: k8s.node.name
            value: "{{.Site.Node.Hostname}}"
            action: upsert
{{- end}}
    exporters:
      prometheusremotewrite:
        endpoint: http://victoria-metrics.observability.svc:8428/api/v1/write
{{- if .Site.Clickhouse.Enabled}}
      clickhouse:
        # Native protocol via the ClusterIP Service; cluster-local only,
        # nothing crosses the ingress firewall.
        endpoint: tcp://clickhouse.observability.svc:9000
        database: otel
        username: default
        # Optional secret + default-empty: the metrics spine must never be
        # held hostage by ledger secret presence (a missing env var would
        # otherwise fail config resolution at startup).
        password: ${env:CLICKHOUSE_ADMIN_PASSWORD:-}
        # The schema is the reviewed DDL in clickhouse/k8s/ddl/, applied by
        # the ledger runbook — never whatever the exporter would CREATE.
        create_schema: false
        timeout: 10s
{{- end}}
    service:
{{- if .Site.Clickhouse.Enabled}}
      extensions: [file_storage]
{{- end}}
      telemetry:
        # Pin the self-telemetry identity. The SDK defaults are
        # service.name=otelcol-contrib plus a service.instance.id UUID minted
        # per process; those resource attributes override the scrape job's
        # job/instance downstream, so the otelcol-self job surfaced in VM as
        # job=otelcol-contrib with an instance that churned on every pod
        # restart, fragmenting the otelcol_* series the collector
        # self-monitoring rules query. Stable values keep one series identity
        # across restarts (verify after the next converge: up{job="otelcol-self"}).
        resource:
          service.name: otelcol-self
          service.instance.id: "{{.Site.Cluster.Name}}"
        metrics:
          # Own metrics on loopback only: hostNetwork means any other bind
          # address would be a real host listener on the public NIC.
          readers:
            - pull:
                exporter:
                  prometheus:
                    host: "127.0.0.1"
                    port: 8888
      pipelines:
        metrics:
          receivers: [prometheus]
          processors: [memory_limiter, batch]
          exporters: [prometheusremotewrite]
{{- if .Site.Clickhouse.Enabled}}
        logs:
          receivers: [filelog, k8sobjects]
          processors: [memory_limiter, resource/site, batch]
          exporters: [clickhouse]
{{- end}}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: otel-collector
  namespace: observability
spec:
  replicas: 1
  # Recreate, not RollingUpdate: under hostNetwork old and new pods would
  # race for 127.0.0.1:8888 and the new one would crashloop, wedging the
  # rollout (the aisucks binary dodges this with SO_REUSEPORT; the collector
  # has no such mechanism). A scrape-interval-sized metrics gap per deploy
  # is the accepted cost.
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: otel-collector
  template:
    metadata:
      labels:
        app: otel-collector
      annotations:
        # The collector does not reload its ConfigMap in place. Roll the pod
        # whenever the rendered manifest inputs change so `guardian up`
        # converges config changes without a manual restart.
        guardian.dev/render-sha256: "{{.RenderHash}}"
    spec:
      serviceAccountName: otel-collector
      hostNetwork: true
      # Cluster DNS must keep resolving *.observability.svc from the host
      # network namespace.
      dnsPolicy: ClusterFirstWithHostNet
      containers:
        - name: otel-collector
          image: {{.Image}}
          args:
            - --config=/conf/config.yaml
{{- if .Site.Clickhouse.Enabled}}
          # filelog reads /var/log/pods, which the kubelet writes root-owned
          # 0640; the contrib image's default uid (10001) cannot read them.
          # A real privilege increase on a hostNetwork pod — bounded by the
          # read-only mount, the namespace's already-privileged PSA (label
          # owned by the victoria-metrics manifest), the single-node
          # cluster, and this being the standard posture for node log
          # agents.
          securityContext:
            runAsUser: 0
          env:
            # optional: the metrics spine must start (and keep alerting
            # alive) whether or not the ledger secret exists yet; the
            # exporter config defaults the password empty to match.
            - name: CLICKHOUSE_ADMIN_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: clickhouse-admin
                  key: password
                  optional: true
{{- end}}
          # No ports block: under hostNetwork declared containerPorts count
          # as host-port claims against the scheduler (see the aisucks
          # manifest for the gamma incident). The only listener is
          # 127.0.0.1:8888 (telemetry above).
          resources:
{{- if .Site.Clickhouse.Enabled}}
            # Ledger tier: two extra receivers + the clickhouse exporter
            # queue over the metrics-only 192Mi/384Mi.
            requests:
              cpu: 100m
              memory: 256Mi
            limits:
              memory: 512Mi
{{- else}}
            requests:
              cpu: 100m
              memory: 192Mi
            limits:
              memory: 384Mi
{{- end}}
          volumeMounts:
            - name: config
              mountPath: /conf
{{- if .Site.Clickhouse.Enabled}}
            - name: varlogpods
              mountPath: /var/log/pods
              readOnly: true
            - name: checkpoints
              mountPath: /var/lib/otel-collector
{{- end}}
      volumes:
        - name: config
          configMap:
            name: otel-collector-config
{{- if .Site.Clickhouse.Enabled}}
        - name: varlogpods
          hostPath:
            path: /var/log/pods
        - name: checkpoints
          hostPath:
            # EPHEMERAL, like /var/lib/clickhouse-data: a wipe drill erases
            # checkpoints and ledger together, so post-wipe re-ingest cannot
            # duplicate into surviving data.
            path: /var/lib/otel-collector
            type: DirectoryOrCreate
{{- end}}
