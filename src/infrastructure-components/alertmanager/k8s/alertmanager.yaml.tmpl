# Alertmanager: routing, grouping, and throttling for alerts fired by the
# metrics plane. Delivery goes straight to ntfy.sh — no bridge pod — using
# ntfy's built-in server-side "alertmanager" message template: appending
# ?template=alertmanager to the publish URL makes ntfy render Alertmanager's
# native webhook JSON into a readable firing/resolved push (docs.ntfy.sh,
# "Message templating", pre-defined templates). The topic is the same one
# Gatus pages (environment alerts.ntfyTopic): one phone subscription covers
# both alert paths.
#
# The observability Namespace and VictoriaMetrics Service are owned by the
# ObservabilityStack XR; this component assumes they exist.
#
# Alertmanager only re-reads its config on SIGHUP or restart; `kubectl apply`
# of this ConfigMap alone (e.g. a topic rotation with an unchanged image)
# needs a `kubectl -n observability rollout restart deploy/alertmanager`.
apiVersion: v1
kind: ConfigMap
metadata:
  name: alertmanager-config
  namespace: observability
data:
  alertmanager.yml: |
    route:
      receiver: ntfy
      group_by: ["alertname"]
      group_wait: 30s
      group_interval: 5m
      repeat_interval: 4h
    receivers:
      - name: ntfy
{{- /* A receiver with no configs is valid Alertmanager: without a topic
       (a site before its ntfy topic is minted) alerts still route, dedupe,
       and show in the API/UI — they just page nobody. */}}
{{- if .Site.Aisucks.NtfyTopic}}
        webhook_configs:
          - url: "https://ntfy.sh/{{.Site.Aisucks.NtfyTopic}}?template=alertmanager"
            send_resolved: true
            # ntfy.sh caps a message at ~4KiB; bound the batch so a wide
            # outage can't push the rendered notification past the limit
            # (the template prints per-alert lines).
            max_alerts: 8
{{- end}}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: alertmanager
  namespace: observability
spec:
  replicas: 1
  selector:
    matchLabels:
      app: alertmanager
  template:
    metadata:
      labels:
        app: alertmanager
    spec:
      # Pod network, not host: the only client is vmalert (pod-to-pod is
      # unpoliced by the Talos ingress firewall) and ClusterIPs resolve from
      # the host netns anyway via Cilium's socket-LB if a human needs the UI
      # over `kubectl port-forward`.
      containers:
        - name: alertmanager
          image: {{.Image}}
          args:
            - --config.file=/etc/alertmanager/alertmanager.yml
            - --storage.path=/alertmanager
            # Single replica on a single-node cluster: disable the HA gossip
            # listener (defaults to 0.0.0.0:9094) — no peer will ever exist.
            - --cluster.listen-address=
          ports:
            - name: web
              containerPort: 9093
          readinessProbe:
            httpGet:
              path: /-/ready
              port: web
            initialDelaySeconds: 2
            periodSeconds: 5
          resources:
            requests:
              cpu: 20m
              memory: 48Mi
            limits:
              memory: 128Mi
          volumeMounts:
            - name: config
              mountPath: /etc/alertmanager
            - name: storage
              mountPath: /alertmanager
      volumes:
        - name: config
          configMap:
            name: alertmanager-config
        - name: storage
          # Silences and the notification log only. Droppable: after a
          # restart a still-firing alert simply re-pages, which is the
          # behavior we want on a box that just rebooted.
          emptyDir: {}
---
apiVersion: v1
kind: Service
metadata:
  name: alertmanager
  namespace: observability
spec:
  selector:
    app: alertmanager
  ports:
    - name: web
      port: 9093
      targetPort: web
