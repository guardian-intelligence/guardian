# Gatus: blackbox monitoring + paging for aisucks. Probes go out to the
# node's public address — the same path a visitor takes — so a dead hostPort,
# a wedged pod, or a node off the network all look like what they are: down.
# Alerts page via ntfy.sh (push topic; subscribe in the ntfy app). The topic
# is unguessable but lives in the environment bundle; rotate it before the repo goes
# public (charter: open code). Cross-site watch targets come from
# environment products.aisucks.watch once more sites enroll.
apiVersion: v1
kind: ConfigMap
metadata:
  name: gatus-config
  namespace: aisucks
data:
  config.yaml: |
{{- if .Site.Aisucks.NtfyTopic}}
    alerting:
      ntfy:
        url: "https://ntfy.sh"
        topic: "{{.Site.Aisucks.NtfyTopic}}"
        priority: 4
        default-alert:
          enabled: true
          failure-threshold: 3
          success-threshold: 2
          send-on-resolved: true
{{- end}}
    endpoints:
{{- /* With a domain, :80 only redirects to HTTPS; probe the real serving
       path a visitor takes. Without one (dev, pre-DNS), probe the node. */}}
{{- $base := printf "http://%s" .Site.Node.Address}}
{{- if .Site.Aisucks.Domain}}{{$base = printf "https://%s" .Site.Aisucks.Domain}}{{end}}
      - name: aisucks-healthz ({{.Site.Cluster.Name}})
        url: "{{$base}}/healthz"
        interval: 30s
        conditions:
          - "[STATUS] == 200"
{{- if .Site.Aisucks.NtfyTopic}}
        alerts:
          - type: ntfy
{{- end}}
      - name: aisucks-page ({{.Site.Cluster.Name}})
        url: "{{$base}}/"
        interval: 30s
        conditions:
          - "[STATUS] == 200"
          # Match the charter-locked promise text, not marketing copy: it is
          # verbatim and changes only by charter amendment, so a page redesign
          # can't silently break the monitor (it did once — the old
          # "EVIDENCE LOCKER" marker vanished in the TanStack rewrite).
          - "[BODY] == pat(*never be sold*)"
{{- if .Site.Aisucks.NtfyTopic}}
        alerts:
          - type: ntfy
{{- end}}
{{- if .Site.Company.Domain}}
{{- $companyBase := "http://company-site-probe.company.svc"}}
      - name: company-healthz ({{.Site.Cluster.Name}})
        url: "{{$companyBase}}/healthz"
        interval: 30s
        conditions:
          - "[STATUS] == 200"
{{- if .Site.Aisucks.NtfyTopic}}
        alerts:
          - type: ntfy
{{- end}}
      - name: company-home ({{.Site.Cluster.Name}})
        url: "{{$companyBase}}/"
        interval: 30s
        conditions:
          - "[STATUS] == 200"
          - "[BODY] == pat(*Guardian Intelligence*)"
{{- if .Site.Aisucks.NtfyTopic}}
        alerts:
          - type: ntfy
{{- end}}
      - name: company-letters ({{.Site.Cluster.Name}})
        url: "{{$companyBase}}/letters"
        interval: 30s
        conditions:
          - "[STATUS] == 200"
          - "[BODY] == pat(*The Coding Agent is the Next Smartphone*)"
{{- if .Site.Aisucks.NtfyTopic}}
        alerts:
          - type: ntfy
{{- end}}
      - name: company-news ({{.Site.Cluster.Name}})
        url: "{{$companyBase}}/news"
        interval: 30s
        conditions:
          - "[STATUS] == 200"
          - "[BODY] == pat(*Guardian Intelligence Inc. announces private beta of Verself.*)"
{{- if .Site.Aisucks.NtfyTopic}}
        alerts:
          - type: ntfy
{{- end}}
{{- end}}
{{- range $i, $target := .Site.Aisucks.Watch}}
      - name: watch-{{$i}}
        url: "{{$target}}"
        interval: 30s
        conditions:
          - "[STATUS] == 200"
{{- if $.Site.Aisucks.NtfyTopic}}
        alerts:
          - type: ntfy
{{- end}}
{{- end}}
{{- range $i, $target := .Site.Aisucks.WatchPages}}
      # Cross-site page checks carry the charter marker, not only status:
      # otherwise a healthy-DB, broken-page state is seen by no watcher but
      # the site's own.
      - name: watch-page-{{$i}}
        url: "{{$target}}"
        interval: 30s
        conditions:
          - "[STATUS] == 200"
          - "[BODY] == pat(*never be sold*)"
{{- if $.Site.Aisucks.NtfyTopic}}
        alerts:
          - type: ntfy
{{- end}}
{{- end}}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: gatus
  namespace: aisucks
spec:
  replicas: 1
  selector:
    matchLabels:
      app: gatus
  template:
    metadata:
      labels:
        app: gatus
    spec:
{{- if and .Site.Aisucks.PodNetwork .Site.Aisucks.Domain}}
      # Pod-network sites: the public-URL self-probes cannot hairpin through
      # the hostNetwork Envoy listener (cilium/cilium#36004 — see the
      # probe Services rendered by PublicHttpService, whose ClusterIPs these
      # aliases pin). Same URLs, same SNI, full TLS verification — measuring app
      # + certificate from in-cluster; the edge listener is the sibling watchers'
      # job.
      hostAliases:
        - ip: 10.96.111.43
          hostnames:
            - "{{.Site.Aisucks.Domain}}"
{{- end}}
      containers:
        - name: gatus
          image: {{.Image}}
          env:
            - name: GATUS_CONFIG_PATH
              value: /config/config.yaml
          ports:
            - name: web
              containerPort: 8080
          resources:
            requests:
              cpu: 50m
              memory: 64Mi
            limits:
              memory: 256Mi
          volumeMounts:
            - name: config
              mountPath: /config
      volumes:
        - name: config
          configMap:
            name: gatus-config
