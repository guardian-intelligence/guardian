load("@io_bazel_rules_go//go:def.bzl", "go_binary", "go_library", "go_test")

go_library(
    name = "sdkoci_lib",
    srcs = ["main.go"],
    importpath = "github.com/guardian-intelligence/guardian/src/release/cmd/sdkoci",
    visibility = ["//visibility:private"],
    deps = [
        "@com_github_opencontainers_image_spec//specs-go/v1:specs-go",
        "@land_oras_oras_go_v2//:oras-go",
        "@land_oras_oras_go_v2//content/oci",
        "@land_oras_oras_go_v2//registry/remote",
        "@land_oras_oras_go_v2//registry/remote/auth",
        "@land_oras_oras_go_v2//registry/remote/retry",
    ],
)

go_binary(
    name = "sdkoci",
    embed = [":sdkoci_lib"],
    visibility = ["//visibility:public"],
)

go_test(
    name = "sdkoci_test",
    srcs = ["main_test.go"],
    embed = [":sdkoci_lib"],
    deps = ["@land_oras_oras_go_v2//content/oci"],
)
