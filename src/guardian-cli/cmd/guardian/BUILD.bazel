load("@io_bazel_rules_go//go:def.bzl", "go_binary", "go_library", "go_test")

go_library(
    name = "guardian_lib",
    srcs = [
        "bao_bootstrap.go",
        "config.go",
        "devtools.go",
        "down.go",
        "main.go",
        "platform_tls.go",
        "push.go",
        "render.go",
        "restore.go",
        "run.go",
        "schematic.go",
        "site.go",
        "tls.go",
        "tools.go",
        "up.go",
    ],
    importpath = "github.com/guardian-intelligence/guardian/src/guardian-cli/cmd/guardian",
    visibility = ["//visibility:private"],
    deps = [
        "@com_github_google_go_containerregistry//pkg/name",
        "@com_github_google_go_containerregistry//pkg/v1:pkg",
        "@com_github_google_go_containerregistry//pkg/v1/layout",
        "@com_github_google_go_containerregistry//pkg/v1/remote",
        "@in_gopkg_yaml_v3//:yaml_v3",
        "@io_bazel_rules_go//go/runfiles",
        "@org_golang_x_crypto//bcrypt",
    ],
)

go_binary(
    name = "guardian",
    data = [
        "//src/guardian-cli/tools/kubectl",
        "//src/guardian-cli/tools/talosctl",
        "//src/infrastructure-components/alertmanager:image",
