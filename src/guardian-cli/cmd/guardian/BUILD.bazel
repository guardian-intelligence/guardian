        "//src/infrastructure-components/cilium:talos-patches",
        "//src/infrastructure-components/clickhouse:image",
        "//src/infrastructure-components/crossplane:image",
        "//src/infrastructure-components/crossplane:manifest",
        "//src/infrastructure-components/crossplane-provider-kubernetes:manifest",
        "//src/infrastructure-components/external-secrets:image",
        "//src/infrastructure-components/external-secrets:manifest",
