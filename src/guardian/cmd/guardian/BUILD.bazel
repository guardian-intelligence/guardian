load("@rules_go//go:def.bzl", "go_binary", "go_library", "go_test")

go_library(
    name = "guardian_lib",
    srcs = ["main.go"],
    importpath = "github.com/guardian-intelligence/guardian/src/guardian/cmd/guardian",
    visibility = ["//visibility:private"],
)

go_binary(
    name = "guardian",
    embed = [":guardian_lib"],
    visibility = ["//visibility:public"],
)

go_test(
    name = "guardian_test",
    srcs = ["main_test.go"],
    embed = [":guardian_lib"],
)
