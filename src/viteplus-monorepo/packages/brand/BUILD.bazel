load("@aspect_rules_js//js:defs.bzl", "js_library")

BRAND_SRCS = glob([
    "package.json",
    "src/**/*",
    "tsconfig.json",
])

filegroup(
    name = "package_manifest",
    srcs = ["package.json"],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "sources",
    srcs = BRAND_SRCS,
    visibility = ["//visibility:public"],
)

js_library(
    name = "pkg",
    srcs = BRAND_SRCS,
    visibility = ["//visibility:public"],
)
