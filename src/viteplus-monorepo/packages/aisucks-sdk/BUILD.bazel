filegroup(
    name = "package_manifest",
    srcs = ["package.json"],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "sources",
    srcs = glob([
        "CHANGELOG.md",
        "README.md",
        "package.json",
        "src/**/*",
        "tsconfig*.json",
    ]),
    visibility = ["//visibility:public"],
)

filegroup(
    name = "generated_sources",
    srcs = glob(["src/gen/**/*.ts"]),
    visibility = ["//visibility:public"],
)
