{
  "name": "@guardian-intelligence/aisucks",
  "version": "0.3.0",
  "description": "Tiny SDK for the aisucks.app public API.",
  "homepage": "https://github.com/guardian-intelligence/guardian/tree/main/src/viteplus-monorepo/packages/aisucks-sdk#readme",
  "bugs": {
    "url": "https://github.com/guardian-intelligence/guardian/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guardian-intelligence/guardian.git",
    "directory": "src/viteplus-monorepo/packages/aisucks-sdk"
  },
  "files": [
    "CHANGELOG.md",
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.release.json",
    "build": "tsc -p tsconfig.build.json",
    "pack:dry-run": "npm pack --dry-run",
    "release": "tsx ./release/main.ts",
    "release:check": "tsx ./release/main.ts --mode check"
  },
  "dependencies": {
    "@bufbuild/protobuf": "catalog:",
    "@connectrpc/connect": "catalog:",
    "@connectrpc/connect-web": "catalog:"
  },
  "devDependencies": {
    "@sigstore/bundle": "catalog:",
    "effect": "catalog:",
    "npm": "catalog:",
    "sigstore": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
