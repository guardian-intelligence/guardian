EOF
""",
    tools = ["@helm_linux_amd64//:helm"],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "all",
    srcs = glob(["**/*"]) + [
        ":cert-manager",
        ":crossplane",
        ":external-secrets",
    ],
    visibility = ["//visibility:public"],
)
