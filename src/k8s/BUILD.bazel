    outs = [
        "bootstrap/external-secrets/base/external-secrets.yaml",
        "bootstrap/external-secrets/base/kustomization.yaml",
    ],
    cmd = """
set -euo pipefail
yaml="$(RULEDIR)/bootstrap/external-secrets/base/external-secrets.yaml"
kustomization="$(RULEDIR)/bootstrap/external-secrets/base/kustomization.yaml"
mkdir -p "$$(dirname "$$yaml")"
