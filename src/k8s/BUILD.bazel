  printf '# Generated from external-secrets Helm chart 2.6.0 (sha256:f3659c0085a41e1be5c016cf186b80aac262ef249a91b1b770b941f18296ef3f).\\n'
  printf '# Do not edit this output; edit src/k8s/BUILD.bazel and upstream pins in MODULE.bazel.\\n'
  printf -- '---\\n'
  printf 'apiVersion: v1\\nkind: Namespace\\nmetadata:\\n  name: external-secrets\\n'
  printf -- '---\\n'
  "$(execpath @helm_linux_amd64//:helm)" template external-secrets "$(location @external_secrets_chart//file)" \
