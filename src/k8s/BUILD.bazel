genrule(
    name = "crossplane",
    srcs = [
        "@crossplane_source//:chart",
        "@crossplane_source//:chart_yaml",
        "@crossplane_source//:crds",
    ],
    outs = [
        "bootstrap/crossplane/base/crossplane.yaml",
        "bootstrap/crossplane/base/kustomization.yaml",
    ],
    cmd = """
set -euo pipefail
yaml="$(RULEDIR)/bootstrap/crossplane/base/crossplane.yaml"
kustomization="$(RULEDIR)/bootstrap/crossplane/base/kustomization.yaml"
mkdir -p "$$(dirname "$$yaml")"
chart_dir="$$(dirname "$(location @crossplane_source//:chart_yaml)")"
{
  printf '# Generated from Crossplane source tag v2.3.2 (sha256:7b2ca515347700ce5468782b1c27b4e784214b9cfabebb5d1c548e53904c1137).\\n'
  printf '# Do not edit this output; edit src/k8s/BUILD.bazel and upstream pins in MODULE.bazel.\\n'
  printf -- '---\\n'
  printf 'apiVersion: v1\\nkind: Namespace\\nmetadata:\\n  name: crossplane-system\\n'
  for crd in $(locations @crossplane_source//:crds); do
    printf -- '---\\n'
    cat "$$crd"
    printf '\\n'
  done
  printf -- '---\\n'
  "$(execpath @helm_linux_amd64//:helm)" template crossplane "$$chart_dir" \
    --namespace crossplane-system \
    --set image.repository=xpkg.crossplane.io/crossplane/crossplane \
    --set image.tag=v2.3.2
} | sed 's#image: "xpkg.crossplane.io/crossplane/crossplane:v2.3.2"#image: registry.guardian.internal/crossplane:bootstrap#g' > "$$yaml"
cat > "$$kustomization" <<'EOF'
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization
resources:
  - crossplane.yaml
images:
  - name: registry.guardian.internal/crossplane
    newName: registry.guardian.internal/crossplane
    newTag: bootstrap
EOF
""",
    tools = ["@helm_linux_amd64//:helm"],
    visibility = ["//visibility:public"],
)

genrule(
    name = "cert-manager",
    srcs = ["@cert_manager_chart//file"],
    outs = [
        "bootstrap/cert-manager/base/cert-manager.yaml",
        "bootstrap/cert-manager/base/kustomization.yaml",
    ],
    cmd = """
set -euo pipefail
yaml="$(RULEDIR)/bootstrap/cert-manager/base/cert-manager.yaml"
kustomization="$(RULEDIR)/bootstrap/cert-manager/base/kustomization.yaml"
mkdir -p "$$(dirname "$$yaml")"
{
  printf '# Generated from cert-manager Helm chart v1.20.2 (sha256:d2a50bd44a09d838c2576a8f3dfca1524597c7393cf8d82ab3ec8a465b9eeb79).\\n'
  printf '# Do not edit this output; edit src/k8s/BUILD.bazel and upstream pins in MODULE.bazel.\\n'
  printf -- '---\\n'
  printf 'apiVersion: v1\\nkind: Namespace\\nmetadata:\\n  name: cert-manager\\n  labels:\\n    pod-security.kubernetes.io/enforce: privileged\\n'
  printf -- '---\\n'
  "$(execpath @helm_linux_amd64//:helm)" template cert-manager "$(location @cert_manager_chart//file)" \
    --namespace cert-manager \
    --include-crds \
    --set crds.enabled=true \
    --set config.enableGatewayAPI=true \
    --set image.digest=sha256:fe0623d7d04a382c888f03343a3a2da716e0d96ad3d5d790c0ebcbcb2a4329a5 \
    --set cainjector.image.digest=sha256:6f5a644135887b2aa7d5cc145072fa56421560e3586ff1f184358022d490f4e1 \
    --set webhook.image.digest=sha256:baf651128b9f05c426cbd5e60e2036bf382c99ca270f49d0757d6f7d2452f4e5 \
    --set startupapicheck.image.digest=sha256:4e2a69b4a0cc9627905bbeecf720f95d5153ca39cacdab923d2748e73556792b \
    --set acmesolver.image.digest=sha256:cfa55e9c3dcfc6a3cba97575748c1549b04a30fd14d88a2fcb9e2dddef415e2f
} | sed \
  -e 's#image: "quay.io/jetstack/cert-manager-cainjector@sha256:6f5a644135887b2aa7d5cc145072fa56421560e3586ff1f184358022d490f4e1"#image: registry.guardian.internal/cert-manager-cainjector:bootstrap#g' \
  -e 's#image: "quay.io/jetstack/cert-manager-controller@sha256:fe0623d7d04a382c888f03343a3a2da716e0d96ad3d5d790c0ebcbcb2a4329a5"#image: registry.guardian.internal/cert-manager-controller:bootstrap#g' \
  -e 's#image: "quay.io/jetstack/cert-manager-webhook@sha256:baf651128b9f05c426cbd5e60e2036bf382c99ca270f49d0757d6f7d2452f4e5"#image: registry.guardian.internal/cert-manager-webhook:bootstrap#g' \
  -e 's#image: "quay.io/jetstack/cert-manager-startupapicheck@sha256:4e2a69b4a0cc9627905bbeecf720f95d5153ca39cacdab923d2748e73556792b"#image: registry.guardian.internal/cert-manager-startupapicheck:bootstrap#g' \
  -e 's#--acme-http01-solver-image=quay.io/jetstack/cert-manager-acmesolver@sha256:cfa55e9c3dcfc6a3cba97575748c1549b04a30fd14d88a2fcb9e2dddef415e2f#--acme-http01-solver-image=registry.guardian.internal/cert-manager-acmesolver:bootstrap#g' \
  -e '/serviceAccountName: cert-manager$$/a\\      hostNetwork: true\\n      dnsPolicy: ClusterFirstWithHostNet' \
  > "$$yaml"
cat > "$$kustomization" <<'EOF'
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization
resources:
  - cert-manager.yaml
images:
  - name: registry.guardian.internal/cert-manager-cainjector
    newName: registry.guardian.internal/cert-manager-cainjector
    newTag: bootstrap
  - name: registry.guardian.internal/cert-manager-controller
    newName: registry.guardian.internal/cert-manager-controller
    newTag: bootstrap
  - name: registry.guardian.internal/cert-manager-webhook
    newName: registry.guardian.internal/cert-manager-webhook
    newTag: bootstrap
  - name: registry.guardian.internal/cert-manager-startupapicheck
    newName: registry.guardian.internal/cert-manager-startupapicheck
    newTag: bootstrap
  - name: registry.guardian.internal/cert-manager-acmesolver
    newName: registry.guardian.internal/cert-manager-acmesolver
    newTag: bootstrap
EOF
""",
    tools = ["@helm_linux_amd64//:helm"],
    visibility = ["//visibility:public"],
)

genrule(
    name = "external-secrets",
