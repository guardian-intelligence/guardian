# aisucks.app web service. hostNetwork + SO_REUSEPORT in the binary is the
# zero-downtime-deploy mechanism on a single box: during a rolling update
# (maxUnavailable 0) old and new pods bind :80/:443 simultaneously, the
# kernel balances, the old pod drains on SIGTERM. Postgres is shared by
# both pods (it's a database); the cert cache is shared safely (certmagic
# FileStorage locks). Site-specific values (domain) render from site.yaml's
# aisucks section; an empty domain serves plain HTTP on :80 (dev, pre-DNS).
apiVersion: v1
kind: Namespace
metadata:
  name: aisucks
  labels:
    pod-security.kubernetes.io/enforce: privileged
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: aisucks
  namespace: aisucks
spec:
  # Two pods, one node: SO_REUSEPORT under hostNetwork means both bind
  # :80/:443 and the kernel balances between them — the same proven mechanism
  # that makes the rolling update zero-downtime.
  # One replica. Two hostNetwork replicas would share 127.0.0.1:9090 via
  # SO_REUSEPORT and scrapes would alternate between two counter sets under
  # one series identity — rate() reads the flips as resets. Zero-downtime
  # deploys do not need 2 (maxSurge provides the overlap, proven 240/240
  # under hammer; the same brief scrape skew applies during each deploy
  # window — accepted). 2 returns when the app pushes OTLP with per-pod
  # resource attributes (release 3).
  replicas: 1
  strategy:
    type: RollingUpdate
    rollingUpdate:
      maxSurge: 1
      maxUnavailable: 0
  selector:
    matchLabels:
      app: aisucks
  template:
    metadata:
      labels:
        app: aisucks
    spec:
      hostNetwork: true
      # Cluster DNS must keep resolving postgres.aisucks.svc from the host
      # network namespace.
      dnsPolicy: ClusterFirstWithHostNet
      terminationGracePeriodSeconds: 30
      containers:
        - name: aisucks
          image: {{.Image}}
          env:
            - name: DOMAIN
              value: "{{.Site.Aisucks.Domain}}"
            - name: ACME_EMAIL
              value: "im.shovonhasan@gmail.com"
            - name: CERT_DIR
              value: /var/lib/aisucks-certs
            - name: INGEST
              value: "{{.Site.Aisucks.Ingest}}"
            # ~80% of the 512Mi memory limit: the Go runtime GCs harder as it
            # nears this instead of hitting the cgroup wall and getting
            # OOM-killed.
            - name: GOMEMLIMIT
              value: "410MiB"
            - name: DATABASE_URL
              valueFrom:
                secretKeyRef:
                  name: aisucks-db
                  key: url
          # No ports block: under hostNetwork the scheduler counts declared
          # containerPorts as host-port claims, which would deadlock rolling
          # updates (new pod unschedulable while the old one runs — found
          # live on gamma, v3→v4). The binary binds :80/:443 itself.
          resources:
            requests:
              cpu: 100m
              memory: 128Mi
            limits:
              memory: 512Mi
          readinessProbe:
            httpGet:
              path: /healthz
              port: 80
            initialDelaySeconds: 2
            periodSeconds: 5
          # Deliberately generous (a minute of failures before a kill): a
          # false-positive liveness kill is worse than slow detection. /livez
          # is process-alive only, no database dependency — a Postgres outage
          # must not get the app restarted by kubelet.
          # The startup probe covers openStore's deliberate 5-minute
          # postgres-wait (the listeners bind only after the DB answers):
          # liveness arms only after first success, so a cold boot is never
          # kill-looped by kubelet — the exact failure the DB retry exists
          # to prevent. 36 x 10s = 6min > the 5min openStore patience.
          startupProbe:
            httpGet:
              path: /livez
              port: 80
            periodSeconds: 10
            failureThreshold: 36
          livenessProbe:
            httpGet:
              path: /livez
              port: 80
            initialDelaySeconds: 10
            periodSeconds: 10
            failureThreshold: 6
          volumeMounts:
            - name: certs
              mountPath: /var/lib/aisucks-certs
      volumes:
        - name: certs
          hostPath:
            path: /var/lib/aisucks-certs
            type: DirectoryOrCreate
