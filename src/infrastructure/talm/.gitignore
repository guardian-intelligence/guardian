# Secret-zero / PKI — NEVER commit (clean-slate rebuild regenerates these via
# `talm gen secrets`). These live only on the release runner's filesystem.
secrets.yaml
secrets.encrypted.yaml
talosconfig
talosconfig.encrypted
talm.key
kubeconfig

# Per-node Talm patches are canonical source for host-specific, non-secret
# facts such as disk serials, public endpoints, and VLAN addresses. Keep them
# tracked so a clean checkout can exercise the management-cluster bootstrap path
# without local inventory state.
