{{- $s := .Service -}}
# Generic public HTTP service envelope. This is the direct-rendered
# implementation of the future platform.guardian.dev/PublicHttpService XR:
# product code supplies an image and domain; the platform supplies namespace,
# pod-network/host-network serving, TLS custody, Service shape, probes, and
# the diagnostics port scraped by OTel.
apiVersion: v1
kind: Namespace
metadata:
  name: {{$s.Namespace}}
  labels:
    pod-security.kubernetes.io/enforce: privileged
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{$s.App}}
  namespace: {{$s.Namespace}}
spec:
  replicas: {{$s.Replicas}}
  selector:
    matchLabels:
      app: {{$s.App}}
{{- if not $s.PodNetwork}}
  strategy:
    type: Recreate
{{- end}}
  template:
    metadata:
      labels:
        app: {{$s.App}}
{{- if $s.PodNetwork}}
        {{$s.NetworkLabelKey}}: {{$s.NetworkLabelVal}}
{{- end}}
    spec:
{{- if not $s.PodNetwork}}
      hostNetwork: true
      dnsPolicy: ClusterFirstWithHostNet
{{- end}}
      securityContext:
        seccompProfile:
          type: RuntimeDefault
      terminationGracePeriodSeconds: 30
      containers:
        - name: {{$s.App}}
          image: {{.Image}}
          securityContext:
            allowPrivilegeEscalation: false
            capabilities:
              drop:
                - ALL
              add:
                - NET_BIND_SERVICE
          env:
            - name: DOMAIN
              value: "{{$s.Domain}}"
            - name: ACME_EMAIL
              value: "{{$s.ACMEEmail}}"
            - name: CERT_DIR
              value: {{$s.CertDir}}
            - name: LISTEN_HTTP
              value: "{{$s.ListenHTTP}}"
            - name: LISTEN_TLS
              value: "{{$s.ListenTLS}}"
            - name: DIAG_ADDR
              value: "{{$s.DiagAddr}}"
            - name: GOMEMLIMIT
              value: "{{$s.GoMemoryLimit}}"
          ports:
            - name: http
              containerPort: {{$s.HTTPPort}}
            - name: https
              containerPort: {{$s.HTTPSPort}}
            - name: metrics
              containerPort: {{$s.MetricsPort}}
          resources:
            requests:
              cpu: {{$s.CPURequest}}
              memory: {{$s.MemoryRequest}}
            limits:
              memory: {{$s.MemoryLimit}}
          readinessProbe:
            httpGet:
              path: {{$s.HealthPath}}
              port: http
            initialDelaySeconds: 2
            periodSeconds: {{$s.ReadinessPeriod}}
          volumeMounts:
            - name: certs
              mountPath: {{$s.CertDir}}
      volumes:
        - name: certs
          hostPath:
            path: {{$s.CertDir}}
            type: DirectoryOrCreate
---
apiVersion: v1
kind: Service
metadata:
  name: {{$s.App}}
  namespace: {{$s.Namespace}}
spec:
  selector:
    app: {{$s.App}}
  ports:
    - name: https
      port: 443
      targetPort: https
    - name: http
      port: 80
      targetPort: http
{{- if and $s.PodNetwork $s.ProbeClusterIP}}
---
# Stable in-cluster probe vantage for public-domain self checks. Pods cannot
# reliably hairpin through the host-network Envoy listener, so Gatus aliases
# {{$s.Domain}} to this ClusterIP and still performs full TLS/SNI validation.
apiVersion: v1
kind: Service
metadata:
  name: {{$s.App}}-probe
  namespace: {{$s.Namespace}}
spec:
  clusterIP: {{$s.ProbeClusterIP}}
  selector:
    app: {{$s.App}}
    {{$s.NetworkLabelKey}}: {{$s.NetworkLabelVal}}
  ports:
    - name: https
      port: 443
      targetPort: https
    - name: http
      port: 80
      targetPort: http
{{- end}}
