{
  "name": "@guardian/visual-harness",
  "version": "0.1.0",
  "private": true,
  "description": "Deterministic Playwright visual capture, drift, and fold canaries for Guardian web surfaces",
  "type": "module",
  "scripts": {
    "typecheck": "vp exec tsc -p tsconfig.json",
