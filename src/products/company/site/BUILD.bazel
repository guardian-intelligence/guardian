load("@rules_oci//oci:defs.bzl", "oci_load", "oci_push")

alias(
    name = "image",
    actual = "//src/products/company/web:image",
    visibility = ["//visibility:public"],
)

oci_load(
    name = "load",
    image = ":image",
    repo_tags = ":repo_tags.txt",
)

oci_push(
    name = "push-harbor",
    image = ":image",
    remote_tags = ["edge"],
    repository = "harbor.guardianintelligence.org/guardian/company-site",
    visibility = ["//visibility:public"],
)
