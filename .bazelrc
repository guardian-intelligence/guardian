build --incompatible_strict_action_env
test --test_output=errors

# Clippy findings (including the pedantic tier enabled at each crate root)
# fail the build rather than scroll past as warnings.
build --@rules_rust//rust/settings:clippy_flags=-Dwarnings

# CI persists this root across runs via actions/cache (build.yml): action
# outputs and fetched external archives survive the ephemeral runner, so a
# PR build re-executes only what its diff invalidates. GC bounds what a main
# run saves back.
common:ci --disk_cache=~/.cache/bazel-ci/disk
common:ci --repository_cache=~/.cache/bazel-ci/repo
common:ci --experimental_disk_cache_gc_max_size=5G

# Hauler's dependency tree is resolved in an isolated go_deps extension
# instance (MODULE.bazel) so it cannot force version bumps on the production
# operator's Go dependencies. Coupled to the Bazel version in .bazelversion:
# when a Bazel bump stabilizes or removes this experimental flag, revisit it
# together with `isolate = True` in MODULE.bazel (fail-closed — every command
# errors on an unknown flag).
common --experimental_isolated_extension_usages
