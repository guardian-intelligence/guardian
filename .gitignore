/bazel-*
**/.terraform/
*.tfstate
*.tfstate.*
# operator credential env files are never committed - creds come from the
# operator's secret store (sops/password manager), exported into the environment.
*.env
/src/aisucks/aisucks
/.guardian/

# Local operator state that may remain after moving the ASH bootstrap tree.
/src/infrastructure/clusters/**/bootstrap/talm/secrets.yaml
/src/infrastructure/clusters/**/bootstrap/talm/secrets.encrypted.yaml
/src/infrastructure/clusters/**/bootstrap/talm/talosconfig
/src/infrastructure/clusters/**/bootstrap/talm/talosconfig.encrypted
/src/infrastructure/clusters/**/bootstrap/talm/talm.key
/src/infrastructure/clusters/**/bootstrap/talm/kubeconfig

# Archived pre-Cozystack tree. Keep source, not local dependency/build output.
/src-old/**/node_modules/
/src-old/**/dist/
/src-old/**/.vite/
/src-old/**/.turbo/
/src-old/**/.next/
/src-old/**/.output/

# Active web workspace dependency/build output is produced by Bazel/rules_js.
/src/viteplus-monorepo/**/node_modules/
/src/products/company/web/node_modules/
/src/products/*/render/node_modules/
/src/products/company/web/.output/
/src/products/company/web/.vite/
