// Renovate is the proposer for every source-plane pin that is not a rendered
// runtime image: the host-CLI lockfile (src/tools/multitool.lock.json), the
// bespoke tool archives (src/tools/*/*.MODULE.bazel), bazel_dep and oci.pull
// in MODULE.bazel, go.mod, the pnpm catalog, GitHub Actions digests, and
// tofu provider pins. Rendered runtime images are Kargo's territory
// (Warehouse → pin-bump PR); Renovate must never touch those paths. Both
// proposers are untrusted: CI + branch protection decide every merge.
//
// Trust tiers (operating manual: docs/dependency-management.md):
//   first-party actions        — no cooldown
//   standalone tools & libs    — 3-day cooldown
//   cluster-coupled tools      — grouped, labeled, never automerged; merges
//                                ride the paired substrate/skew change
//   substrate (Talos/k8s/tofu) — doorbell only: the PR starts the upgrade
//                                runbook, merging it is the runbook's last step
//
// No automerge anywhere yet: observe-mode first, tiers earn automerge after
// watched cycles (same arc as the image-provenance VAP Warn→Deny flip).
//
// Lockfile sha256 pairs are rederived automatically: postUpgradeTasks runs
// tools/ops/multitool-repin on every lockfile bump, and CI reruns it with
// --check. The bootstrap pivots (bazelisk + aspect) remain the only
// hand-completed sha pairs — a stale hash fails every CI job's bootstrap
// step until finished.
{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["config:best-practices"],

  // Kargo's territory plus the standard junk dirs (setting ignorePaths
  // replaces the preset default, so the node_modules entries come along).
  // Kargo's Stage pipelines git-push image bumps into exactly these three
  // stage-manifest trees; the rest of deployments/ is infrastructure
  // components whose chart pins Renovate proposes like any other dep.
  ignorePaths: [
    "**/node_modules/**",
    "**/bower_components/**",
    "src/infrastructure/deployments/company/**",
    "src/infrastructure/deployments/iam/**",
    "src/infrastructure/deployments/products/**",
  ],

  // The bespoke tool pins (restic, ruby) live in
  // src/tools/<tool>/<tool>.MODULE.bazel as http_archive/http_file. Only the
  // legacy `bazel` manager parses those rules (and recomputes sha256 on
  // bump); `bazel-module` matches the same files but reads
  // bazel_dep/overrides only. Patterns add to the manager's defaults, they
  // do not replace them.
  bazel: {
    managerFilePatterns: ["/\\.MODULE\\.bazel$/"],
  },

  // These managers extract image refs from the rendered manifest trees
  // (src/infrastructure/base, helm values, kustomizations). That plane is
  // owned by the generated union lock + Kargo Warehouses + the provenance
  // VAP, and each ref there is digest-pinned deliberately — Renovate must
  // not be a second proposer for it.
  "helm-values": { enabled: false },
  helmv3: { enabled: false },
  kustomize: { enabled: false },

  // The flux manager is different: source-controller chart pins
  // (OCIRepository tag+digest, HelmRepository-backed HelmRelease versions)
  // are source-plane deps like any other, so Renovate is their one
  // proposer. The scope below cannot reach the rendered plane — stage
  // manifests are plain Deployments and cozystack HelmReleases use
  // ExternalArtifact chartRefs, neither of which this manager reads — and
  // it excludes bootstrap/, where the dark-mode OCIRepository points at a
  // registry no datasource lookup can reach.
  flux: {
    managerFilePatterns: [
      "/^src\\/infrastructure\\/(base|deployments)\\/.+\\.ya?ml$/",
    ],
  },

  // Everything not overridden below waits out a 3-day cooldown, mirroring
  // pnpm-workspace.yaml's minimumReleaseAge: 4320 (Renovate does not read
  // pnpm's setting; if the two drift, pnpm fails the lockfile update loudly).
  minimumReleaseAge: "3 days",

  // hauler's vendored go.mod names its own module; the registry lookup can
  // never succeed and the permanent dashboard WARN it produces is noise.
  ignoreDeps: ["hauler.dev/go/hauler/v2"],

  osvVulnerabilityAlerts: true,
  dependencyDashboardOSVVulnerabilitySummary: "unresolved",
  vulnerabilityAlerts: {
    addLabels: ["security"],
  },

  platformCommit: "enabled",
  labels: ["dependencies"],

  packageRules: [
    // Majors are one dashboard click away, never an unprompted PR.
    {
      matchUpdateTypes: ["major"],
      dependencyDashboardApproval: true,
    },

    // First-party actions: no cooldown.
    {
      matchManagers: ["github-actions"],
      matchPackageNames: ["actions/**", "renovatebot/**"],
      minimumReleaseAge: null,
    },

    // Third-party actions carry a second pin in .github/actions-allowlist.json
    // (allowed_actions: selected), which Renovate does not touch. Bumping a
    // `uses:` digest fails //:actions_allowlist_test until the allowlist entry
    // moves too, and the merged workflow hits a startup_failure until a repo
    // admin re-applies the setting. The allowlist edit and the PUT are the
    // reviewer's two steps; the test keeps the PR red until the first is done.
    {
      matchManagers: ["github-actions"],
      matchPackageNames: ["!actions/**", "!renovatebot/**"],
      prBodyNotes: [
        "Third-party action: update the matching digest in .github/actions-allowlist.json in this PR (drop the superseded one) or //:actions_allowlist_test stays red, and after merge re-apply the setting — `gh api -X PUT repos/guardian-intelligence/guardian/actions/permissions/selected-actions --input .github/actions-allowlist.json` — or the next run of any workflow using the new ref dies as a startup_failure. See docs/dependency-management.md.",
      ],
    },

    // The @voidzero-dev vite-plus packages are one toolchain but the pnpm
    // catalog hides them behind aliases — `vite` -> @voidzero-dev/vite-plus-core,
    // `vitest` -> @voidzero-dev/vite-plus-test, and the plain `vite-plus` meta
    // package — so Renovate proposes them as unrelated deps in separate PRs
    // (core landed at 0.2.4 in one PR while the meta package sat at 0.1.24 in
    // another). Group them so a reviewer sees the whole toolchain move at once
    // instead of reconstructing it from scattered PRs. Matched by package name,
    // not the `vite`/`vitest` alias keys, to avoid catching the real vite
    // bundler catalogued separately as `vite@>=8.0.0 <=8.0.15`.
    {
      matchPackageNames: ["@voidzero-dev/**", "vite-plus"],
      groupName: "vite-plus (voidzero) toolchain",
      addLabels: ["viteplus-toolchain"],
      prBodyNotes: [
        "vite-plus, its `-core` (aliased `vite`), and its `-test` (aliased `vitest`) do not share one version line: `-core` tracks the meta package, but the meta package's minor bumps can be breaking migrations (0.2.x drops the bundled `@voidzero-dev/vite-plus-test` for upstream `vitest`, so the catalog alias must be reworked, not version-bumped). Treat a grouped bump as a migration checkpoint, never an automerge. Also bump the four `@voidzero-dev+vite-plus-linux-x64-gnu@<version>/dir` binding paths hardcoded in src/products/viteplus-monorepo/**/BUILD.bazel — Renovate cannot see them and the build stays red until they match.",
      ],
    },

    // Every lockfile bump completes itself: repin reconciles asset
    // filenames and archive member paths with the bumped release tag,
    // recomputes the sha256 pairs, and refuses hash changes for unbumped
    // URLs — all in the renovate sandbox, so the PR lands green instead of
    // sitting red awaiting a hand step. The command must stay listed in
    // RENOVATE_ALLOWED_COMMANDS (renovate.yml).
    {
      matchFileNames: ["src/tools/multitool.lock.json"],
      postUpgradeTasks: {
        commands: ["tools/ops/multitool-repin"],
        fileFilters: ["src/tools/multitool.lock.json"],
        executionMode: "branch",
      },
    },

    // Percona tags docker images for every tarball release; only the plain
    // X.Y tags are the tarball versions (the -N/-ubi8/-arch suffixed tags
    // are image rebuilds).
    {
      matchPackageNames: ["percona/percona-distribution-postgresql"],
      allowedVersions: "/^\\d+\\.\\d+$/",
    },

    // ClickHouse stays on the -lts channel: tags that do not match this
    // pattern (-stable, -prestable) are not versions at all to Renovate, and
    // the 4th component compares as a patch so lts hotfixes surface.
    {
      matchPackageNames: ["ClickHouse/ClickHouse"],
      versioning: "regex:^v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)\\.(?<build>\\d+)-lts$",
    },

    // Review-time couplings that lived as comments next to the old
    // .MODULE.bazel pins; the lockfile is JSON, so they ride the PR body.
    {
      matchPackageNames: ["sigstore/cosign"],
      prBodyNotes: [
        "cosign must stay on the same major as the sigstore/cosign-installer pin in the CI workflows — the dark-drive copy verifies what CI signs (docs/supply-chain-design.md). The countersigner's and release projector's COSIGN_IMAGE pins (deployments/guardian/system/zot-countersigner.yaml and release-projector.yaml) and the images.declared.lock digest ride the same release; TestCountersignerCosignPinsMoveTogether and TestReleaseProjectorToolPinsMoveTogether keep this PR red until they move too.",
      ],
    },
    {
      matchPackageNames: ["regclient/regclient"],
      prBodyNotes: [
        "The release projector's REGCTL_IMAGE pin (deployments/guardian/system/release-projector.yaml) and its images.declared.lock digest ride the same release; TestReleaseProjectorToolPinsMoveTogether keeps this PR red until they move too.",
      ],
    },
    {
      matchPackageNames: ["fluxcd/flux2"],
      prBodyNotes: [
        "flux CLI stays on the release line shipping the kustomize-controller series guardian-mgmt runs.",
      ],
    },

    // Cluster-coupled tools: one grouped PR, merged only alongside the
    // substrate move the version-skew conformance test demands.
    {
      matchPackageNames: [
        "cozystack/talm",
        "cozystack/boot-to-talos",
        "siderolabs/talos",
        "fluxcd/flux2",
      ],
      groupName: "cluster-coupled tools",
      addLabels: ["cluster-coupled"],
      automerge: false,
    },

    // Tofu provider pins: doorbell tier. Applying a root is a custody
    // operation, so the PR is a signal, not a deploy.
    {
      matchManagers: ["terraform"],
      addLabels: ["substrate-upgrade"],
      minimumReleaseAge: null,
      automerge: false,
    },

    // Substrate doorbells: every regex-managed pin that is not a lockfile
    // tool or a dev-tooling pivot — new substrate custom managers get
    // doorbell semantics by default, no second registration step. The PR is
    // the upgrade runbook's starting gun and merging it is the runbook's
    // last step, so Git never claims a version the cluster does not run. No
    // cooldown — the doorbell should ring promptly; the drill provides the
    // soak.
    {
      matchManagers: ["custom.regex"],
      matchFileNames: ["!src/tools/multitool.lock.json"],
      matchPackageNames: [
        "!renovatebot/renovate",
        "!bazelbuild/bazelisk",
        "!aspect-build/aspect-cli",
      ],
      addLabels: ["substrate-upgrade"],
      minimumReleaseAge: null,
      automerge: false,
    },

    // The bootstrap pivots ship a hand-completed sha256 pair per platform
    // (regex managers cannot recompute hashes), so an unprompted PR would sit
    // red until someone finishes it. Dashboard approval makes it opt-in.
    {
      matchPackageNames: ["bazelbuild/bazelisk", "aspect-build/aspect-cli"],
      dependencyDashboardApproval: true,
    },

    // The kubectl pin and the cluster kubernetesVersion share one depName on
    // purpose: they move in one doorbell PR, and the version-skew conformance
    // test refuses any state where they drift more than one minor apart.
    // kubectl lives in the lockfile, which the blanket doorbell rule
    // excludes, so the doorbell attributes are restated here.
    {
      matchPackageNames: ["kubernetes/kubernetes"],
      groupName: "kubernetes (substrate)",
      addLabels: ["cluster-coupled", "substrate-upgrade"],
      minimumReleaseAge: null,
      automerge: false,
    },
  ],

  customManagers: [
    // Host-CLI lockfile, GitHub-hosted tools: the release tag in each
    // download URL is the version, and the per-platform URLs of one tool
    // share a tag, so a bump moves them together. Only the tag segment is
    // rewritten here — the postUpgradeTasks repin reconciles the version
    // echoed in asset filenames and archive member paths from the tag.
    {
      customType: "regex",
      managerFilePatterns: ["/^src/tools/multitool\\.lock\\.json$/"],
      matchStrings: [
        '"url": "https://github\\.com/(?<depName>[^/"]+/[^/"]+)/releases/download/(?<currentValue>[^/"]+)/',
      ],
      datasourceTemplate: "github-releases",
    },

    // Host-CLI lockfile, helm: get.helm.sh is invisible to the GitHub
    // matcher above but the project releases on GitHub.
    {
      customType: "regex",
      managerFilePatterns: ["/^src/tools/multitool\\.lock\\.json$/"],
      matchStrings: ['"url": "https://get\\.helm\\.sh/helm-(?<currentValue>v[0-9.]+)-'],
      depNameTemplate: "helm/helm",
      datasourceTemplate: "github-releases",
    },

    // Host-CLI lockfile, kubectl: dl.k8s.io is invisible to the GitHub
    // matcher above.
    {
      customType: "regex",
      managerFilePatterns: ["/^src/tools/multitool\\.lock\\.json$/"],
      matchStrings: [
        '"url": "https://dl\\.k8s\\.io/release/(?<currentValue>v[0-9.]+)/bin/',
      ],
      depNameTemplate: "kubernetes/kubernetes",
      datasourceTemplate: "github-releases",
    },

    // Host-CLI lockfile, percona psql/pgbench: downloads.percona.com has no
    // datasource, so the docker image percona tags for every tarball release
    // is the version oracle (constrained to plain X.Y tags above). The
    // version appears twice per URL; the template rewrites both. A major
    // bump also moves the distribution path segment, which this template
    // does not — majors are dashboard-gated and the dead URL fails repin
    // loudly, making the doorbell PR visibly incomplete until hand-shaped.
    {
      customType: "regex",
      managerFilePatterns: ["/^src/tools/multitool\\.lock\\.json$/"],
      matchStrings: [
        '"url": "https://downloads\\.percona\\.com/downloads/postgresql-distribution-(?<pgMajor>\\d+)/(?<currentValue>[0-9.]+)/binary/tarball/percona-postgresql-[0-9.]+-(?<buildSuffix>ssl\\d+)',
      ],
      autoReplaceStringTemplate: '"url": "https://downloads.percona.com/downloads/postgresql-distribution-{{{pgMajor}}}/{{{newValue}}}/binary/tarball/percona-postgresql-{{{newValue}}}-{{{buildSuffix}}}',
      depNameTemplate: "percona/percona-distribution-postgresql",
      datasourceTemplate: "docker",
    },

    // Talos installer image — pinned identically in the talm values and the
    // declared lock (machine.install.image is a bootstrap artifact, not a
    // rendered pod image). One dep, one PR, both files.
    {
      customType: "regex",
      managerFilePatterns: [
        "/^src/infrastructure/talm/values\\.yaml$/",
        "/^src/infrastructure/bootstrap/bundle/images\\.declared\\.lock$/",
      ],
      matchStrings: [
        "(?<packageName>factory\\.talos\\.dev/metal-installer-secureboot/be66fdc8a38c2f517f33cba0a6daa7ab97ff87d51e8ca7d2160e45911ba09cf5):(?<currentValue>v[0-9.]+)@(?<currentDigest>sha256:[a-f0-9]{64})",
      ],
      datasourceTemplate: "docker",
    },

    // `# renovate: datasource=... depName=...` annotation convention for
    // version strings in YAML (the cluster kubernetesVersion in the talm
    // Chart.yaml today; annotate new substrate pins the same way and add
    // their depName to the substrate doorbell rule).
    {
      customType: "regex",
      managerFilePatterns: ["/^src/infrastructure/talm/Chart\\.yaml$/"],
      matchStrings: [
        '# renovate: datasource=(?<datasource>[a-z-.]+) depName=(?<depName>[^\\s]+)\\n\\s*[A-Za-z]+: "(?<currentValue>v?[0-9][^"]*)"',
      ],
    },

    // Cozystack platform doorbell — the cozy-installer pin in the declared
    // lock is the platform version the cluster runs (applied by the upgrade
    // runbook, never by Flux), and no manager reads lock files.
    {
      customType: "regex",
      managerFilePatterns: [
        "/^src/infrastructure/bootstrap/bundle/images\\.declared\\.lock$/",
      ],
      matchStrings: [
        "(?<packageName>ghcr\\.io/cozystack/cozystack/cozy-installer):(?<currentValue>[0-9.]+)@(?<currentDigest>sha256:[a-f0-9]{64})",
      ],
      datasourceTemplate: "docker",
    },

    // Renovate updates itself: the runner tag in renovate.yml and the
    // validator pin in the config gate carry the same version and must
    // move together (the -full suffix stays in the file, outside the match).
    {
      customType: "regex",
      managerFilePatterns: [
        "/^\\.github/workflows/renovate\\.yml$/",
        "/^\\.github/scripts/check-renovate-config\\.sh$/",
      ],
      matchStrings: [
        "renovate-version: (?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)",
        "-p renovate@(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)",
      ],
      depNameTemplate: "renovatebot/renovate",
      datasourceTemplate: "github-releases",
    },

    // The bootstrap pivots (bazelisk + aspect) in scripts/bootstrap/ — shell
    // assignments no manager reads, annotated in place like the Chart.yaml
    // convention. The adjacent sha256 pins are completed by hand; a stale
    // hash fails every CI job's bootstrap step, so a half-finished PR cannot
    // merge quietly.
    {
      customType: "regex",
      managerFilePatterns: ["/^scripts/bootstrap/bootstrap-[a-z0-9-]+$/"],
      matchStrings: [
        '# renovate: datasource=(?<datasource>[a-z-.]+) depName=(?<depName>[^\\s]+)\\n[a-z_]+_version="(?<currentValue>[0-9][^"]*)"',
      ],
      extractVersionTemplate: "^v?(?<version>.*)$",
    },

    // The golden runner image pins (actions/runner, node) — annotated shell
    // assignments like the bootstrap pivots. The adjacent sha256 pins are
    // completed by hand from the upstream checksum files; a stale hash fails
    // the image build on the tracer host. GitHub retires runner versions on
    // ~30-day windows, so these PRs are the image re-release doorbell.
    {
      customType: "regex",
      managerFilePatterns: ["/^src/services/postflight/image/pins\\.env$/"],
      matchStrings: [
        '# renovate: datasource=(?<datasource>[a-z-.]+) depName=(?<depName>[^\\s]+)\\n[A-Z_]+_VERSION="(?<currentValue>[0-9][^"]*)"',
      ],
      extractVersionTemplate: "^v?(?<version>.*)$",
    },
  ],
}
