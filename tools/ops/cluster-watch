#!/usr/bin/env python3
"""cluster-watch — one command to watch the Guardian cluster converge.

Two read-only views:

  cluster-watch                Live Flux, Kargo, and Flagger rollout status
                               read straight from the cluster (needs
                               KUBECONFIG). Refreshes every few seconds and
                               shows exactly what is not converged.

  cluster-watch --until-ready  Exit after the requested Git revision and all
                               rollout resources remain healthy for three
                               consecutive samples. Use --revision after a
                               merge so an already-green old revision cannot
                               satisfy the check.

  cluster-watch --stream       Tail the alert stream the cluster publishes to
                               ntfy (VMRule -> Alertmanager -> Alerta ->
                               alert-relay -> ntfy). Needs no cluster access —
                               works from anywhere, even off the VPN. The
                               underlying rules debounce ~15m, so this reports
                               *sustained* failure (a change that never
                               converged), not a fresh push.

  cluster-watch --convergence  Same alert stream, narrowed to Flux convergence
                               alerts only (Kustomization / HelmRelease /
                               source-controller).

Env:
  KUBECTL      kubectl binary used by live status (default kubectl)
  NTFY_BASE    ntfy server base URL         (default https://ntfy.sh)
  NTFY_TOPIC   topic the relay publishes to (default guardian-operations-fable)
  KUBECONFIG   used by live status          (default ~/.kube/config)
"""

import argparse
import datetime
import json
import os
import re
import subprocess
import sys
import time
import urllib.request

NTFY_BASE = os.environ.get("NTFY_BASE", "https://ntfy.sh").rstrip("/")
NTFY_TOPIC = os.environ.get("NTFY_TOPIC", "guardian-operations-fable")

# Alertnames the stock cozy-monitoring flux-resources rules emit, plus the
# source-controller ones. Titles read "KustomizationNotApplied on ..." or
# "[Closed] HelmReleaseNotReady on ...", so a substring match catches both.
FLUX_ALERT_MARKERS = (
    "Kustomization",
    "HelmRelease",
    "GitRepository",
    "OCIRepository",
    "Bucket",
    "ImagePolicy",
    "ImageRepository",
    "ImageUpdateAutomation",
)

# ntfy priority (1..5) -> (label, ANSI colour). 3 is the default Alerta's
# text-only Slack payload carries when it has no severity; 4/5 want eyes.
PRIORITY = {
    5: ("P5", "\033[1;37;41m"),  # white on red
    4: ("P4", "\033[1;31m"),     # bold red
    3: ("P3", "\033[0;33m"),     # yellow
    2: ("P2", "\033[0;32m"),     # green (resolves land here)
    1: ("P1", "\033[2;37m"),     # dim
}
RESET = "\033[0m"
DIM = "\033[2m"
GREEN = "\033[0;32m"


def colour_on(stream):
    return stream.isatty() and os.environ.get("NO_COLOR") is None


def paint(text, code, on):
    return f"{code}{text}{RESET}" if on else text


def hhmmss(epoch):
    return time.strftime("%H:%M:%S", time.localtime(epoch))


def is_flux_alert(title):
    return any(marker in title for marker in FLUX_ALERT_MARKERS)


def clean_slack(text):
    """Alerta's text-only Slack payload wraps the body in `*bold*`, `_italic_`
    and `<url|label>` markup and a dashboard-relative alert permalink. Strip it
    so the body line is readable in a terminal."""
    text = re.sub(r"<[^>|]*\|([^>]*)>", r"\1", text)  # <url|label> -> label
    text = re.sub(r"<[^>]*>", "", text)               # <url> or stray link -> drop
    text = re.sub(r"_(.+?)_", r"\1", text)            # _italic_ -> italic
    text = text.replace("*", "")
    return text.strip()


def render(msg, convergence, grep, on):
    title = msg.get("title") or "(no title)"
    body = clean_slack((msg.get("message") or "").strip())
    tags = msg.get("tags") or []
    prio = int(msg.get("priority") or 3)

    if convergence and not is_flux_alert(title):
        return
    if grep and grep.lower() not in (title + " " + body).lower():
        return

    plabel, pcolour = PRIORITY.get(prio, ("P?", ""))
    stamp = paint(hhmmss(msg.get("time", time.time())), DIM, on)
    tagstr = (" " + paint("[" + ", ".join(tags) + "]", DIM, on)) if tags else ""
    print(f"{stamp} {paint(plabel, pcolour, on)} {title}{tagstr}")
    # The body is worth a second line only when it says more than the title
    # already does (e.g. a CPUThrottling percentage); for Flux alerts it just
    # restates the title, so drop it.
    if body and body not in title and title.split(" on ")[0] not in body:
        for line in body.splitlines():
            print(f"           {paint(line, DIM, on)}")


def watch_ntfy(args):
    on = colour_on(sys.stdout)
    scope = "Flux convergence" if args.convergence else "all"
    print(paint(f"cluster-watch: {NTFY_TOPIC} ({scope} alerts, replaying last {args.since})",
                DIM, on))
    url = f"{NTFY_BASE}/{NTFY_TOPIC}/json?since={args.since}"
    while True:
        try:
            with urllib.request.urlopen(url, timeout=90) as resp:
                for raw in resp:
                    line = raw.decode("utf-8", "replace").strip()
                    if not line:
                        continue
                    try:
                        msg = json.loads(line)
                    except json.JSONDecodeError:
                        continue
                    if msg.get("event") == "message":
                        render(msg, args.convergence, args.grep, on)
        except KeyboardInterrupt:
            return 0
        except Exception as exc:  # network drop, server hiccup — reconnect
            print(paint(f"  (reconnecting: {exc})", DIM, on), file=sys.stderr)
            time.sleep(3)
            # Only a short backlog on reconnect, so a flaky link doesn't replay
            # the whole window each time.
            url = f"{NTFY_BASE}/{NTFY_TOPIC}/json?since=30s"


def kubectl_json(get_args):
    kc = os.environ.get("KUBECONFIG", os.path.expanduser("~/.kube/config"))
    paths = [os.path.expanduser(path) for path in kc.split(os.pathsep) if path]
    if not any(os.path.exists(path) for path in paths):
        raise SystemExit(f"cluster-watch needs a kubeconfig for live status; "
                         f"KUBECONFIG={kc} not found")
    kubectl = os.environ.get("KUBECTL", "kubectl")
    out = subprocess.run([kubectl, *get_args, "-o", "json"],
                         capture_output=True, text=True)
    if out.returncode != 0:
        raise SystemExit(f"kubectl failed: {out.stderr.strip()}")
    return json.loads(out.stdout)


def status_condition(obj, condition_type):
    for c in obj.get("status", {}).get("conditions", []):
        if c.get("type") == condition_type:
            return c.get("status"), c.get("reason", ""), c.get("message", "")
    return "Unknown", "NoStatus", ""


def object_name(obj):
    md = obj["metadata"]
    return f"{md.get('namespace', '<cluster>')}/{md['name']}"


def finding(kind, obj, status, reason, message=""):
    return {
        "kind": kind,
        "name": object_name(obj),
        "status": status,
        "reason": reason,
        "message": message,
    }


def timestamp_age_seconds(value, now):
    if not value:
        return None
    created = datetime.datetime.fromisoformat(value.replace("Z", "+00:00"))
    return (now - created).total_seconds()


def collect_status(revision="", now=None, get_json=kubectl_json):
    now = now or datetime.datetime.now(datetime.timezone.utc)
    findings = []

    flux_kinds = [
        ("kustomizations.kustomize.toolkit.fluxcd.io", "Kustomization"),
        ("helmreleases.helm.toolkit.fluxcd.io", "HelmRelease"),
    ]
    for resource, kind in flux_kinds:
        for obj in get_json(["get", resource, "-A"]).get("items", []):
            status, reason, message = status_condition(obj, "Ready")
            if status != "True":
                findings.append(finding(kind, obj, status, reason, message))
                continue
            source = obj.get("spec", {}).get("sourceRef", {})
            if (revision and kind == "Kustomization" and
                    source.get("name") == "guardian"):
                applied = obj.get("status", {}).get("lastAppliedRevision", "")
                if revision not in applied:
                    findings.append(finding(
                        kind,
                        obj,
                        "Unknown",
                        "RevisionPending",
                        f"last applied {applied or 'revision unavailable'}",
                    ))

    stages = get_json(["get", "stages.kargo.akuity.io", "-A"]).get("items", [])
    for obj in stages:
        status, reason, message = status_condition(obj, "Healthy")
        if status == "False" or reason == "NoStatus":
            findings.append(finding("KargoStage", obj, status, reason, message))

    warehouses = get_json([
        "get", "warehouses.kargo.akuity.io", "-A",
    ]).get("items", [])
    for obj in warehouses:
        for condition_type in ("Ready", "Healthy"):
            status, reason, message = status_condition(obj, condition_type)
            if status == "False" or reason == "NoStatus":
                findings.append(finding(
                    "KargoWarehouse", obj, status,
                    f"{condition_type}:{reason}", message,
                ))
                break

    promotions = get_json([
        "get", "promotions.kargo.akuity.io", "-A",
    ]).get("items", [])
    latest_promotions = {}
    for obj in promotions:
        md = obj["metadata"]
        key = (md.get("namespace", ""), obj.get("spec", {}).get("stage", ""))
        current = latest_promotions.get(key)
        if (current is None or
                md.get("creationTimestamp", "") >
                current["metadata"].get("creationTimestamp", "")):
            latest_promotions[key] = obj
    for obj in latest_promotions.values():
        phase = obj.get("status", {}).get("phase", "")
        age = timestamp_age_seconds(
            obj["metadata"].get("creationTimestamp", ""), now,
        )
        if phase in ("", "Pending", "Running"):
            findings.append(finding("KargoPromotion", obj, "Unknown", phase or "Pending"))
        elif phase in ("Failed", "Errored") and (age is None or age < 21600):
            findings.append(finding(
                "KargoPromotion", obj, "False", phase,
                obj.get("status", {}).get("message", ""),
            ))

    canaries = get_json(["get", "canaries.flagger.app", "-A"]).get("items", [])
    for obj in canaries:
        phase = obj.get("status", {}).get("phase", "")
        if phase != "Succeeded":
            status = "False" if phase == "Failed" else "Unknown"
            findings.append(finding("Canary", obj, status, phase or "NoStatus"))

    return findings


def render_findings(findings, on):
    lines = []
    for item in findings:
        colour = "\033[1;31m" if item["status"] == "False" else "\033[0;33m"
        lines.append(paint(
            f"{item['kind']:15} {item['name']:44} {item['reason']}",
            colour,
            on,
        ))
        if item["message"]:
            lines.append(f"  {paint(item['message'].strip()[:200], DIM, on)}")
    return lines


def watch_status(args):
    on = colour_on(sys.stdout)
    stable = 0
    try:
        while True:
            findings = collect_status(args.revision)
            stable = stable + 1 if not findings else 0
            if on:
                sys.stdout.write("\033[2J\033[H")
            print(paint(
                f"cluster-watch --status  {hhmmss(time.time())}  "
                f"({len(findings)} not converged)",
                DIM,
                on,
            ))
            if findings:
                print("\n".join(render_findings(findings, on)))
            else:
                print(paint(
                    "  Flux, Kargo, and Flagger rollout resources healthy",
                    GREEN,
                    on,
                ))
                if args.until_ready:
                    print(paint(
                        f"  stable sample {stable}/{args.stable_samples}", DIM, on,
                    ))
            if args.until_ready and stable >= args.stable_samples:
                return 0
            time.sleep(args.interval)
    except KeyboardInterrupt:
        return 0


def main():
    p = argparse.ArgumentParser(description="Watch the Guardian cluster converge.")
    p.add_argument("--status", action="store_true",
                   help="live Flux convergence status from the cluster (default; needs KUBECONFIG)")
    p.add_argument("--stream", action="store_true",
                   help="tail the ntfy alert stream instead of polling live Flux status")
    p.add_argument("--convergence", action="store_true",
                   help="ntfy mode: show only Flux convergence alerts")
    p.add_argument("--since", default="15m",
                   help="ntfy backlog window replayed on connect (default 15m)")
    p.add_argument("--grep", default="",
                   help="ntfy mode: only alerts whose title/body contains this substring")
    p.add_argument("--interval", type=float, default=5.0,
                   help="--status refresh seconds (default 5)")
    p.add_argument("--revision", default="",
                   help="Guardian Git revision every Flux Kustomization must have applied")
    p.add_argument("--stable-samples", type=int, default=3,
                   help="healthy samples required by --until-ready (default 3)")
    p.add_argument("--until-ready", action="store_true",
                   help="exit after the requested revision and rollout resources are stable")
    args = p.parse_args()
    if (args.stream or args.convergence) and (args.until_ready or args.revision):
        p.error("--until-ready and --revision apply only to live status")
    if args.stable_samples < 1:
        p.error("--stable-samples must be at least 1")
    return watch_ntfy(args) if args.stream or args.convergence else watch_status(args)


if __name__ == "__main__":
    sys.exit(main())
