#!/usr/bin/env bash
# Secret scan run by the pre-commit hook (mode: staged); `tree` mode scans a
# whole checkout on demand. Two layers, one ruleset:
#
#   1. Presence: custody-shaped FILES may not exist anywhere in the
#      workspace, gitignored or not. The encrypted custody bundle
#      (`aspect infra custody`, runbooks/custody.md) is their only home;
#      a gitignore line is not a security boundary.
#   2. Content: gitleaks with .gitleaks.toml (stock rules + custody shapes)
#      over staged changes (hook) or the whole checkout (tree).
#
# A content hit on anything already pushed is a leak-response event, not a
# lint — see runbooks/custody.md "Leak response".
set -euo pipefail

mode="${1:-staged}"
repo_root="$(git rev-parse --show-toplevel)"
cd "${repo_root}"

fail=0

# --- layer 1: custody-shaped files must not exist in the workspace ---
presence_hits="$(
  find . -path ./.git -prune -o -path ./.claude -prune -o -type f \( \
    -name 'custody.env' -o -name 'talm.key' \
    -o -regextype posix-extended -regex '.*/unseal-[0-9a-f]{64}\.key' \
  \) -print 2>/dev/null
  for f in secrets.yaml talosconfig kubeconfig; do
    p="src/infrastructure/talm/${f}"
    if [[ -f "${p}" ]]; then
      echo "./${p}"
    fi
  done
)"
if [[ -n "${presence_hits}" ]]; then
  echo "ERROR: custody-shaped files exist in the workspace (gitignored does not make them safe):" >&2
  echo "${presence_hits}" | sed 's/^/  /' >&2
  echo "Move them into the encrypted custody bundle (aspect infra custody --action create, then wipe" >&2
  echo "the plaintext) — see src/infrastructure/runbooks/custody.md." >&2
  fail=1
fi

# --- layer 2: content scan via pinned gitleaks ---
gitleaks_bin=""
gitleaks_target="@multitool//tools/gitleaks"
if command -v bazelisk >/dev/null 2>&1; then
  if bazelisk build "${gitleaks_target}" >/dev/null 2>&1; then
    gitleaks_out="$(bazelisk cquery --output=files "${gitleaks_target}" 2>/dev/null)"
    case "${gitleaks_out}" in
      external/*) gitleaks_bin="$(bazelisk info output_base 2>/dev/null)/${gitleaks_out}" ;;
      ?*) gitleaks_bin="$(bazelisk info execution_root 2>/dev/null)/${gitleaks_out}" ;;
    esac
    if [[ ! -x "${gitleaks_bin}" ]]; then
      echo "ERROR: built ${gitleaks_target} but its output (${gitleaks_out:-none}) is not executable" >&2
      exit 2
    fi
  fi
fi
if [[ -x "${gitleaks_bin}" ]]; then
  case "${mode}" in
  staged)
    "${gitleaks_bin}" git --pre-commit --staged --no-banner --redact \
      --config .gitleaks.toml . || fail=1
    ;;
  tree)
    "${gitleaks_bin}" dir --no-banner --redact --config .gitleaks.toml . || fail=1
    ;;
  *)
    echo "usage: secret-scan [staged|tree]" >&2
    exit 2
    ;;
  esac
else
  # The hook stays useful without a toolchain; CI must never take this
  # branch silently.
  echo "WARN: pinned gitleaks unavailable (no bazelisk?); content scan skipped, presence check still enforced" >&2
  if [[ "${mode}" == "tree" ]]; then
    fail=1
  fi
fi

exit "${fail}"
