#!/usr/bin/env bash
set -euo pipefail

readonly ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
readonly NAMESPACE="${SPICEDB_NAMESPACE:-tenant-guardian-prod}"
readonly SERVICE="${SPICEDB_SERVICE:-spicedb}"
readonly LOCAL_GRPC_PORT="${SPICEDB_LOCAL_GRPC_PORT:-15051}"
readonly LOCAL_METRICS_PORT="${SPICEDB_LOCAL_METRICS_PORT:-19090}"
readonly TLS_HOSTNAME="spicedb.${NAMESPACE}.svc.cozy.local"

PATH="${ROOT}/.guardian/tools/bin:${PATH}"

port_forward_pid=""
temporary_directory=""

usage() {
  cat <<'USAGE'
Usage:
  tools/ops/spicedb-qualify placement
  tools/ops/spicedb-qualify verify
  tools/ops/spicedb-qualify load [duration] [qps] [evidence-directory]

placement
  Proves namespace-scoped operator RBAC and three-node placement for SpiceDB
  and PostgreSQL. This needs only the platform-agent read-only role.

verify
  Proves the checked-in positive and negative authorization decisions, valid
  TLS trust, rejection of an unrelated CA, and invalid-token rejection. The
  generated API credential is a Kubernetes Secret, so authenticate explicitly
  for Secret read before running this mode.

load
  Observes the Flux-deployed, verified-TLS Thumper profile for the requested
  duration (default 10m) and expected QPS (default 50), while writing logs,
  metric deltas, and latency quantiles to the evidence directory. Change QPS
  in Git; this command refuses to measure a different deployed value.

This tool only reads Kubernetes objects and opens a port-forward. All rollout,
failover, rotation, upgrade, restore, and alert-drill changes belong in Git and
must be reconciled by Flux.
USAGE
}

fail() {
  printf 'ERROR: %s\n' "$*" >&2
  exit 1
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || fail "missing required command: $1 (run: aspect tools install)"
}

resolve_pinned_tool() {
  local name="$1"
  local output
  require_command bazelisk
  bazelisk build "@multitool//tools/${name}" >/dev/null
  output="$(bazelisk cquery --output=files "@multitool//tools/${name}" 2>/dev/null)"
  [[ -n "${output}" ]] || fail "could not resolve repo-pinned ${name}"
  printf '%s/%s\n' "${ROOT}" "${output}"
}

cleanup() {
  if [[ -n "${port_forward_pid}" ]] && kill -0 "${port_forward_pid}" 2>/dev/null; then
    kill "${port_forward_pid}" 2>/dev/null || true
    wait "${port_forward_pid}" 2>/dev/null || true
  fi
  if [[ -n "${temporary_directory}" ]]; then
    rm -rf "${temporary_directory}"
  fi
}
trap cleanup EXIT

wait_for_port_forward() {
  local log_path="$1"
  for _ in $(seq 1 100); do
    if ! kill -0 "${port_forward_pid}" 2>/dev/null; then
      cat "${log_path}" >&2
      fail "SpiceDB port-forward exited before becoming ready"
    fi
    if grep -q 'Forwarding from 127.0.0.1' "${log_path}"; then
      return
    fi
    sleep 0.1
  done
  cat "${log_path}" >&2
  fail "timed out waiting for the SpiceDB port-forward"
}

start_port_forward() {
  local log_path="$1"
  local service="$2"
  local local_port="$3"
  local remote_port="$4"
  kubectl -n "${NAMESPACE}" port-forward --address 127.0.0.1 \
    "svc/${service}" "${local_port}:${remote_port}" >"${log_path}" 2>&1 &
  port_forward_pid="$!"
  wait_for_port_forward "${log_path}"
}

secret_value() {
  local secret_name="$1"
  local key="$2"
  kubectl -n "${NAMESPACE}" get secret "${secret_name}" -o json |
    jq -er --arg key "${key}" '.data[$key]' |
    base64 -d
}

assert_three_nodes() {
  local description="$1"
  local selector="$2"
  local pods_json
  local ready_count
  local nodes

  pods_json="$(kubectl -n "${NAMESPACE}" get pods -l "${selector}" -o json)"
  ready_count="$(jq '[.items[] | select(any(.status.conditions[]?; .type == "Ready" and .status == "True"))] | length' <<<"${pods_json}")"
  nodes="$(jq -r '.items[].spec.nodeName // empty' <<<"${pods_json}" | sort -u)"

  [[ "${ready_count}" == "3" ]] || fail "${description} has ${ready_count} Ready pods; expected 3"
  [[ "$(wc -l <<<"${nodes}" | tr -d ' ')" == "3" ]] ||
    fail "${description} does not occupy three distinct nodes: ${nodes//$'\n'/, }"
  printf '%s nodes:\n%s\n' "${description}" "${nodes}"
}

placement() {
  require_command kubectl
  require_command jq

  kubectl -n "${NAMESPACE}" get role spicedb-operator >/dev/null
  kubectl -n "${NAMESPACE}" get rolebinding spicedb-operator >/dev/null

  local binding_count
  binding_count="$(
    kubectl get clusterrolebindings -o json |
      jq --arg ns "${NAMESPACE}" '
        [.items[] |
          select(any(.subjects[]?;
            .kind == "ServiceAccount" and
            .namespace == $ns and
            .name == "spicedb-operator"
          ))
        ] | length
      '
  )"
  [[ "${binding_count}" == "0" ]] ||
    fail "spicedb-operator is referenced by ${binding_count} ClusterRoleBinding object(s)"

  local binding_json
  binding_json="$(kubectl -n "${NAMESPACE}" get rolebinding spicedb-operator -o json)"
  jq -e --arg ns "${NAMESPACE}" '
    .roleRef.kind == "Role" and
    .roleRef.name == "spicedb-operator" and
    (.subjects | length) == 1 and
    .subjects[0].kind == "ServiceAccount" and
    .subjects[0].name == "spicedb-operator" and
    .subjects[0].namespace == $ns
  ' <<<"${binding_json}" >/dev/null ||
    fail "spicedb-operator RoleBinding is not confined to its namespaced Role and service account"

  assert_three_nodes SpiceDB 'guardian.dev/component=authorization-datastore'
  assert_three_nodes PostgreSQL 'cnpg.io/cluster=postgres-spicedb'
  printf 'Operator RBAC is namespace-scoped.\n'
}

verify() {
  require_command kubectl
  require_command jq
  local zed_bin
  zed_bin="$(resolve_pinned_tool zed)"

  kubectl auth can-i -n "${NAMESPACE}" get secrets | grep -qx yes ||
    fail "Secret read is required for this explicit qualification; authenticate with an audited role first"

  temporary_directory="$(mktemp -d)"
  local ca_path="${temporary_directory}/ca.crt"
  local wrong_ca_path="${temporary_directory}/wrong-ca.crt"
  local port_forward_log="${temporary_directory}/port-forward.log"
  local token

  secret_value spicedb-server-tls ca.crt >"${ca_path}"
  secret_value postgres-spicedb-ca ca.crt >"${wrong_ca_path}"
  token="$(secret_value spicedb-api-token-slot-b password)"
  start_port_forward "${port_forward_log}" "${SERVICE}" "${LOCAL_GRPC_PORT}" 50051

  local zed_common=(
    "--endpoint=127.0.0.1:${LOCAL_GRPC_PORT}"
    "--hostname-override=${TLS_HOSTNAME}"
    "--certificate-path=${ca_path}"
    "--token=${token}"
    --skip-version-check
  )

  "${zed_bin}" "${zed_common[@]}" permission check --error-on-no-permission \
    organization:guardian manage guardian_account:alice >/dev/null

  if "${zed_bin}" "${zed_common[@]}" permission check --error-on-no-permission \
    organization:guardian manage guardian_account:mallory >/dev/null 2>&1; then
    fail "negative authorization check unexpectedly allowed mallory"
  fi

  if "${zed_bin}" \
    "--endpoint=127.0.0.1:${LOCAL_GRPC_PORT}" \
    "--hostname-override=${TLS_HOSTNAME}" \
    "--certificate-path=${wrong_ca_path}" \
    "--token=${token}" \
    --skip-version-check schema read >/dev/null 2>&1; then
    fail "SpiceDB accepted an unrelated certificate authority"
  fi

  if "${zed_bin}" \
    "--endpoint=127.0.0.1:${LOCAL_GRPC_PORT}" \
    "--hostname-override=${TLS_HOSTNAME}" \
    "--certificate-path=${ca_path}" \
    --token=deliberately-invalid-token \
    --skip-version-check schema read >/dev/null 2>&1; then
    fail "SpiceDB accepted an invalid API token"
  fi

  printf 'Positive/negative decisions, TLS verification, and invalid-token rejection passed.\n'
}

load() {
  local duration="${1:-10m}"
  local qps="${2:-50}"
  local evidence_directory="${3:-${ROOT}/.guardian/evidence/spicedb/$(date -u +%Y%m%dT%H%M%SZ)}"

  require_command kubectl
  require_command curl
  require_command jq

  [[ "${qps}" =~ ^[1-9][0-9]*$ ]] || fail "QPS must be a positive integer"

  mkdir -p "${evidence_directory}"
  local port_forward_log="${evidence_directory}/port-forward.log"
  local thumper_log="${evidence_directory}/thumper.log"
  local metrics_before="${evidence_directory}/metrics-before.prom"
  local metrics_path="${evidence_directory}/metrics.prom"
  local summary_path="${evidence_directory}/summary.txt"
  local deployment_json
  local args
  local declared_qps

  deployment_json="$(kubectl -n "${NAMESPACE}" get deployment spicedb-thumper -o json)"
  args="$(jq -r '.spec.template.spec.containers[] | select(.name == "thumper") | .args[]' <<<"${deployment_json}")"
  declared_qps="$(sed -n 's/^--qps=//p' <<<"${args}")"
  [[ "${declared_qps}" == "${qps}" ]] ||
    fail "deployed Thumper QPS is ${declared_qps:-unset}, not ${qps}; change thumper.yaml through Git and wait for Flux"
  grep -qx -- '--insecure=false' <<<"${args}" ||
    fail "deployed Thumper does not require TLS"
  grep -qx -- '--ca-path=/tls/ca.crt' <<<"${args}" ||
    fail "deployed Thumper does not verify the serving CA"
  if grep -qx -- '--no-verify-ca' <<<"${args}"; then
    fail "deployed Thumper disables certificate verification"
  fi

  start_port_forward "${port_forward_log}" spicedb-thumper "${LOCAL_METRICS_PORT}" 9090

  for _ in $(seq 1 100); do
    if curl --fail --silent "http://127.0.0.1:${LOCAL_METRICS_PORT}/metrics" >/dev/null 2>&1; then
      break
    fi
    sleep 0.1
  done

  curl --fail --silent "http://127.0.0.1:${LOCAL_METRICS_PORT}/metrics" >"${metrics_before}"
  local started_at
  started_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  printf 'Observing the Flux-deployed Thumper at %s QPS for %s.\n' "${qps}" "${duration}"
  sleep "${duration}"

  curl --fail --silent "http://127.0.0.1:${LOCAL_METRICS_PORT}/metrics" >"${metrics_path}"
  kubectl -n "${NAMESPACE}" logs deployment/spicedb-thumper --since-time="${started_at}" >"${thumper_log}"

  local incorrect_decisions
  local step_errors
  local completed_requests
  local p50
  local p95
  local p99
  incorrect_decisions="$(grep -c 'wrong permissionship' "${thumper_log}" || true)"
  step_errors="$(grep -c 'error calling script step' "${thumper_log}" || true)"
  completed_requests="$(
    awk '
      FNR == NR {
        if ($1 ~ /^grpc_client_handled_total\{/ &&
            $0 ~ /grpc_service="authzed.api.v1.PermissionsService"/ &&
            $0 ~ /grpc_method="CheckPermission"/) {
          before += $NF
        }
        next
      }
      /^grpc_client_handled_total\{/ &&
      /grpc_service="authzed.api.v1.PermissionsService"/ &&
      /grpc_method="CheckPermission"/ {
        after += $NF
      }
      END { printf "%.0f", after - before }
    ' "${metrics_before}" "${metrics_path}"
  )"
  histogram_quantile() {
    local quantile="$1"
    awk -v q="${quantile}" '
      function record(line, destination, labels, value) {
        if (line !~ /^grpc_client_handling_seconds_bucket\{/ ||
            line !~ /grpc_service="authzed.api.v1.PermissionsService"/ ||
            line !~ /grpc_method="CheckPermission"/) {
          return
        }
        labels = line
        sub(/[[:space:]].*$/, "", labels)
        value = line
        sub(/^.*[[:space:]]/, "", value)
        sub(/^.*le="/, "", labels)
        sub(/".*$/, "", labels)
        if (destination == 1) {
          before[labels] += value
        } else {
          after[labels] += value
        }
      }
      FNR == NR { record($0, 1); next }
      { record($0, 2) }
      END {
        split("0.006 0.010 0.018 0.024 0.032 0.042 0.056 0.075 0.100 0.178 0.316 0.562 1.000 +Inf", bounds, " ")
        total = after["+Inf"] - before["+Inf"]
        if (total <= 0) {
          print "nan"
          exit
        }
        target = q * total
        previous_count = 0
        previous_bound = 0
        for (i = 1; i <= 14; i++) {
          bound = bounds[i]
          count = after[bound] - before[bound]
          if (count >= target) {
            if (bound == "+Inf") {
              printf "%.6f", previous_bound
            } else if (count == previous_count) {
              printf "%.6f", bound
            } else {
              printf "%.6f", previous_bound + (bound - previous_bound) * (target - previous_count) / (count - previous_count)
            }
            exit
          }
          previous_count = count
          previous_bound = bound + 0
        }
      }
    ' "${metrics_before}" "${metrics_path}"
  }
  p50="$(histogram_quantile 0.50)"
  p95="$(histogram_quantile 0.95)"
  p99="$(histogram_quantile 0.99)"

  {
    printf 'duration=%s\n' "${duration}"
    printf 'target_qps=%s\n' "${qps}"
    printf 'completed_check_permission_requests=%s\n' "${completed_requests}"
    printf 'check_permission_p50_seconds=%s\n' "${p50}"
    printf 'check_permission_p95_seconds=%s\n' "${p95}"
    printf 'check_permission_p99_seconds=%s\n' "${p99}"
    printf 'step_errors=%s\n' "${step_errors}"
    printf 'incorrect_decisions=%s\n' "${incorrect_decisions}"
  } | tee "${summary_path}"

  [[ "${incorrect_decisions}" == "0" ]] ||
    fail "Thumper observed ${incorrect_decisions} incorrect authorization decision(s); see ${thumper_log}"
  [[ "${completed_requests}" -gt 0 ]] ||
    fail "Thumper did not complete any CheckPermission requests"

  printf 'Evidence written to %s\n' "${evidence_directory}"
}

case "${1:---help}" in
  placement)
    placement
    ;;
  verify)
    verify
    ;;
  load)
    shift
    load "$@"
    ;;
  -h | --help)
    usage
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
