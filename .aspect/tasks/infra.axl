def _harbor_child_gets(stage, namespace):
    release = "harbor-guardian"
    registry = release + "-registry"
    return [
        (stage + " harbor helmrelease", ["-n", namespace, "get", "helmreleases.helm.toolkit.fluxcd.io/" + release]),
        (stage + " harbor system helmrelease", ["-n", namespace, "get", "helmreleases.helm.toolkit.fluxcd.io/" + release + "-system"]),
        (stage + " harbor credentials secret", ["-n", namespace, "get", "secret/" + release + "-credentials"]),
        (stage + " harbor registry bucket claim", ["-n", namespace, "get", "bucketclaims.objectstorage.k8s.io/" + registry]),
        (stage + " harbor registry bucket access", ["-n", namespace, "get", "bucketaccesses.objectstorage.k8s.io/" + registry]),
        (stage + " harbor registry bucket secret", ["-n", namespace, "get", "secret/" + registry + "-bucket"]),
        (stage + " harbor registry s3 secret", ["-n", namespace, "get", "secret/" + registry + "-s3"]),
        (stage + " harbor core workload monitor", ["-n", namespace, "get", "workloadmonitors.cozystack.io/" + release + "-core"]),
        (stage + " harbor registry workload monitor", ["-n", namespace, "get", "workloadmonitors.cozystack.io/" + release + "-registry"]),
        (stage + " harbor portal workload monitor", ["-n", namespace, "get", "workloadmonitors.cozystack.io/" + release + "-portal"]),
    ]

def _harbor_child_waits(stage, namespace):
    release = "harbor-guardian"
    return [
        (stage + " harbor helmrelease", ["-n", namespace, "wait", "--for=condition=Ready", "helmreleases.helm.toolkit.fluxcd.io/" + release]),
        (stage + " harbor system helmrelease", ["-n", namespace, "wait", "--for=condition=Ready", "helmreleases.helm.toolkit.fluxcd.io/" + release + "-system"]),
    ]

def _harbor_bucket_checks(stage, namespace):
    registry = "harbor-guardian-registry"
    return [
        (stage + " harbor registry bucket protocol", ["-n", namespace, "get", "bucketclaims.objectstorage.k8s.io/" + registry, "-o", "jsonpath={.spec.protocols[0]}"], "s3"),
        (stage + " harbor registry bucket access protocol", ["-n", namespace, "get", "bucketaccesses.objectstorage.k8s.io/" + registry, "-o", "jsonpath={.spec.protocol}"], "s3"),
        (stage + " harbor registry bucket access claim", ["-n", namespace, "get", "bucketaccesses.objectstorage.k8s.io/" + registry, "-o", "jsonpath={.spec.bucketClaimName}"], registry),
        (stage + " harbor registry bucket access secret", ["-n", namespace, "get", "bucketaccesses.objectstorage.k8s.io/" + registry, "-o", "jsonpath={.spec.credentialsSecretName}"], registry + "-bucket"),
    ]

def _postgres_child_gets(stage, namespace):
    release = "postgres-guardian"
    return [
        (stage + " postgres helmrelease", ["-n", namespace, "get", "helmreleases.helm.toolkit.fluxcd.io/" + release]),
        (stage + " postgres cnpg cluster", ["-n", namespace, "get", "clusters.postgresql.cnpg.io/" + release]),
        (stage + " postgres credentials secret", ["-n", namespace, "get", "secret/" + release + "-credentials"]),
        (stage + " postgres init script secret", ["-n", namespace, "get", "secret/" + release + "-init-script"]),
        (stage + " postgres workload monitor", ["-n", namespace, "get", "workloadmonitors.cozystack.io/" + release]),
    ]

def _postgres_child_waits(stage, namespace):
    release = "postgres-guardian"
    return [
        (stage + " postgres helmrelease", ["-n", namespace, "wait", "--for=condition=Ready", "helmreleases.helm.toolkit.fluxcd.io/" + release]),
        (stage + " postgres cnpg cluster", ["-n", namespace, "wait", "--for=condition=Ready", "clusters.postgresql.cnpg.io/" + release]),
    ]

def _postgres_child_checks(stage, namespace):
    release = "postgres-guardian"
    return [
        (stage + " postgres cnpg instances", ["-n", namespace, "get", "clusters.postgresql.cnpg.io/" + release, "-o", "jsonpath={.spec.instances}"], "3"),
        (stage + " postgres cnpg storage class", ["-n", namespace, "get", "clusters.postgresql.cnpg.io/" + release, "-o", "jsonpath={.spec.storage.storageClass}"], "replicated"),
        (stage + " postgres cnpg min sync replicas", ["-n", namespace, "get", "clusters.postgresql.cnpg.io/" + release, "-o", "jsonpath={.spec.minSyncReplicas}"], "1"),
        (stage + " postgres cnpg max sync replicas", ["-n", namespace, "get", "clusters.postgresql.cnpg.io/" + release, "-o", "jsonpath={.spec.maxSyncReplicas}"], "2"),
        (stage + " postgres workload monitor replicas", ["-n", namespace, "get", "workloadmonitors.cozystack.io/" + release, "-o", "jsonpath={.spec.replicas}"], "3"),
        (stage + " postgres workload monitor kind", ["-n", namespace, "get", "workloadmonitors.cozystack.io/" + release, "-o", "jsonpath={.spec.kind}"], "postgres"),
    ]

def _clickhouse_child_gets(stage, namespace):
    release = "clickhouse-guardian"
    return [
        (stage + " clickhouse helmrelease", ["-n", namespace, "get", "helmreleases.helm.toolkit.fluxcd.io/" + release]),
        (stage + " clickhouse installation", ["-n", namespace, "get", "clickhouseinstallations.clickhouse.altinity.com/" + release]),
        (stage + " clickhouse keeper installation", ["-n", namespace, "get", "clickhousekeeperinstallations.clickhouse-keeper.altinity.com/" + release + "-keeper"]),
        (stage + " clickhouse keeper scrape", ["-n", namespace, "get", "vmpodscrapes.operator.victoriametrics.com/" + release + "-keeper"]),
        (stage + " clickhouse credentials secret", ["-n", namespace, "get", "secret/" + release + "-credentials"]),
        (stage + " clickhouse backup api secret", ["-n", namespace, "get", "secret/" + release + "-backup-api-auth"]),
        (stage + " clickhouse workload monitor", ["-n", namespace, "get", "workloadmonitors.cozystack.io/" + release]),
        (stage + " clickhouse keeper workload monitor", ["-n", namespace, "get", "workloadmonitors.cozystack.io/" + release + "-keeper"]),
    ]

def _clickhouse_child_waits(stage, namespace):
    release = "clickhouse-guardian"
    return [
        (stage + " clickhouse helmrelease", ["-n", namespace, "wait", "--for=condition=Ready", "helmreleases.helm.toolkit.fluxcd.io/" + release]),
    ]

def _clickhouse_child_checks(stage, namespace):
    release = "clickhouse-guardian"
    return [
        (stage + " clickhouse shards", ["-n", namespace, "get", "clickhouseinstallations.clickhouse.altinity.com/" + release, "-o", "jsonpath={.spec.configuration.clusters[0].layout.shardsCount}"], "1"),
        (stage + " clickhouse replicas", ["-n", namespace, "get", "clickhouseinstallations.clickhouse.altinity.com/" + release, "-o", "jsonpath={.spec.configuration.clusters[0].layout.replicasCount}"], "3"),
        (stage + " clickhouse backup sidecar", ["-n", namespace, "get", "clickhouseinstallations.clickhouse.altinity.com/" + release, "-o", "jsonpath={.spec.templates.podTemplates[0].spec.containers[1].name}"], "clickhouse-backup"),
        (stage + " clickhouse backup api port", ["-n", namespace, "get", "clickhouseinstallations.clickhouse.altinity.com/" + release, "-o", "jsonpath={.spec.templates.podTemplates[0].spec.containers[1].ports[0].name}"], "ch-backup-api"),
        (stage + " clickhouse keeper replicas", ["-n", namespace, "get", "clickhousekeeperinstallations.clickhouse-keeper.altinity.com/" + release + "-keeper", "-o", "jsonpath={.spec.configuration.clusters[0].layout.replicasCount}"], "3"),
        (stage + " clickhouse workload monitor replicas", ["-n", namespace, "get", "workloadmonitors.cozystack.io/" + release, "-o", "jsonpath={.spec.replicas}"], "3"),
        (stage + " clickhouse workload monitor kind", ["-n", namespace, "get", "workloadmonitors.cozystack.io/" + release, "-o", "jsonpath={.spec.kind}"], "clickhouse"),
        (stage + " clickhouse keeper workload monitor replicas", ["-n", namespace, "get", "workloadmonitors.cozystack.io/" + release + "-keeper", "-o", "jsonpath={.spec.replicas}"], "3"),
        (stage + " clickhouse keeper workload monitor kind", ["-n", namespace, "get", "workloadmonitors.cozystack.io/" + release + "-keeper", "-o", "jsonpath={.spec.kind}"], "clickhouse"),
    ]

