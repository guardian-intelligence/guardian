def _load_harbor_registry_impl(ctx):
    kubectl = _kubectl_path(ctx)
    if kubectl == None:
        return 1
    oras = _oras_path(ctx)
    if oras == None:
        return 1

    rc = _check_live_context(ctx, kubectl)
    if rc != 0:
        return rc
    if ctx.args.revision != "":
        rc = _check_flux_revision(ctx, kubectl, ctx.args.revision)
        if rc != 0:
            return rc

    load_args = [
        "--oras",
        oras,
        "--kubectl",
        kubectl,
        "--stage",
        ctx.args.stage,
        "--repository",
        ctx.args.repository,
        "--iterations",
        ctx.args.iterations,
        "--payload-bytes",
        ctx.args.payload_bytes,
        "--request-timeout",
        ctx.args.request_timeout,
        "--wait-timeout",
        ctx.args.wait_timeout,
    ]
    if ctx.args.kubeconfig != "":
        load_args.extend(["--kubeconfig", _kubeconfig_path(ctx)])
    if ctx.args.host != "":
        load_args.extend(["--host", ctx.args.host])
    if ctx.args.tag != "":
        load_args.extend(["--tag", ctx.args.tag])

    return checked_spawn(
        ctx,
        "bazelisk",
        ["run", HARBOR_REGISTRY_TARGET, "--"] + load_args,
        cwd = ws_path(ctx),
        label = "cozystack harbor registry load",
    )

def _openbao_drill_impl(ctx):
    kubectl = _kubectl_path(ctx)
    if kubectl == None:
        return 1

    rc = _check_live_context(ctx, kubectl)
    if rc != 0:
        return rc
    if ctx.args.revision != "":
        rc = _check_flux_revision(ctx, kubectl, ctx.args.revision)
        if rc != 0:
            return rc

    drill_args = [
        "--kubectl",
        kubectl,
        "--namespace",
        ctx.args.namespace,
        "--statefulset",
        ctx.args.statefulset,
        "--bootstrap-secret",
        ctx.args.bootstrap_secret,
        "--mode",
        ctx.args.mode,
        "--request-timeout",
        ctx.args.request_timeout,
        "--wait-timeout",
        ctx.args.wait_timeout,
    ]
    if ctx.args.kubeconfig != "":
        drill_args.extend(["--kubeconfig", _kubeconfig_path(ctx)])
    if ctx.args.snapshot_name != "":
        drill_args.extend(["--snapshot-name", ctx.args.snapshot_name])

    return checked_spawn(
        ctx,
        "bazelisk",
        ["run", OPENBAO_DRILL_TARGET, "--"] + drill_args,
        cwd = ws_path(ctx),
        label = "cozystack openbao drill",
    )

def _openbao_apply_impl(ctx):
    kubectl = _kubectl_path(ctx)
    if kubectl == None:
        return 1
    tofu = _tofu_path(ctx)
    if tofu == None:
        return 1

    endpoint = _tofu_backend_endpoint(ctx, ctx.args.tofu_backend_endpoint)
    if endpoint == None:
        return 1

    rc = _check_live_context(ctx, kubectl)
    if rc != 0:
        return rc
    if ctx.args.revision != "":
        rc = _check_flux_revision(ctx, kubectl, ctx.args.revision)
        if rc != 0:
            return rc

    apply_args = [
        "--kubectl",
        kubectl,
        "--tofu",
        tofu,
        "--namespace",
        ctx.args.namespace,
        "--statefulset",
        ctx.args.statefulset,
        "--service",
        ctx.args.service,
        "--bootstrap-secret",
        ctx.args.bootstrap_secret,
        "--root",
        ws_path(ctx, GUARDIAN_MGMT_OPENBAO_ROOT),
        "--backend-endpoint",
        endpoint,
        "--mode",
        ctx.args.mode,
        "--request-timeout",
        ctx.args.request_timeout,
        "--wait-timeout",
        ctx.args.wait_timeout,
        "--port-forward-ready-timeout",
        ctx.args.port_forward_ready_timeout,
    ]
    if ctx.args.kubeconfig != "":
        apply_args.extend(["--kubeconfig", _kubeconfig_path(ctx)])

    return checked_spawn(
        ctx,
        "bazelisk",
        ["run", OPENBAO_APPLY_TARGET, "--"] + apply_args,
        cwd = ws_path(ctx),
        label = "cozystack openbao apply",
    )

def _openbao_backup_secrets_impl(ctx):
    kubectl = _kubectl_path(ctx)
    if kubectl == None:
        return 1

    endpoint = _tofu_backend_endpoint(ctx, ctx.args.endpoint)
    if endpoint == None:
        return 1

    rc = _check_live_context(ctx, kubectl)
    if rc != 0:
        return rc
    if ctx.args.revision != "":
        rc = _check_flux_revision(ctx, kubectl, ctx.args.revision)
        if rc != 0:
            return rc

    secret_args = [
        "--kubectl",
        kubectl,
        "--namespace",
        ctx.args.namespace,
        "--statefulset",
        ctx.args.statefulset,
        "--service",
        ctx.args.service,
        "--bootstrap-secret",
        ctx.args.bootstrap_secret,
        "--endpoint",
        endpoint,
        "--bucket",
        ctx.args.bucket,
        "--region",
        ctx.args.region,
        "--stages",
        ctx.args.stages,
        "--dry-run=" + ctx.args.dry_run,
        "--force-sync=" + ctx.args.force_sync,
        "--allow-shared-backup-credential=" + ctx.args.allow_shared_backup_credential,
        "--request-timeout",
        ctx.args.request_timeout,
        "--wait-timeout",
        ctx.args.wait_timeout,
        "--sync-wait-timeout",
        ctx.args.sync_wait_timeout,
        "--port-forward-ready-timeout",
        ctx.args.port_forward_ready_timeout,
    ]
    if ctx.args.kubeconfig != "":
        secret_args.extend(["--kubeconfig", _kubeconfig_path(ctx)])

    return checked_spawn(
        ctx,
        "bazelisk",
        ["run", OPENBAO_BACKUP_SECRETS_TARGET, "--"] + secret_args,
        cwd = ws_path(ctx),
        label = "cozystack openbao backup secrets",
    )

def _publish_company_site_impl(ctx):
    kubectl = _kubectl_path(ctx)
    if kubectl == None:
        return 1

    rc = _check_live_context(ctx, kubectl)
    if rc != 0:
        return rc
    if ctx.args.revision != "":
        rc = _check_flux_revision(ctx, kubectl, ctx.args.revision)
        if rc != 0:
            return rc

    publish_args = [
        "--kubectl",
        kubectl,
        "--request-timeout",
        ctx.args.request_timeout,
        "--wait-timeout",
        ctx.args.wait_timeout,
        "--host",
        ctx.args.host,
        "--project",
        ctx.args.project,
        "--project-public=" + ctx.args.project_public,
        "--port-forward-service",
        ctx.args.port_forward_service,
        "--port-forward-ready-timeout",
        ctx.args.port_forward_ready_timeout,
        "--namespace",
        ctx.args.namespace,
        "--secret",
        ctx.args.secret,
        "--target",
        ctx.args.target,
        "--workspace",
        ws_path(ctx),
    ]
    if ctx.args.kubeconfig != "":
        publish_args.extend(["--kubeconfig", _kubeconfig_path(ctx)])

    return checked_spawn(
