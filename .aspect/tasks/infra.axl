def _apply_evidence_restore_impl(ctx):
    return _kubectl(ctx, ["apply", "-f", "src/infrastructure/evidence/database-restore.yaml"], label = "kubectl apply -f src/infrastructure/evidence/database-restore.yaml")

def _capture_evidence(ctx, phase = None, allow_failures = None):
    rc = checked_spawn(
        ctx,
        "bazelisk",
        ["build", KUBECTL_TARGET, TALOSCTL_TARGET, CAPTURE_EVIDENCE_TARGET],
        cwd = ws_path(ctx),
        label = "bazelisk build " + KUBECTL_TARGET + " " + TALOSCTL_TARGET + " " + CAPTURE_EVIDENCE_TARGET,
    )
    if rc != 0:
        return rc
    capture_args = _kubectl_live_flags(ctx)
    if ctx.args.out_dir != "":
        capture_args.extend(["--out-dir", ctx.args.out_dir])
    if phase != None:
        capture_args.extend(["--phase", phase])
    elif ctx.args.phase != "":
        capture_args.extend(["--phase", ctx.args.phase])
    if ctx.args.talosconfig != "":
        capture_args.extend(["--talosconfig", ctx.args.talosconfig])
    if ctx.args.talos_endpoints != "":
        capture_args.extend(["--talos-endpoints", ctx.args.talos_endpoints])
    if ctx.args.talos_nodes != "":
        capture_args.extend(["--talos-nodes", ctx.args.talos_nodes])
    if allow_failures != None:
        if allow_failures:
            capture_args.append("--allow-failures")
    elif ctx.args.allow_failures:
        capture_args.append("--allow-failures")
    return checked_spawn(
        ctx,
        ws_path(ctx, CAPTURE_EVIDENCE_BIN),
        capture_args,
        cwd = ws_path(ctx),
        env = {
            "KUBECTL_BIN": ws_path(ctx, KUBECTL_RUNNER),
            "TALOSCTL_BIN": ws_path(ctx, TALOSCTL_RUNNER),
        },
        label = "capture management evidence",
    )

def _capture_evidence_impl(ctx):
    return _capture_evidence(ctx)

def _publish_company_site_impl(ctx):
    return checked_spawn(
        ctx,
        "bazelisk",
        ["run", COMPANY_SITE_PUSH_TARGET],
        cwd = ws_path(ctx),
        label = "bazelisk run " + COMPANY_SITE_PUSH_TARGET,
    )

def _preflight_impl(ctx):
    rc = _inventory_check_impl(ctx)
    if rc != 0:
        return rc
    rc = _validate_impl(ctx)
    if rc != 0:
        return rc
    rc = checked_spawn(
        ctx,
        "bazelisk",
        [
            "build",
            "//:build",
            "//src/products/company/site:image",
            "//src/products/company/site:image.digest",
        ],
        cwd = ws_path(ctx),
        label = "bazelisk build //:build //src/products/company/site:image //src/products/company/site:image.digest",
    )
    if rc != 0:
        return rc
    return _quiet_bazel(
        ctx,
        ["run", KUBECTL_TARGET, "--", "kustomize", "src/infrastructure/base"],
        "kubectl kustomize src/infrastructure/base",
    )

def _evidence_wait_impl(ctx):
    return _kubectl_many(ctx, [
        ["wait", "job/evidence-postgres-load", "-n", "tenant-root", "--for=condition=complete", "--timeout", ctx.args.timeout],
        ["wait", "job/evidence-clickhouse-load", "-n", "tenant-root", "--for=condition=complete", "--timeout", ctx.args.timeout],
        ["wait", "job/evidence-harbor-oci-read", "-n", "tenant-root", "--for=condition=complete", "--timeout", ctx.args.timeout],
        ["wait", "job/evidence-openbao-load", "-n", "tenant-root", "--for=condition=complete", "--timeout", ctx.args.timeout],
        ["wait", "job/evidence-http-load", "-n", "tenant-root", "--for=condition=complete", "--timeout", ctx.args.timeout],
        ["wait", "job/evidence-storage-smoke", "-n", "tenant-root", "--for=condition=complete", "--timeout", ctx.args.timeout],
        ["wait", "backupjob/evidence-postgres-adhoc", "-n", "tenant-root", "--for=jsonpath={.status.phase}=Succeeded", "--timeout", ctx.args.timeout],
        ["wait", "backupjob/evidence-clickhouse-adhoc", "-n", "tenant-root", "--for=jsonpath={.status.phase}=Succeeded", "--timeout", ctx.args.timeout],
    ])

def _evidence_restore_wait_impl(ctx):
    return _kubectl_many(ctx, [
        ["wait", "restorejob/evidence-postgres-to-copy", "-n", "tenant-root", "--for=jsonpath={.status.phase}=Succeeded", "--timeout", ctx.args.timeout],
        ["wait", "restorejob/evidence-clickhouse-to-copy", "-n", "tenant-root", "--for=jsonpath={.status.phase}=Succeeded", "--timeout", ctx.args.timeout],
    ])

def _evidence_snapshot_impl(ctx):
    return _kubectl_many(ctx, [
        ["get", "job/evidence-postgres-load", "job/evidence-clickhouse-load", "job/evidence-harbor-oci-read", "job/evidence-openbao-load", "job/evidence-http-load", "job/evidence-storage-smoke", "-n", "tenant-root", "-o", "wide", "--ignore-not-found"],
        ["get", "secret/guardian-openbao-evidence-token", "-n", "tenant-root", "-o", "name", "--ignore-not-found"],
        ["get", "pvc/evidence-replicated-retain", "-n", "tenant-root", "-o", "wide", "--ignore-not-found"],
        ["get", "backupjob/evidence-postgres-adhoc", "backupjob/evidence-clickhouse-adhoc", "-n", "tenant-root", "-o", "yaml", "--ignore-not-found"],
        ["get", "restorejob/evidence-postgres-to-copy", "restorejob/evidence-clickhouse-to-copy", "-n", "tenant-root", "-o", "yaml", "--ignore-not-found"],
        ["get", "backup", "-n", "tenant-root", "-l", "guardian.dev/evidence=infrastructure", "-o", "wide"],
        ["get", "postgres/guardian-restore-check", "clickhouse/ledger-restore-check", "-n", "tenant-root", "-o", "wide", "--ignore-not-found"],
        ["get", "pods", "-n", "tenant-root", "-l", "guardian.dev/evidence=infrastructure", "-o", "wide", "--ignore-not-found"],
    ])

def _evidence_logs_impl(ctx):
    return _kubectl_many(ctx, [
        ["logs", "job/evidence-postgres-load", "-n", "tenant-root"],
        ["logs", "job/evidence-clickhouse-load", "-n", "tenant-root"],
        ["logs", "job/evidence-harbor-oci-read", "-n", "tenant-root"],
        ["logs", "job/evidence-openbao-load", "-n", "tenant-root"],
        ["logs", "job/evidence-http-load", "-n", "tenant-root"],
        ["logs", "job/evidence-storage-smoke", "-n", "tenant-root"],
    ])

def _evidence_clean_impl(ctx):
    commands = [
        ["delete", "job/evidence-postgres-load", "job/evidence-clickhouse-load", "job/evidence-harbor-oci-read", "job/evidence-openbao-load", "job/evidence-http-load", "job/evidence-storage-smoke", "-n", "tenant-root", "--ignore-not-found"],
        ["delete", "backupjob/evidence-postgres-adhoc", "backupjob/evidence-clickhouse-adhoc", "-n", "tenant-root", "--ignore-not-found"],
        ["delete", "restorejob/evidence-postgres-to-copy", "restorejob/evidence-clickhouse-to-copy", "-n", "tenant-root", "--ignore-not-found"],
        ["delete", "postgres/guardian-restore-check", "clickhouse/ledger-restore-check", "-n", "tenant-root", "--ignore-not-found"],
        ["delete", "configmap/evidence-postgres-load", "configmap/evidence-clickhouse-load", "configmap/evidence-harbor-oci-read", "configmap/evidence-openbao-load", "configmap/evidence-http-load", "configmap/evidence-storage-smoke", "-n", "tenant-root", "--ignore-not-found"],
    ]
    if ctx.args.delete_pvc:
        commands.append(["delete", "pvc/evidence-replicated-retain", "-n", "tenant-root", "--ignore-not-found"])
    return _kubectl_many(ctx, commands)

def _evidence_run_impl(ctx):
    steps = [
        ["clean", _evidence_clean_impl],
        ["apply", _apply_evidence_impl],
        ["wait", _evidence_wait_impl],
        ["restore-apply", _apply_evidence_restore_impl],
        ["restore-wait", _evidence_restore_wait_impl],
        ["logs", _evidence_logs_impl],
        ["snapshot", _evidence_snapshot_impl],
        ["capture", _capture_evidence_impl],
    ]
    for pair in steps:
        name = pair[0]
        fn = pair[1]
        rc = fn(ctx)
        if rc != 0:
            ctx.std.io.stderr.write("evidence-run failed during " + name + "; capturing current evidence state\n")
            _capture_evidence(ctx, allow_failures = True)
            return rc
    return 0

def _live_snapshot_impl(ctx):
    return _kubectl_many(ctx, [
        ["version"],
        ["get", "nodes", "-o", "wide"],
        ["get", "storageclass", "-o", "wide"],
        ["get", "pv", "-o", "wide"],
        ["get", "pvc", "-A", "-o", "wide"],
        ["get", "secret", "guardian-r2-db-backups", "-n", "tenant-root", "-o", "name"],
        ["get", "packages", "-A", "-o", "wide"],
        ["get", "tenants", "-A", "-o", "wide"],
        ["get", "cnpgs.strategy.backups.cozystack.io", "-o", "wide"],
        ["get", "altinities.strategy.backups.cozystack.io", "-o", "wide"],
        ["get", "backupclasses", "-o", "wide"],
        ["get", "plans", "-A", "-o", "wide"],
        ["get", "backupjobs", "-A", "-o", "wide"],
        ["get", "backups", "-A", "-o", "wide"],
        ["get", "harbor", "oci", "-n", "tenant-root", "-o", "yaml"],
        ["get", "clickhouse", "ledger", "-n", "tenant-root", "-o", "yaml"],
        ["get", "postgres", "guardian", "-n", "tenant-root", "-o", "yaml"],
        ["get", "openbao", "guardian", "-n", "tenant-root", "-o", "yaml"],
        ["get", "deploy/company-site", "svc/company-site", "ing/company-site", "-n", "tenant-dev", "-o", "wide"],
        ["get", "deploy/company-site", "svc/company-site", "ing/company-site", "-n", "tenant-gamma", "-o", "wide"],
        ["get", "deploy/company-site", "svc/company-site", "ing/company-site", "-n", "tenant-root", "-o", "wide"],
        ["get", "certificate", "-A", "-o", "wide"],
        ["get", "ingress", "-A", "-o", "wide"],
        ["get", "pods", "-A", "-o", "wide"],
    ])

def _live_rollout_impl(ctx):
    return _kubectl_many(ctx, [
        ["rollout", "status", "deployment/company-site", "-n", "tenant-dev", "--timeout", ctx.args.timeout],
        ["rollout", "status", "deployment/company-site", "-n", "tenant-gamma", "--timeout", ctx.args.timeout],
        ["rollout", "status", "deployment/company-site", "-n", "tenant-root", "--timeout", ctx.args.timeout],
    ])

def _talos_health_impl(ctx):
    rc = _talosctl(ctx, ["health"], label = "talosctl health")
    if rc != 0:
        return rc
    return _talosctl(ctx, ["etcd", "members"], label = "talosctl etcd members")

def _outage_snapshot_impl(ctx):
    if ctx.args.node == "":
        ctx.std.io.stderr.write("ERROR: pass --node with the Kubernetes node name being exercised\n")
        return 1
    return _kubectl_many(ctx, [
        ["get", "node", ctx.args.node, "-o", "wide"],
        ["get", "pods", "-A", "--field-selector", "spec.nodeName=" + ctx.args.node, "-o", "wide"],
        ["get", "nodes", "-o", "wide"],
        ["get", "pods", "-A", "-o", "wide"],
        ["rollout", "status", "deployment/company-site", "-n", "tenant-dev", "--timeout", ctx.args.timeout],
        ["rollout", "status", "deployment/company-site", "-n", "tenant-gamma", "--timeout", ctx.args.timeout],
        ["rollout", "status", "deployment/company-site", "-n", "tenant-root", "--timeout", ctx.args.timeout],
    ])

def _outage_cordon_impl(ctx):
    if ctx.args.node == "":
        ctx.std.io.stderr.write("ERROR: pass --node with the Kubernetes node name to cordon\n")
        return 1
    return _kubectl(ctx, ["cordon", ctx.args.node], label = "kubectl cordon " + ctx.args.node)

def _outage_drain_impl(ctx):
    if ctx.args.node == "":
        ctx.std.io.stderr.write("ERROR: pass --node with the Kubernetes node name to drain\n")
        return 1
    return _kubectl(ctx, [
        "drain",
        ctx.args.node,
        "--ignore-daemonsets",
        "--delete-emptydir-data",
        "--timeout",
        ctx.args.timeout,
    ], label = "kubectl drain " + ctx.args.node)

def _outage_uncordon_impl(ctx):
    if ctx.args.node == "":
        ctx.std.io.stderr.write("ERROR: pass --node with the Kubernetes node name to uncordon\n")
        return 1
    return _kubectl(ctx, ["uncordon", ctx.args.node], label = "kubectl uncordon " + ctx.args.node)

def _outage_run_impl(ctx):
    if ctx.args.node == "":
        ctx.std.io.stderr.write("ERROR: pass --node with the Kubernetes node name under outage rehearsal\n")
        return 1
    rc = _outage_snapshot_impl(ctx)
    if rc != 0:
        _capture_evidence(ctx, phase = "outage-failed", allow_failures = True)
        return rc
    rc = _capture_evidence(ctx, phase = "outage-before")
    if rc != 0:
        return rc
    rc = _outage_cordon_impl(ctx)
    if rc != 0:
        _capture_evidence(ctx, phase = "outage-failed", allow_failures = True)
        return rc
    rc = _outage_drain_impl(ctx)
    if rc != 0:
        _capture_evidence(ctx, phase = "outage-failed", allow_failures = True)
        return rc
    rc = _outage_snapshot_impl(ctx)
    if rc != 0:
        _capture_evidence(ctx, phase = "outage-failed", allow_failures = True)
        return rc
    rc = _capture_evidence(ctx, phase = "outage-drained", allow_failures = True)
    if rc != 0:
        return rc
    rc = _outage_uncordon_impl(ctx)
    if rc != 0:
        _capture_evidence(ctx, phase = "outage-failed", allow_failures = True)
        return rc
    rc = _outage_snapshot_impl(ctx)
    if rc != 0:
        _capture_evidence(ctx, phase = "outage-failed", allow_failures = True)
        return rc
    return _capture_evidence(ctx, phase = "outage-after")

_KUBECTL_LIVE_ARGS = {
    "context": args.string(default = "", description = "Optional kubeconfig context."),
    "kubeconfig": args.string(default = "", description = "Optional kubeconfig path. Defaults to kubectl's environment/config loading."),
}

_KUBECTL_TIMEOUT_ARGS = dict(_KUBECTL_LIVE_ARGS)
_KUBECTL_TIMEOUT_ARGS.update({
    "timeout": args.string(default = "10m", description = "kubectl wait/rollout timeout."),
})

_KUBECTL_OUTAGE_ARGS = dict(_KUBECTL_TIMEOUT_ARGS)
_KUBECTL_OUTAGE_ARGS.update({
    "node": args.string(default = "", description = "Kubernetes node name under outage rehearsal."),
})

_KUBECTL_EVIDENCE_CLEAN_ARGS = dict(_KUBECTL_LIVE_ARGS)
_KUBECTL_EVIDENCE_CLEAN_ARGS.update({
    "delete_pvc": args.boolean(default = False, description = "Also delete the retained storage-smoke PVC and its checksum data."),
})

_TALOS_LIVE_ARGS = {
    "endpoints": args.string(default = "10.8.0.250", description = "Talos API endpoint list."),
    "nodes": args.string(default = "10.8.0.11,10.8.0.12,10.8.0.13", description = "Talos node list."),
    "talosconfig": args.string(default = "", description = "Optional talosconfig path."),
}

_CAPTURE_EVIDENCE_ARGS = dict(_KUBECTL_LIVE_ARGS)
_CAPTURE_EVIDENCE_ARGS.update({
    "allow_failures": args.boolean(default = False, description = "Write all outputs and exit 0 even if one captured command fails."),
    "out_dir": args.string(default = "", description = "Output directory; defaults under docs/reports/infrastructure/live-runs/."),
    "phase": args.string(default = "snapshot", description = "Evidence phase label, e.g. baseline, evidence, outage-before, outage-down, outage-after."),
    "talos_endpoints": args.string(default = "10.8.0.250", description = "Talos API endpoint list."),
    "talos_nodes": args.string(default = "10.8.0.11,10.8.0.12,10.8.0.13", description = "Talos node list."),
    "talosconfig": args.string(default = "", description = "Optional talosconfig path. Talos capture is skipped unless set or TALOSCONFIG is present."),
})

_OUTAGE_RUN_ARGS = dict(_CAPTURE_EVIDENCE_ARGS)
_OUTAGE_RUN_ARGS.update({
    "node": args.string(default = "", description = "Kubernetes node name under outage rehearsal."),
    "timeout": args.string(default = "10m", description = "kubectl drain/rollout timeout."),
})

_EVIDENCE_RUN_ARGS = dict(_CAPTURE_EVIDENCE_ARGS)
_EVIDENCE_RUN_ARGS.update({
    "delete_pvc": args.boolean(default = False, description = "Also delete the retained storage-smoke PVC and its checksum data before running evidence."),
    "timeout": args.string(default = "30m", description = "kubectl wait/rollout timeout for evidence jobs, backup jobs, and restore jobs."),
})

