        "component": args.string(default = "postgres", description = "Database component: postgres or clickhouse."),
        "kubeconfig": args.string(default = "", description = "Kubeconfig for guardian-mgmt. Defaults to KUBECONFIG/current context."),
        "name": args.string(default = "", description = "Optional Kubernetes Job name. Defaults to a timestamped DNS label."),
        "pgbench_clients": args.string(default = "4", description = "pgbench concurrent client count."),
        "pgbench_duration_seconds": args.string(default = "60", description = "pgbench run duration in seconds."),
        "pgbench_jobs": args.string(default = "2", description = "pgbench worker thread count."),
        "pgbench_scale": args.string(default = "10", description = "pgbench initialization scale factor."),
        "request_timeout": args.string(default = "15s", description = "kubectl API request timeout."),
        "revision": args.string(default = "", description = "Optional expected Flux-reconciled commit SHA to check before the load test."),
        "stage": args.string(default = "root", description = "Guardian bootstrap stage: root."),
        "ttl_seconds_after_finished": args.string(default = "86400", description = "Kubernetes Job ttlSecondsAfterFinished."),
        "wait_timeout": args.string(default = "20m", description = "Timeout for load Job completion."),
    },
)

