    rc = checked_spawn(
        ctx,
        "bazelisk",
        ["build", KUBECTL_TARGET, DB_BACKUP_SECRET_TARGET],
        cwd = ws_path(ctx),
        label = "bazelisk build " + KUBECTL_TARGET + " " + DB_BACKUP_SECRET_TARGET,
