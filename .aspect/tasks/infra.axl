def _capture_stdout(ctx, program, args, cwd = None, label = None, auth_hint = "kubernetes"):
    label_str = label if label != None else program
    cmd = ctx.std.process.command(program).args(args)
    if cwd != None:
        cmd = cmd.current_dir(cwd)
    if ctx.std.io.stderr.is_tty:
        ctx.std.io.stderr.write("$ " + label_str + "\n")
    r = cmd.stdout("piped").stderr("piped").spawn().wait_with_output()
    if r.status.code != 0:
        ctx.std.io.stderr.write("ERROR: " + label_str + " failed\n")
        if r.stdout != "":
            ctx.std.io.stderr.write(r.stdout)
        if r.stderr != "":
            ctx.std.io.stderr.write(r.stderr)
            _write_auth_hint(ctx, r.stderr, auth_hint)
        return None
    return r.stdout.strip()

def _capture_success(ctx, program, args, cwd = None, label = None, auth_hint = "kubernetes"):
    label_str = label if label != None else program
    cmd = ctx.std.process.command(program).args(args)
    if cwd != None:
        cmd = cmd.current_dir(cwd)
    if ctx.std.io.stderr.is_tty:
        ctx.std.io.stderr.write("$ " + label_str + "\n")
    r = cmd.stdout("piped").stderr("piped").spawn().wait_with_output()
    if r.status.code != 0:
        ctx.std.io.stderr.write("ERROR: " + label_str + " failed\n")
        if r.stdout != "":
            ctx.std.io.stderr.write(r.stdout)
        if r.stderr != "":
            ctx.std.io.stderr.write(r.stderr)
            _write_auth_hint(ctx, r.stderr, auth_hint)
        return 1
    return 0

def _write_auth_hint(ctx, stderr, auth_hint):
    if stderr.find("tls: failed to verify certificate") == -1:
        return
    if stderr.find("x509:") == -1:
        return
    if auth_hint == "talos":
        ctx.std.io.stderr.write(
            "ERROR: Talos rejected the local talosconfig credentials. Refresh "
            + "the guardian-mgmt Talos operator state from the current cluster "
            + "before running Talos L2 validation; do not use insecure TLS flags "
            + "for management-plane validation.\n",
        )
        return
    ctx.std.io.stderr.write(
        "ERROR: Kubernetes rejected the local cluster credentials. Refresh the "
        + "guardian-mgmt kubeconfig/Talos operator state from the current cluster "
        + "with `aspect infra kubeconfig` when the local Talm state is current; "
        + "do not use insecure TLS flags for management-cluster debugging.\n",
    )

def _tofu_root(ctx, root, args, label, env = None):
    return checked_spawn(
        ctx,
        "bazelisk",
        ["run", TOFU_TARGET, "--", "-chdir=" + ws_path(ctx, root)] + args,
        cwd = ws_path(ctx),
        env = env,
        label = label,
    )

def _tofu_validate_env(ctx, label):
    return {
        "AWS_EC2_METADATA_DISABLED": "true",
        "TF_DATA_DIR": ws_path(ctx, ".terraform/validate/" + label),
    }

def _cloudflare_account_id(ctx):
    path = ws_path(ctx, GUARDIAN_BACKEND_TFVARS)
    if not ctx.std.fs.exists(path):
        ctx.std.io.stderr.write("ERROR: missing " + GUARDIAN_BACKEND_TFVARS + "\n")
        return None

    for line in ctx.std.fs.read_to_string(path).split("\n"):
        item = line.strip()
        if item == "" or item.startswith("#"):
            continue
        parts = item.split("=", 1)
        if len(parts) != 2:
            continue
        if parts[0].strip() != "cloudflare_account_id":
            continue
        account_id = parts[1].strip()
        if account_id.startswith("\"") and account_id.endswith("\""):
            account_id = account_id[1:len(account_id) - 1]
        if account_id == "":
            ctx.std.io.stderr.write("ERROR: cloudflare_account_id is empty in " + GUARDIAN_BACKEND_TFVARS + "\n")
            return None
        return account_id

    ctx.std.io.stderr.write("ERROR: cloudflare_account_id is missing in " + GUARDIAN_BACKEND_TFVARS + "\n")
    return None

def _tofu_backend_endpoint(ctx, value):
    endpoint = value
    if endpoint == "":
        endpoint = ctx.std.env.var("AWS_ENDPOINT_URL_S3") or ""
    if endpoint != "":
        return endpoint

    account_id = _cloudflare_account_id(ctx)
    if account_id == None:
        return None
    return "https://" + account_id + ".r2.cloudflarestorage.com"

def _tofu_backend_roots(ctx, root):
    if root == "all":
        return [
            (GUARDIAN_MGMT_ROOT, "guardian-mgmt"),
            (GUARDIAN_MGMT_OPENBAO_ROOT, "guardian-mgmt-openbao"),
            (GUARDIAN_MGMT_DNS_ROOT, "guardian-mgmt-dns"),
        ]
    if root == "guardian-mgmt":
        return [(GUARDIAN_MGMT_ROOT, "guardian-mgmt")]
    if root == "guardian-mgmt-openbao":
        return [(GUARDIAN_MGMT_OPENBAO_ROOT, "guardian-mgmt-openbao")]
    if root == "guardian-mgmt-dns":
        return [(GUARDIAN_MGMT_DNS_ROOT, "guardian-mgmt-dns")]
    ctx.std.io.stderr.write("ERROR: --root must be all, guardian-mgmt, guardian-mgmt-openbao, or guardian-mgmt-dns\n")
    return None

def _tofu_backend_init(ctx, roots, endpoint):
    for root, label in roots:
        args = [
            "init",
            "-input=false",
            "-reconfigure",
            "-backend-config=endpoint=" + endpoint,
        ]
        rc = _tofu_root(
            ctx,
            root,
            args,
            "tofu init backend " + label,
        )
        if rc != 0:
            return rc
    return 0

def _kubectl_path(ctx):
    rc = checked_spawn(
        ctx,
        "bazelisk",
        ["build", KUBECTL_FILE_TARGET],
        cwd = ws_path(ctx),
        label = "bazelisk build " + KUBECTL_FILE_TARGET,
    )
    if rc != 0:
        return None
    output_base = _capture_stdout(
        ctx,
        "bazelisk",
        ["info", "output_base"],
        cwd = ws_path(ctx),
        label = "bazelisk info output_base",
    )
    if output_base == None:
        return None
    return output_base + "/external/+http_file+kubectl_linux_amd64/file/kubectl"

