def _tofu_path(ctx):
    rc = checked_spawn(
        ctx,
        "bazelisk",
        ["build", TOFU_TARGET],
        cwd = ws_path(ctx),
        label = "bazelisk build " + TOFU_TARGET,
    )
    if rc != 0:
        return None
    output_path = _capture_stdout(
        ctx,
        "bazelisk",
        ["cquery", TOFU_TARGET, "--output=files"],
        cwd = ws_path(ctx),
        label = "bazelisk cquery " + TOFU_TARGET + " --output=files",
    )
    if output_path == None:
        return None
    return ws_path(ctx, output_path)

def _kubectl_args(ctx, args):
    return _kubectl_args_for(ctx, ctx.args.kubeconfig, args)

def _kubectl_args_for(ctx, kubeconfig, args):
    out = []
    if kubeconfig != "":
        out.extend(["--kubeconfig", _workspace_path_if_relative(ctx, kubeconfig)])
    if ctx.args.request_timeout != "":
        out.append("--request-timeout=" + ctx.args.request_timeout)
    out.extend(args)
    return out

def _kubeconfig_path(ctx):
    return _workspace_path_if_relative(ctx, ctx.args.kubeconfig)

def _workspace_path_if_relative(ctx, path):
    if path == "" or path.startswith("/") or path.startswith("~"):
        return path
    return ws_path(ctx, path)

def _talosconfig_path(ctx):
    if ctx.args.talosconfig != "":
        return ctx.args.talosconfig
    return ws_path(ctx, ctx.args.root) + "/talosconfig"

def _talosctl_args(ctx, args):
    out = [
        "--talosconfig",
        _talosconfig_path(ctx),
        "--endpoints",
        ctx.args.endpoints,
        "--nodes",
        ctx.args.nodes,
    ]
    out.extend(args)
    return out

def _kubectl_capture(ctx, kubectl, args, label):
    return _kubectl_capture_for(ctx, kubectl, ctx.args.kubeconfig, args, label)

def _kubectl_capture_for(ctx, kubectl, kubeconfig, args, label):
    return _capture_stdout(
        ctx,
        kubectl,
        _kubectl_args_for(ctx, kubeconfig, args),
        cwd = ws_path(ctx),
        label = label,
    )

def _talosctl_capture(ctx, talosctl, args, label):
    return _capture_stdout(
        ctx,
        talosctl,
        _talosctl_args(ctx, args),
        cwd = ws_path(ctx),
        label = label,
        auth_hint = "talos",
    )

def _kubectl_success(ctx, kubectl, args, label):
    return _kubectl_success_for(ctx, kubectl, ctx.args.kubeconfig, args, label)

def _kubectl_success_for(ctx, kubectl, kubeconfig, args, label):
    return _capture_success(
        ctx,
        kubectl,
        _kubectl_args_for(ctx, kubeconfig, args),
        cwd = ws_path(ctx),
        label = label,
    )

def _talosctl_success(ctx, talosctl, args, label):
    return _capture_success(
        ctx,
        talosctl,
        _talosctl_args(ctx, args),
        cwd = ws_path(ctx),
        label = label,
        auth_hint = "talos",
    )

def _contains(items, needle):
    for item in items:
        if item == needle:
            return True
    return False

def _unique_non_empty_lines(value):
    out = []
    for line in value.split("\n"):
        item = line.strip()
        if item == "":
            continue
        if not _contains(out, item):
            out.append(item)
    return out

def _first_csv_value(value):
    for item in value.split(","):
        item = item.strip()
        if item != "":
            return item
    return value.strip()

def _expected_revision(ctx):
    if ctx.args.revision == "":
        ctx.std.io.stderr.write("ERROR: --revision is required; pass the merged main commit SHA that source-controller must have applied\n")
        return None
    return ctx.args.revision

def _line_count(s):
    count = 0
    for line in s.split("\n"):
        if line.strip() != "":
            count = count + 1
    return count

def _assert_contains(ctx, value, needle, label):
    if value.find(needle) == -1:
        ctx.std.io.stderr.write("ERROR: " + label + " = " + value + "; expected it to contain " + needle + "\n")
        return 1
    return 0

def _assert_equals(ctx, value, expected, label):
    if value != expected:
        ctx.std.io.stderr.write("ERROR: " + label + " = " + value + "; expected " + expected + "\n")
        return 1
    return 0

def _check_live_context(ctx, kubectl):
    return _check_live_context_for(ctx, kubectl, ctx.args.kubeconfig)

def _check_live_context_for(ctx, kubectl, kubeconfig):
    server = _kubectl_capture_for(ctx, kubectl, kubeconfig, ["config", "view", "--minify", "--output=jsonpath={.clusters[0].cluster.server}"], "kubectl current cluster server")
    if server == None:
        return 1
    if _contains(EXCLUDED_KUBE_APIS, server):
        ctx.std.io.stderr.write("ERROR: refusing to validate against excluded cluster API " + server + "\n")
        return 1
    if not _contains(EXPECTED_KUBE_APIS, server):
        ctx.std.io.stderr.write("ERROR: kubeconfig points at " + server + "; expected guardian-mgmt API endpoint from src/infrastructure/bootstrap/guardian-mgmt/main.tf\n")
        return 1

    nodes = _kubectl_capture_for(ctx, kubectl, kubeconfig, ["get", "nodes", "-o", "name"], "kubectl get nodes")
    if nodes == None:
        return 1
    if _line_count(nodes) != 3:
        ctx.std.io.stderr.write("ERROR: guardian-mgmt should have exactly 3 nodes; kubectl reported:\n" + nodes + "\n")
        return 1

    node_details = _kubectl_capture_for(ctx, kubectl, kubeconfig, ["get", "nodes", "-o", "wide"], "kubectl get nodes -o wide")
    if node_details == None:
        return 1
    return _assert_contains(ctx, node_details, "10.8.0.", "node InternalIP addresses")

def _check_flux_revision(ctx, kubectl, revision):
    return _check_flux_revision_for(ctx, kubectl, ctx.args.kubeconfig, revision)

def _check_flux_revision_for(ctx, kubectl, kubeconfig, revision):
    checks = [
        ("guardian GitRepository artifact revision", ["-n", "cozy-fluxcd", "get", "gitrepositories.source.toolkit.fluxcd.io/guardian", "-o", "jsonpath={.status.artifact.revision}"]),
        ("guardian-mgmt-base last applied revision", ["-n", "cozy-fluxcd", "get", "kustomizations.kustomize.toolkit.fluxcd.io/guardian-mgmt-base", "-o", "jsonpath={.status.lastAppliedRevision}"]),
        ("guardian-mgmt-tenant-apps last applied revision", ["-n", "cozy-fluxcd", "get", "kustomizations.kustomize.toolkit.fluxcd.io/guardian-mgmt-tenant-apps", "-o", "jsonpath={.status.lastAppliedRevision}"]),
        ("guardian-mgmt-platform-tenant last applied revision", ["-n", "cozy-fluxcd", "get", "kustomizations.kustomize.toolkit.fluxcd.io/guardian-mgmt-platform-tenant", "-o", "jsonpath={.status.lastAppliedRevision}"]),
        ("guardian-mgmt-platform-dev-tenant last applied revision", ["-n", "cozy-fluxcd", "get", "kustomizations.kustomize.toolkit.fluxcd.io/guardian-mgmt-platform-dev-tenant", "-o", "jsonpath={.status.lastAppliedRevision}"]),
        ("guardian-mgmt-platform-dev last applied revision", ["-n", "cozy-fluxcd", "get", "kustomizations.kustomize.toolkit.fluxcd.io/guardian-mgmt-platform-dev", "-o", "jsonpath={.status.lastAppliedRevision}"]),
        ("guardian-mgmt-platform-gamma-tenant last applied revision", ["-n", "cozy-fluxcd", "get", "kustomizations.kustomize.toolkit.fluxcd.io/guardian-mgmt-platform-gamma-tenant", "-o", "jsonpath={.status.lastAppliedRevision}"]),
        ("guardian-mgmt-platform-gamma last applied revision", ["-n", "cozy-fluxcd", "get", "kustomizations.kustomize.toolkit.fluxcd.io/guardian-mgmt-platform-gamma", "-o", "jsonpath={.status.lastAppliedRevision}"]),
        ("guardian-mgmt-platform-prod-tenant last applied revision", ["-n", "cozy-fluxcd", "get", "kustomizations.kustomize.toolkit.fluxcd.io/guardian-mgmt-platform-prod-tenant", "-o", "jsonpath={.status.lastAppliedRevision}"]),
        ("guardian-mgmt-platform-prod last applied revision", ["-n", "cozy-fluxcd", "get", "kustomizations.kustomize.toolkit.fluxcd.io/guardian-mgmt-platform-prod", "-o", "jsonpath={.status.lastAppliedRevision}"]),
    ]
    for label, kubectl_args in checks:
        value = _kubectl_capture_for(ctx, kubectl, kubeconfig, kubectl_args, "kubectl read " + label)
        if value == None:
            return 1
        rc = _assert_contains(ctx, value, revision, label)
        if rc != 0:
            return rc
    return 0

def _check_company_site_spread(ctx, kubectl):
    return _check_company_site_spread_for(ctx, kubectl, ctx.args.kubeconfig)

def _check_company_site_spread_for(ctx, kubectl, kubeconfig):
    for label, namespace, stage in LIVE_COMPANY_SITE_SPREADS:
        node_names = _kubectl_capture_for(
            ctx,
            kubectl,
            kubeconfig,
            [
                "-n",
                namespace,
                "get",
                "pods",
                "-l",
                "app.kubernetes.io/name=company-site,guardian.dev/stage=" + stage,
                "-o",
                "jsonpath={range .items[*]}{.spec.nodeName}{\"\\n\"}{end}",
            ],
            "kubectl read " + label,
        )
        if node_names == None:
            return 1
        unique_nodes = _unique_non_empty_lines(node_names)
        if len(unique_nodes) != 3:
            ctx.std.io.stderr.write(
                "ERROR: "
                + label
                + " is scheduled on "
                + str(len(unique_nodes))
                + " unique nodes, expected 3; nodes:\n"
                + node_names
                + "\n",
            )
            return 1
    return 0

def _render_kustomizations(ctx):
    kubectl = _kubectl_path(ctx)
    if kubectl == None:
        return 1
    for path in [
        "src/infrastructure/base",
        "src/infrastructure/tenants/guardian-commercial",
        "src/infrastructure/tenants/platform",
        "src/infrastructure/tenants/platform/dev",
        "src/infrastructure/tenants/platform/gamma",
        "src/infrastructure/tenants/platform/prod",
        "src/infrastructure/products/platform/dev",
        "src/infrastructure/products/platform/gamma",
        "src/infrastructure/products/platform/prod",
    ]:
        rc = _capture_success(
            ctx,
            kubectl,
            ["kustomize", path],
            cwd = ws_path(ctx),
            label = "kubectl kustomize " + path,
        )
        if rc != 0:
            return rc
    return 0

def _check_source_hygiene(ctx):
    failed = False
    for rel, reason in FORBIDDEN_SOURCE_PATHS:
        path = ws_path(ctx, rel)
        if ctx.std.fs.exists(path):
            ctx.std.io.stderr.write("ERROR: remove " + rel + ": " + reason + "\n")
            failed = True
    if failed:
        return 1
    return 0

def _validate_impl(ctx):
    rc = _check_source_hygiene(ctx)
    if rc != 0:
        return rc

    for root, label in [
        (GUARDIAN_MGMT_ROOT, "guardian-mgmt"),
        (GUARDIAN_MGMT_OPENBAO_ROOT, "guardian-mgmt-openbao"),
        (GUARDIAN_MGMT_DNS_ROOT, "guardian-mgmt-dns"),
    ]:
        rc = _tofu_root(ctx, root, ["fmt", "-check"], "tofu fmt -check " + label)
        if rc != 0:
            return rc
        rc = _tofu_root(ctx, root, ["init", "-backend=false", "-input=false", "-reconfigure"], "tofu init -backend=false " + label)
        if rc != 0:
            return rc
        rc = _tofu_root(ctx, root, ["validate"], "tofu validate " + label)
        if rc != 0:
            return rc
    rc = checked_spawn(
        ctx,
        "bazelisk",
        ["build"] + INFRA_FILEGROUPS,
        cwd = ws_path(ctx),
        label = "bazelisk build infra filegroups",
    )
    if rc != 0:
        return rc
    rc = checked_spawn(
        ctx,
        "bazelisk",
        ["test"] + INFRA_TESTS,
        cwd = ws_path(ctx),
        label = "bazelisk test infra invariants",
    )
    if rc != 0:
        return rc
    return _render_kustomizations(ctx)

def _topology_impl(ctx):
    tofu_args = ["output", "-json"]
    if ctx.args.name != "":
        tofu_args.append(ctx.args.name)
    return _tofu_root(
        ctx,
        GUARDIAN_MGMT_ROOT,
        tofu_args,
        "tofu output -json guardian-mgmt",
    )

def _tofu_init_impl(ctx):
    endpoint = _tofu_backend_endpoint(ctx, ctx.args.endpoint)
    if endpoint == None:
        return 1
    roots = _tofu_backend_roots(ctx, ctx.args.root)
    if roots == None:
        return 1
    return _tofu_backend_init(ctx, roots, endpoint)

def _dns_apply_impl(ctx):
    if ctx.args.mode not in ["plan", "apply"]:
        ctx.std.io.stderr.write("ERROR: --mode must be plan or apply\n")
        return 1

    endpoint = _tofu_backend_endpoint(ctx, ctx.args.endpoint)
    if endpoint == None:
        return 1
    rc = _tofu_backend_init(ctx, [(GUARDIAN_MGMT_DNS_ROOT, "guardian-mgmt-dns")], endpoint)
    if rc != 0:
        return rc

    tofu_args = [
        ctx.args.mode,
        "-input=false",
        "-var-file=" + ws_path(ctx, GUARDIAN_BACKEND_TFVARS),
    ]
    if ctx.args.mode == "apply":
        tofu_args.append("-auto-approve")

    return _tofu_root(
        ctx,
        GUARDIAN_MGMT_DNS_ROOT,
        tofu_args,
        "tofu " + ctx.args.mode + " guardian-mgmt-dns",
    )

def _require_talm_operator_state(ctx, root):
    missing = []
    for filename in [
        "secrets.yaml",
        "talm.key",
        "talosconfig.encrypted",
    ]:
        path = root + "/" + filename
        if not ctx.std.fs.exists(path):
            missing.append(path)
    if len(missing) != 0:
        ctx.std.io.stderr.write(
            "ERROR: current Talm operator state is required before refreshing guardian-mgmt kubeconfig; restore missing files: "
            + ", ".join(missing)
            + ". Refusing to generate new local key material.\n",
        )
        return 1
    return 0

def _kubeconfig_impl(ctx):
    root = ws_path(ctx, ctx.args.root)
    talosconfig = ctx.args.talosconfig
    if talosconfig == "":
        talosconfig = root + "/talosconfig"

    rc = _require_talm_operator_state(ctx, root)
    if rc != 0:
        return rc

    rc = checked_spawn(
        ctx,
        "bazelisk",
        [
            "run",
            TALM_TARGET,
            "--",
            "talosconfig",
            "--root",
            root,
            "--talosconfig",
            talosconfig,
        ],
        cwd = root,
        label = "talm talosconfig guardian-mgmt",
    )
    if rc != 0:
        return rc

    rc = checked_spawn(
        ctx,
        "bazelisk",
        [
            "run",
            TALM_TARGET,
            "--",
            "kubeconfig",
            "--root",
            root,
            "--talosconfig",
            talosconfig,
            "--nodes",
            _first_csv_value(ctx.args.nodes),
            "--endpoints",
            ctx.args.endpoints,
            "--merge=false",
            "--force",
        ],
        cwd = root,
        label = "talm kubeconfig guardian-mgmt",
    )
    if rc != 0:
        return rc

    ctx.std.io.stderr.write("wrote guardian-mgmt kubeconfig to " + root + "/kubeconfig\n")
    return 0

def _talos_impl(ctx):
    talosctl = _talosctl_path(ctx)
    if talosctl == None:
        return 1

    addresses = _talosctl_capture(
        ctx,
        talosctl,
        ["get", "addresses"],
        "talosctl get addresses",
    )
    if addresses == None:
        return 1
    for node in GUARDIAN_MGMT_TALOS_NODES:
        rc = _assert_contains(ctx, addresses, node, "talos addresses")
        if rc != 0:
            return rc

    rc = _talosctl_success(
        ctx,
        talosctl,
        ["get", "routes"],
        "talosctl get routes",
    )
    if rc != 0:
        return rc

    kubespan = _talosctl_capture(
        ctx,
        talosctl,
        ["get", "kubespanpeerstatuses", "-o", "jsonpath={.items}"],
        "talosctl get kubespanpeerstatuses",
    )
    if kubespan == None:
        return 1
    rc = _assert_equals(ctx, kubespan, "[]", "kubespan peer statuses")
    if rc != 0:
        return rc

    ctx.std.io.stderr.write("guardian-mgmt Talos L2 checks passed\n")
    return 0

def _live_impl(ctx):
    revision = _expected_revision(ctx)
    if revision == None:
        return 1
    kubectl = _kubectl_path(ctx)
    if kubectl == None:
        return 1
    return _live_checks(ctx, kubectl, ctx.args.kubeconfig, revision)

def _live_checks(ctx, kubectl, kubeconfig, revision):
    rc = _check_live_context_for(ctx, kubectl, kubeconfig)
    if rc != 0:
        return rc

    for label, kubectl_args in LIVE_FLUX_WAITS:
        rc = _kubectl_success_for(
            ctx,
            kubectl,
            kubeconfig,
            kubectl_args + ["--timeout=" + ctx.args.wait_timeout],
            "kubectl wait " + label,
        )
        if rc != 0:
            return rc

    rc = _check_flux_revision_for(ctx, kubectl, kubeconfig, revision)
    if rc != 0:
        return rc

    for label, kubectl_args in LIVE_WAITS:
        rc = _kubectl_success_for(
            ctx,
            kubectl,
            kubeconfig,
            kubectl_args + ["--timeout=" + ctx.args.wait_timeout],
            "kubectl wait " + label,
        )
        if rc != 0:
            return rc

    for label, kubectl_args in LIVE_GETS:
        rc = _kubectl_success_for(ctx, kubectl, kubeconfig, kubectl_args, "kubectl get " + label)
        if rc != 0:
            return rc

    for label, kubectl_args, expected in LIVE_VALUE_CHECKS:
        value = _kubectl_capture_for(ctx, kubectl, kubeconfig, kubectl_args, "kubectl read " + label)
        if value == None:
            return 1
        rc = _assert_equals(ctx, value, expected, label)
        if rc != 0:
            return rc

    rc = _check_company_site_spread_for(ctx, kubectl, kubeconfig)
    if rc != 0:
        return rc

    ctx.std.io.stderr.write("guardian-mgmt source-controller has reconciled " + revision + "\n")
    return 0

def _bootstrap_impl(ctx):
    revision = _expected_revision(ctx)
    if revision == None:
        return 1

    endpoint = _tofu_backend_endpoint(ctx, ctx.args.tofu_backend_endpoint)
    if endpoint == None:
        return 1
    rc = _tofu_backend_init(ctx, [(GUARDIAN_MGMT_ROOT, "guardian-mgmt")], endpoint)
    if rc != 0:
        return rc

    rc = _tofu_root(
        ctx,
        GUARDIAN_MGMT_ROOT,
        ["output", "-json"],
        "tofu output -json guardian-mgmt",
    )
    if rc != 0:
        return rc

    rc = _validate_impl(ctx)
    if rc != 0:
        return rc

    rc = _kubeconfig_impl(ctx)
    if rc != 0:
        return rc

    rc = _talos_impl(ctx)
    if rc != 0:
        return rc

    kubectl = _kubectl_path(ctx)
    if kubectl == None:
        return 1

    live_kubeconfig = ctx.args.kubeconfig
    if live_kubeconfig == "":
        live_kubeconfig = ws_path(ctx, ctx.args.root) + "/kubeconfig"
    return _live_checks(ctx, kubectl, live_kubeconfig, revision)

def _backup_drill_impl(ctx):
    kubectl = _kubectl_path(ctx)
    if kubectl == None:
        return 1

    rc = _check_live_context(ctx, kubectl)
    if rc != 0:
        return rc
    if ctx.args.revision != "":
        rc = _check_flux_revision(ctx, kubectl, ctx.args.revision)
        if rc != 0:
            return rc

    if ctx.args.allow_in_place_restore != "" and ctx.args.allow_in_place_restore != "true" and ctx.args.allow_in_place_restore != "false":
        ctx.std.io.stderr.write("ERROR: --allow-in-place-restore must be true or false\n")
        return 1
    if ctx.args.create_restore_target != "" and ctx.args.create_restore_target != "true" and ctx.args.create_restore_target != "false":
        ctx.std.io.stderr.write("ERROR: --create-restore-target must be true or false\n")
        return 1
    if ctx.args.cleanup_created_restore_target != "" and ctx.args.cleanup_created_restore_target != "true" and ctx.args.cleanup_created_restore_target != "false":
        ctx.std.io.stderr.write("ERROR: --cleanup-created-restore-target must be true or false\n")
        return 1

    drill_args = [
        "--kubectl",
        kubectl,
        "--stage",
        ctx.args.stage,
        "--component",
        ctx.args.component,
        "--application",
        ctx.args.application,
        "--request-timeout",
        ctx.args.request_timeout,
        "--wait-timeout",
        ctx.args.wait_timeout,
    ]
    if ctx.args.kubeconfig != "":
        drill_args.extend(["--kubeconfig", _kubeconfig_path(ctx)])
    if ctx.args.name != "":
        drill_args.extend(["--name", ctx.args.name])
    if ctx.args.restore_target != "":
        drill_args.extend(["--restore-target", ctx.args.restore_target])
    if ctx.args.allow_in_place_restore == "true":
        drill_args.append("--allow-in-place-restore=true")
    if ctx.args.create_restore_target == "true":
        drill_args.append("--create-restore-target=true")
    if ctx.args.cleanup_created_restore_target == "false":
        drill_args.append("--cleanup-created-restore-target=false")

    return checked_spawn(
        ctx,
        "bazelisk",
        ["run", BACKUP_DRILL_TARGET, "--"] + drill_args,
        cwd = ws_path(ctx),
        label = "cozystack backup drill",
    )

def _node_outage_drill_impl(ctx):
    if ctx.args.node == "":
        ctx.std.io.stderr.write("ERROR: --node is required\n")
        return 1
    if ctx.args.confirm_node != ctx.args.node:
        ctx.std.io.stderr.write("ERROR: --confirm-node must exactly match --node before running this disruptive drill\n")
        return 1

    kubectl = _kubectl_path(ctx)
    if kubectl == None:
        return 1

    rc = _check_live_context(ctx, kubectl)
    if rc != 0:
        return rc
    if ctx.args.revision != "":
        rc = _check_flux_revision(ctx, kubectl, ctx.args.revision)
        if rc != 0:
            return rc

    drill_args = [
        "--kubectl",
        kubectl,
        "--node",
        ctx.args.node,
        "--confirm-node",
        ctx.args.confirm_node,
        "--request-timeout",
        ctx.args.request_timeout,
        "--drain-timeout",
        ctx.args.drain_timeout,
        "--wait-timeout",
        ctx.args.wait_timeout,
    ]
    if ctx.args.kubeconfig != "":
        drill_args.extend(["--kubeconfig", _kubeconfig_path(ctx)])

    return checked_spawn(
        ctx,
        "bazelisk",
        ["run", NODE_OUTAGE_DRILL_TARGET, "--"] + drill_args,
        cwd = ws_path(ctx),
        label = "cozystack node outage drill",
    )

def _load_http_impl(ctx):
    if ctx.args.require_live != "true" and ctx.args.require_live != "false":
        ctx.std.io.stderr.write("ERROR: --require-live must be true or false\n")
        return 1

    k6 = _k6_path(ctx)
    if k6 == None:
        return 1

    kubectl = _kubectl_path(ctx)
    if kubectl == None:
        return 1

    if ctx.args.require_live == "true":
        rc = _check_live_context(ctx, kubectl)
        if rc != 0:
            return rc
        if ctx.args.revision != "":
            rc = _check_flux_revision(ctx, kubectl, ctx.args.revision)
            if rc != 0:
                return rc

    load_args = [
        "--k6",
        k6,
        "--script",
        ws_path(ctx, "src/infrastructure/load/http-smoke.js"),
        "--kubectl",
        kubectl,
        "--stage",
        ctx.args.stage,
        "--surface",
        ctx.args.surface,
        "--request-timeout",
        ctx.args.request_timeout,
        "--wait-timeout",
        ctx.args.wait_timeout,
        "--vus",
        ctx.args.vus,
        "--duration",
        ctx.args.duration,
        "--http-failed-threshold",
        ctx.args.http_failed_threshold,
        "--sleep-seconds",
        ctx.args.sleep_seconds,
        "--port-forward-ready-timeout",
        ctx.args.port_forward_ready_timeout,
    ]
    if ctx.args.kubeconfig != "":
        load_args.extend(["--kubeconfig", _kubeconfig_path(ctx)])
    if ctx.args.url != "":
        load_args.extend(["--url", ctx.args.url])
    if ctx.args.expected_statuses != "":
        load_args.extend(["--expected-statuses", ctx.args.expected_statuses])
    if ctx.args.host_overrides != "":
        load_args.extend(["--host-overrides", ctx.args.host_overrides])

    return checked_spawn(
        ctx,
        "bazelisk",
        ["run", HTTP_LOAD_TARGET, "--"] + load_args,
        cwd = ws_path(ctx),
        label = "cozystack http load",
    )

