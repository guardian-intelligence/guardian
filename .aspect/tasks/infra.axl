)

edge_failover_drill = task(
    implementation = _edge_failover_drill_impl,
    name = "edge-failover-drill",
    group = ["infra"],
    summary = "Reboot one guardian-mgmt node while k6 measures Cloudflare LB public-edge failover.",
    args = {
        "confirm_node_ip": args.string(default = "", description = "Must exactly match --node-ip before the task reboots a Talos node."),
        "cooldown": args.string(default = "20s", description = "Time to keep sampling after Kubernetes node recovery."),
        "duration": args.string(default = "5m", description = "k6 probe duration for this node drill."),
        "expected_statuses": args.string(default = "200,302", description = "Comma-separated acceptable public edge HTTP status codes."),
        "kube_api_server": args.string(default = "", description = "Optional Kubernetes API server to use while the target node reboots."),
        "kube_timeout": args.string(default = "10m", description = "Timeout for Kubernetes node NotReady/Ready transitions."),
        "kubeconfig": args.string(default = "", description = "Kubeconfig for guardian-mgmt. Defaults to KUBECONFIG/current context."),
        "k6_dns": args.string(default = "ttl=0,select=random,policy=preferIPv6", description = "k6 DNS resolver policy for the public edge probe."),
        "node_ip": args.string(default = "", description = "Talos node IP/address to reboot."),
        "node_name": args.string(default = "", description = "Kubernetes node name to watch during this drill."),
        "report": args.string(default = "reports/infrastructure/edge-failover-report.json", description = "JSON outage report path."),
        "request_timeout": args.string(default = "5s", description = "Per-request public edge timeout."),
        "revision": args.string(default = "", description = "Optional expected Flux-reconciled commit SHA to check before the drill."),
        "root": args.string(default = "src/infrastructure/clusters/ash/bootstrap/talm", description = "Talm root containing gitignored talosconfig."),
        "sample_interval_ms": args.string(default = "250", description = "k6 sample interval in milliseconds."),
        "talos_endpoint": args.string(default = "206.223.228.101,45.250.254.119,206.223.228.87", description = "Comma-separated Talos API endpoints for guardian-mgmt."),
        "talosconfig": args.string(default = "", description = "Optional talosconfig path. Defaults to <root>/talosconfig."),
        "url": args.string(default = "https://dashboard.guardianintelligence.org/", description = "Public edge URL to probe during failover."),
        "warmup": args.string(default = "10s", description = "Time to collect baseline samples before each reboot."),
    },
)

