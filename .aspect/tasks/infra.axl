def _clickhouse_child_checks(stage, namespace):
    release = "clickhouse-guardian"
    return [
        (stage + " clickhouse shards", ["-n", namespace, "get", "clickhouseinstallations.clickhouse.altinity.com/" + release, "-o", "jsonpath={.spec.configuration.clusters[0].layout.shardsCount}"], "1"),
        (stage + " clickhouse replicas", ["-n", namespace, "get", "clickhouseinstallations.clickhouse.altinity.com/" + release, "-o", "jsonpath={.spec.configuration.clusters[0].layout.replicasCount}"], "3"),
        (stage + " clickhouse backup sidecar", ["-n", namespace, "get", "clickhouseinstallations.clickhouse.altinity.com/" + release, "-o", "jsonpath={.spec.templates.podTemplates[0].spec.containers[1].name}"], "clickhouse-backup"),
        (stage + " clickhouse backup api port", ["-n", namespace, "get", "clickhouseinstallations.clickhouse.altinity.com/" + release, "-o", "jsonpath={.spec.templates.podTemplates[0].spec.containers[1].ports[0].name}"], "ch-backup-api"),
        (stage + " clickhouse keeper replicas", ["-n", namespace, "get", "clickhousekeeperinstallations.clickhouse-keeper.altinity.com/" + release + "-keeper", "-o", "jsonpath={.spec.configuration.clusters[0].layout.replicasCount}"], "3"),
        (stage + " clickhouse workload monitor replicas", ["-n", namespace, "get", "workloadmonitors.cozystack.io/" + release, "-o", "jsonpath={.spec.replicas}"], "3"),
        (stage + " clickhouse workload monitor kind", ["-n", namespace, "get", "workloadmonitors.cozystack.io/" + release, "-o", "jsonpath={.spec.kind}"], "clickhouse"),
        (stage + " clickhouse keeper workload monitor replicas", ["-n", namespace, "get", "workloadmonitors.cozystack.io/" + release + "-keeper", "-o", "jsonpath={.spec.replicas}"], "3"),
        (stage + " clickhouse keeper workload monitor kind", ["-n", namespace, "get", "workloadmonitors.cozystack.io/" + release + "-keeper", "-o", "jsonpath={.spec.kind}"], "clickhouse"),
    ]

def _monitoring_gets(stage, namespace):
    return [
        (stage + " monitoring", ["-n", namespace, "get", "monitorings.apps.cozystack.io/monitoring"]),
    ]

def _monitoring_waits(stage, namespace):
    return [
        (stage + " monitoring app", ["-n", namespace, "wait", "--for=condition=Ready", "monitorings.apps.cozystack.io/monitoring"]),
        (stage + " monitoring workloads", ["-n", namespace, "wait", "--for=condition=WorkloadsReady", "monitorings.apps.cozystack.io/monitoring"]),
    ]

def _monitoring_checks(stage, namespace, host, shortterm_storage, longterm_storage, log_retention, log_storage):
    return [
        (stage + " monitoring host", ["-n", namespace, "get", "monitorings.apps.cozystack.io/monitoring", "-o", "jsonpath={.spec.host}"], host),
        (stage + " monitoring shortterm storage", ["-n", namespace, "get", "monitorings.apps.cozystack.io/monitoring", "-o", "jsonpath={.spec.metricsStorages[0].storage}"], shortterm_storage),
        (stage + " monitoring shortterm storage class", ["-n", namespace, "get", "monitorings.apps.cozystack.io/monitoring", "-o", "jsonpath={.spec.metricsStorages[0].storageClassName}"], "replicated"),
        (stage + " monitoring longterm storage", ["-n", namespace, "get", "monitorings.apps.cozystack.io/monitoring", "-o", "jsonpath={.spec.metricsStorages[1].storage}"], longterm_storage),
        (stage + " monitoring longterm storage class", ["-n", namespace, "get", "monitorings.apps.cozystack.io/monitoring", "-o", "jsonpath={.spec.metricsStorages[1].storageClassName}"], "replicated"),
        (stage + " monitoring logs retention", ["-n", namespace, "get", "monitorings.apps.cozystack.io/monitoring", "-o", "jsonpath={.spec.logsStorages[0].retentionPeriod}"], log_retention),
        (stage + " monitoring logs storage", ["-n", namespace, "get", "monitorings.apps.cozystack.io/monitoring", "-o", "jsonpath={.spec.logsStorages[0].storage}"], log_storage),
        (stage + " monitoring logs storage class", ["-n", namespace, "get", "monitorings.apps.cozystack.io/monitoring", "-o", "jsonpath={.spec.logsStorages[0].storageClassName}"], "replicated"),
        (stage + " monitoring vmagent cluster label", ["-n", namespace, "get", "monitorings.apps.cozystack.io/monitoring", "-o", "jsonpath={.spec.vmagent.externalLabels.cluster}"], "guardian-mgmt"),
    ]

