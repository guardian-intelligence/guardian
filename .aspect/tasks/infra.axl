    if rc != 0:
        return rc
    return checked_spawn(
        ctx,
        ws_path(ctx, DB_BACKUP_SECRET_BIN),
        _kubectl_live_flags(ctx),
        cwd = ws_path(ctx),
        env = {"KUBECTL_BIN": ws_path(ctx, KUBECTL_RUNNER)},
        label = "seed tenant-root/guardian-r2-db-backups",
    )

