def _capture_stdout(ctx, program, args, cwd = None, label = None, auth_hint = "kubernetes"):
    label_str = label if label != None else program
    cmd = ctx.std.process.command(program).args(args)
    if cwd != None:
        cmd = cmd.current_dir(cwd)
    if ctx.std.io.stderr.is_tty:
        ctx.std.io.stderr.write("$ " + label_str + "\n")
    r = cmd.stdout("piped").stderr("piped").spawn().wait_with_output()
    if r.status.code != 0:
        ctx.std.io.stderr.write("ERROR: " + label_str + " failed\n")
        if r.stdout != "":
            ctx.std.io.stderr.write(r.stdout)
        if r.stderr != "":
            ctx.std.io.stderr.write(r.stderr)
            _write_auth_hint(ctx, r.stderr, auth_hint)
        return None
    return r.stdout.strip()

def _capture_success(ctx, program, args, cwd = None, label = None, auth_hint = "kubernetes"):
    label_str = label if label != None else program
    cmd = ctx.std.process.command(program).args(args)
    if cwd != None:
        cmd = cmd.current_dir(cwd)
    if ctx.std.io.stderr.is_tty:
        ctx.std.io.stderr.write("$ " + label_str + "\n")
    r = cmd.stdout("piped").stderr("piped").spawn().wait_with_output()
    if r.status.code != 0:
        ctx.std.io.stderr.write("ERROR: " + label_str + " failed\n")
        if r.stdout != "":
            ctx.std.io.stderr.write(r.stdout)
        if r.stderr != "":
            ctx.std.io.stderr.write(r.stderr)
            _write_auth_hint(ctx, r.stderr, auth_hint)
        return 1
    return 0

def _write_auth_hint(ctx, stderr, auth_hint):
    if stderr.find("tls: failed to verify certificate") == -1:
        return
    if stderr.find("x509:") == -1:
        return
    if auth_hint == "talos":
        ctx.std.io.stderr.write(
            "ERROR: Talos rejected the local talosconfig credentials. Refresh "
            + "the guardian-mgmt Talos operator state from the current cluster "
            + "before running Talos L2 validation; do not use insecure TLS flags "
            + "for management-plane validation.\n",
        )
        return
    ctx.std.io.stderr.write(
        "ERROR: Kubernetes rejected the local cluster credentials. Refresh the "
        + "guardian-mgmt kubeconfig/Talos operator state from the current cluster "
        + "with `aspect infra kubeconfig` when the local Talm state is current; "
        + "do not use insecure TLS flags for management-cluster debugging.\n",
    )

def _tofu_root(ctx, root, args, label, env = None):
    return checked_spawn(
        ctx,
        "bazelisk",
        ["run", TOFU_TARGET, "--", "-chdir=" + ws_path(ctx, root)] + args,
        cwd = ws_path(ctx),
        env = env,
        label = label,
    )

def _tofu_validate_env(ctx, label):
    return {
        "AWS_EC2_METADATA_DISABLED": "true",
        "TF_DATA_DIR": ws_path(ctx, ".terraform/validate/" + label),
    }

def _cloudflare_account_id(ctx):
    path = ws_path(ctx, GUARDIAN_BACKEND_TFVARS)
    if not ctx.std.fs.exists(path):
        ctx.std.io.stderr.write("ERROR: missing " + GUARDIAN_BACKEND_TFVARS + "\n")
        return None

    for line in ctx.std.fs.read_to_string(path).split("\n"):
        item = line.strip()
        if item == "" or item.startswith("#"):
            continue
        parts = item.split("=", 1)
        if len(parts) != 2:
            continue
        if parts[0].strip() != "cloudflare_account_id":
            continue
        account_id = parts[1].strip()
        if account_id.startswith("\"") and account_id.endswith("\""):
            account_id = account_id[1:len(account_id) - 1]
        if account_id == "":
            ctx.std.io.stderr.write("ERROR: cloudflare_account_id is empty in " + GUARDIAN_BACKEND_TFVARS + "\n")
            return None
        return account_id

    ctx.std.io.stderr.write("ERROR: cloudflare_account_id is missing in " + GUARDIAN_BACKEND_TFVARS + "\n")
    return None

def _tofu_backend_endpoint(ctx, value):
    endpoint = value
    if endpoint == "":
        endpoint = ctx.std.env.var("AWS_ENDPOINT_URL_S3") or ""
    if endpoint != "":
        return endpoint

    account_id = _cloudflare_account_id(ctx)
    if account_id == None:
        return None
    return "https://" + account_id + ".r2.cloudflarestorage.com"

def _tofu_backend_roots(ctx, root):
    if root == "all":
        return [
            (GUARDIAN_MGMT_ROOT, "guardian-mgmt"),
            (GUARDIAN_MGMT_DNS_ROOT, "guardian-mgmt-dns"),
        ]
    if root == "guardian-mgmt":
        return [(GUARDIAN_MGMT_ROOT, "guardian-mgmt")]
    if root == "guardian-mgmt-dns":
        return [(GUARDIAN_MGMT_DNS_ROOT, "guardian-mgmt-dns")]
    ctx.std.io.stderr.write("ERROR: --root must be all, guardian-mgmt, or guardian-mgmt-dns\n")
    return None

def _tofu_backend_init(ctx, roots, endpoint):
    for root, label in roots:
        args = [
            "init",
            "-input=false",
            "-reconfigure",
            "-backend-config=endpoint=" + endpoint,
        ]
        rc = _tofu_root(
            ctx,
            root,
            args,
            "tofu init backend " + label,
        )
        if rc != 0:
            return rc
    return 0

def _tool_path(ctx, target):
    path = bazel_output_file(ctx, target)
    if path == "":
        return None
    return path

def _kubectl_path(ctx):
    return _tool_path(ctx, KUBECTL_TARGET)

def _kubectl_args(ctx, args):
    return _kubectl_args_for(ctx, ctx.args.kubeconfig, args)

def _kubectl_args_for(ctx, kubeconfig, args, kube_api_server = ""):
    out = []
    if kubeconfig != "":
        out.extend(["--kubeconfig", _workspace_path_if_relative(ctx, kubeconfig)])
    if kube_api_server != "":
        out.extend(["--server", kube_api_server])
    if ctx.args.request_timeout != "":
        out.append("--request-timeout=" + ctx.args.request_timeout)
    out.extend(args)
    return out

def _kubeconfig_path(ctx):
    return _workspace_path_if_relative(ctx, ctx.args.kubeconfig)

def _workspace_path_if_relative(ctx, path):
    if path == "" or path.startswith("/") or path.startswith("~"):
        return path
    return ws_path(ctx, path)

def _expand_operator_path(ctx, path):
    if path == "~":
        home = ctx.std.env.var("HOME") or ""
        if home == "":
            ctx.std.io.stderr.write("ERROR: HOME is not set; pass an absolute --install-path\n")
            return None
        return home
    if path.startswith("~/"):
        home = ctx.std.env.var("HOME") or ""
        if home == "":
            ctx.std.io.stderr.write("ERROR: HOME is not set; pass an absolute --install-path\n")
            return None
        return home + path[1:]
    return _workspace_path_if_relative(ctx, path)

def _talosconfig_path(ctx):
    if ctx.args.talosconfig != "":
        return _workspace_path_if_relative(ctx, ctx.args.talosconfig)
    return ws_path(ctx, ctx.args.root) + "/talosconfig"

def _talosctl_args(ctx, args):
    out = [
        "--talosconfig",
        _talosconfig_path(ctx),
        "--endpoints",
        ctx.args.endpoints,
        "--nodes",
        ctx.args.nodes,
    ]
    out.extend(args)
    return out

def _kubectl_capture(ctx, kubectl, args, label):
    return _kubectl_capture_for(ctx, kubectl, ctx.args.kubeconfig, args, label)

def _kubectl_capture_for(ctx, kubectl, kubeconfig, args, label, kube_api_server = ""):
    return _capture_stdout(
        ctx,
        kubectl,
        _kubectl_args_for(ctx, kubeconfig, args, kube_api_server),
        cwd = ws_path(ctx),
        label = label,
    )

def _talosctl_capture(ctx, talosctl, args, label):
    return _capture_stdout(
        ctx,
        talosctl,
        _talosctl_args(ctx, args),
        cwd = ws_path(ctx),
        label = label,
        auth_hint = "talos",
    )

def _talosctl_success(ctx, talosctl, args, label):
    return _capture_success(
        ctx,
        talosctl,
        _talosctl_args(ctx, args),
        cwd = ws_path(ctx),
        label = label,
        auth_hint = "talos",
    )

def _contains(items, needle):
    for item in items:
        if item == needle:
            return True
    return False

def _unique_non_empty_lines(value):
    out = []
    for line in value.split("\n"):
        item = line.strip()
        if item == "":
            continue
        if not _contains(out, item):
            out.append(item)
    return out

def _first_csv_value(value):
    for item in value.split(","):
        item = item.strip()
        if item != "":
            return item
    return value.strip()

def _line_count(s):
    count = 0
    for line in s.split("\n"):
        if line.strip() != "":
            count = count + 1
    return count

def _assert_contains(ctx, value, needle, label):
    if value.find(needle) == -1:
        ctx.std.io.stderr.write("ERROR: " + label + " = " + value + "; expected it to contain " + needle + "\n")
        return 1
    return 0

def _assert_equals(ctx, value, expected, label):
    if value != expected:
        ctx.std.io.stderr.write("ERROR: " + label + " = " + value + "; expected " + expected + "\n")
        return 1
    return 0

def _check_live_context(ctx, kubectl):
    return _check_live_context_for(ctx, kubectl, ctx.args.kubeconfig)

def _check_live_context_for(ctx, kubectl, kubeconfig, kube_api_server = ""):
    server = kube_api_server
    if server == "":
        server = _kubectl_capture_for(ctx, kubectl, kubeconfig, ["config", "view", "--minify", "--output=jsonpath={.clusters[0].cluster.server}"], "kubectl current cluster server")
        if server == None:
            return 1
    if _contains(EXCLUDED_KUBE_APIS, server):
        ctx.std.io.stderr.write("ERROR: refusing to validate against excluded cluster API " + server + "\n")
        return 1
    if not _contains(EXPECTED_KUBE_APIS, server):
        ctx.std.io.stderr.write("ERROR: kubeconfig points at " + server + "; expected guardian-mgmt API endpoint from src/infrastructure/bootstrap/guardian-mgmt/main.tf\n")
        return 1

    nodes = _kubectl_capture_for(ctx, kubectl, kubeconfig, ["get", "nodes", "-o", "name"], "kubectl get nodes", kube_api_server)
    if nodes == None:
        return 1
    if _line_count(nodes) != 3:
        ctx.std.io.stderr.write("ERROR: guardian-mgmt should have exactly 3 nodes; kubectl reported:\n" + nodes + "\n")
        return 1

    node_details = _kubectl_capture_for(ctx, kubectl, kubeconfig, ["get", "nodes", "-o", "wide"], "kubectl get nodes -o wide", kube_api_server)
    if node_details == None:
        return 1
    return _assert_contains(ctx, node_details, "10.8.0.", "node InternalIP addresses")

def _check_flux_revision(ctx, kubectl, revision):
    return _check_flux_revision_for(ctx, kubectl, ctx.args.kubeconfig, revision)

def _check_flux_revision_for(ctx, kubectl, kubeconfig, revision, kube_api_server = ""):
    checks = [
        ("guardian GitRepository artifact revision", ["-n", "cozy-fluxcd", "get", "gitrepositories.source.toolkit.fluxcd.io/guardian", "-o", "jsonpath={.status.artifact.revision}"]),
        ("guardian-mgmt-platform last applied revision", ["-n", "cozy-fluxcd", "get", "kustomizations.kustomize.toolkit.fluxcd.io/guardian-mgmt-platform", "-o", "jsonpath={.status.lastAppliedRevision}"]),
        ("guardian-mgmt-platform-patches last applied revision", ["-n", "cozy-fluxcd", "get", "kustomizations.kustomize.toolkit.fluxcd.io/guardian-mgmt-platform-patches", "-o", "jsonpath={.status.lastAppliedRevision}"]),
        ("guardian-mgmt-storage last applied revision", ["-n", "cozy-fluxcd", "get", "kustomizations.kustomize.toolkit.fluxcd.io/guardian-mgmt-storage", "-o", "jsonpath={.status.lastAppliedRevision}"]),
        ("guardian-mgmt-base last applied revision", ["-n", "cozy-fluxcd", "get", "kustomizations.kustomize.toolkit.fluxcd.io/guardian-mgmt-base", "-o", "jsonpath={.status.lastAppliedRevision}"]),
        ("guardian-mgmt-app-patches last applied revision", ["-n", "cozy-fluxcd", "get", "kustomizations.kustomize.toolkit.fluxcd.io/guardian-mgmt-app-patches", "-o", "jsonpath={.status.lastAppliedRevision}"]),
    ]
    for label, kubectl_args in checks:
        value = _kubectl_capture_for(ctx, kubectl, kubeconfig, kubectl_args, "kubectl read " + label, kube_api_server)
        if value == None:
            return 1
        rc = _assert_contains(ctx, value, revision, label)
        if rc != 0:
            return rc
    return 0

def _render_kustomizations(ctx):
    kubectl = _kubectl_path(ctx)
    if kubectl == None:
        return 1
    for path in [
        "src/infrastructure/base",
        "src/infrastructure/deployments/guardian/system",
    ]:
        rc = _capture_success(
            ctx,
            kubectl,
            ["kustomize", path],
            cwd = ws_path(ctx),
            label = "kubectl kustomize " + path,
        )
        if rc != 0:
            return rc
    return 0

def _check_source_hygiene(ctx):
    failed = False
    for rel, reason in FORBIDDEN_SOURCE_PATHS:
        path = ws_path(ctx, rel)
        if ctx.std.fs.exists(path):
            ctx.std.io.stderr.write("ERROR: remove " + rel + ": " + reason + "\n")
            failed = True
    if failed:
        return 1
    return 0

def _validate_impl(ctx):
    rc = _check_source_hygiene(ctx)
    if rc != 0:
        return rc

    for root, label in [
        (GUARDIAN_MGMT_ROOT, "guardian-mgmt"),
        (GUARDIAN_MGMT_DNS_ROOT, "guardian-mgmt-dns"),
    ]:
        tofu_env = _tofu_validate_env(ctx, label)
        rc = _tofu_root(ctx, root, ["fmt", "-check"], "tofu fmt -check " + label, env = tofu_env)
        if rc != 0:
            return rc
        rc = _tofu_root(ctx, root, ["init", "-backend=false", "-input=false", "-reconfigure"], "tofu init -backend=false " + label, env = tofu_env)
        if rc != 0:
            return rc
        rc = _tofu_root(ctx, root, ["validate"], "tofu validate " + label, env = tofu_env)
        if rc != 0:
            return rc
    rc = checked_spawn(
        ctx,
        "bazelisk",
        ["build"] + INFRA_FILEGROUPS,
        cwd = ws_path(ctx),
        label = "bazelisk build infra filegroups",
    )
    if rc != 0:
        return rc
    rc = checked_spawn(
        ctx,
        "bazelisk",
        ["test"] + INFRA_TESTS,
        cwd = ws_path(ctx),
        label = "bazelisk test infra invariants",
    )
    if rc != 0:
        return rc
    return _render_kustomizations(ctx)

def _topology_impl(ctx):
    tofu_args = ["output", "-json"]
    if ctx.args.name != "":
        tofu_args.append(ctx.args.name)
    return _tofu_root(
        ctx,
        GUARDIAN_MGMT_ROOT,
        tofu_args,
        "tofu output -json guardian-mgmt",
    )

def _tofu_init_impl(ctx):
    endpoint = _tofu_backend_endpoint(ctx, ctx.args.endpoint)
    if endpoint == None:
        return 1
    roots = _tofu_backend_roots(ctx, ctx.args.root)
    if roots == None:
        return 1
    return _tofu_backend_init(ctx, roots, endpoint)

def _require_talm_operator_state(ctx, root):
    missing = []
    for filename in [
        "secrets.yaml",
        "talm.key",
        "talosconfig.encrypted",
    ]:
        path = root + "/" + filename
        if not ctx.std.fs.exists(path):
            missing.append(path)
    if len(missing) != 0:
        ctx.std.io.stderr.write(
            "ERROR: current Talm operator state is required before refreshing guardian-mgmt kubeconfig; restore missing files: "
            + ", ".join(missing)
            + ". Refusing to generate new local key material.\n",
        )
        return 1
    return 0

def _kubeconfig_impl(ctx):
    kubeconfig = _mint_custody_kubeconfig(ctx)
    if kubeconfig == None:
        return 1
    if ctx.args.install:
        kubectl = _kubectl_path(ctx)
        if kubectl == None:
            return 1
        rc = _install_kubeconfig(ctx, kubectl, kubeconfig)
        # Installed into ~/.kube/config; the staged bundle-path copy (if any)
        # has served its purpose. Without --install the staged file IS the
        # deliverable, so leave it.
        _shred_staged_breakglass_kubeconfig(ctx)
        return rc
    return 0

CUSTODY_BUNDLE_DIR = "/dev/shm/guardian-custody"
CUSTODY_MINT_ROOT = "/dev/shm/guardian-talm-mint"

# When breakglass mints from the restored bundle, the kubeconfig is staged here
# (tmpfs, 0600) so it survives the mint-root shred long enough for the caller to
# install it; the caller shreds it immediately after. Never a durable artifact.
CUSTODY_BREAKGLASS_KUBECONFIG = "/dev/shm/guardian-breakglass.kubeconfig"

def _shred_staged_breakglass_kubeconfig(ctx):
    # No-op unless the bundle path staged one; the tree path returns a workspace
    # file we must not touch.
    if ctx.std.fs.exists(CUSTODY_BREAKGLASS_KUBECONFIG):
        checked_spawn(
            ctx,
            "sh",
            ["-c", "shred -u '" + CUSTODY_BREAKGLASS_KUBECONFIG + "' 2>/dev/null || rm -f '" + CUSTODY_BREAKGLASS_KUBECONFIG + "'"],
            label = "shred staged breakglass kubeconfig",
        )

def _assemble_mint_root(ctx, root):
    """Archive-only custody: build a tmpfs Talm root from the tracked chart
    plus the secrets in the restored custody bundle, so plaintext never
    touches the repo tree. Caller shreds CUSTODY_MINT_ROOT when done."""
    if not ctx.std.fs.exists(CUSTODY_BUNDLE_DIR + "/talm/secrets.yaml"):
        ctx.std.io.stderr.write(
            "ERROR: no plaintext Talm state in the tree and no restored custody bundle at "
            + CUSTODY_BUNDLE_DIR
            + "; run `aspect infra custody --action restore` first (and `--action wipe` after).\n",
        )
        return None
    rc = checked_spawn(
        ctx,
        "sh",
        [
            "-c",
            "rm -rf '" + CUSTODY_MINT_ROOT + "' && mkdir -m 700 '" + CUSTODY_MINT_ROOT +
            "' && cp -a '" + root + "/.' '" + CUSTODY_MINT_ROOT +
            "' && cp '" + CUSTODY_BUNDLE_DIR + "/talm/secrets.yaml' '" + CUSTODY_BUNDLE_DIR + "/talm/talm.key' '" + CUSTODY_BUNDLE_DIR + "/talm/talosconfig' '" + CUSTODY_MINT_ROOT + "/'",
        ],
        label = "assemble tmpfs talm mint root from custody bundle",
    )
    if rc != 0:
        return None
    return CUSTODY_MINT_ROOT

def _cleanup_mint_root(ctx):
    checked_spawn(
        ctx,
        "sh",
        ["-c", "if [ -d '" + CUSTODY_MINT_ROOT + "' ]; then find '" + CUSTODY_MINT_ROOT + "' -type f -exec shred -u {} + && rm -rf '" + CUSTODY_MINT_ROOT + "'; fi"],
        label = "shred tmpfs talm mint root",
    )

def _mint_custody_kubeconfig(ctx):
    root = _workspace_path_if_relative(ctx, ctx.args.root)
    talosconfig = _workspace_path_if_relative(ctx, ctx.args.talosconfig)
    if not ctx.std.fs.exists(root + "/secrets.yaml"):
        root = _assemble_mint_root(ctx, root)
        if root == None:
            return None
        if talosconfig == "":
            talosconfig = root + "/talosconfig"
        out = _mint_custody_kubeconfig_from(ctx, root, talosconfig)
        if out == None:
            _cleanup_mint_root(ctx)
            return None

        # The mint root (and the kubeconfig inside it) is about to be shredded,
        # but callers still need to consume the kubeconfig. Copy it out to a
        # stable tmpfs path first; the caller shreds it once installed. Without
        # this the bundle path returns a path to an already-deleted file and
        # `use-context admin@guardian-mgmt` fails (regression exposed once the
        # tree no longer holds secrets.yaml and this branch became the only one).
        rc = checked_spawn(
            ctx,
            "sh",
            ["-c", "umask 077 && cp '" + out + "' '" + CUSTODY_BREAKGLASS_KUBECONFIG + "'"],
            label = "stage breakglass kubeconfig off the mint root",
        )
        _cleanup_mint_root(ctx)
        if rc != 0:
            return None
        return CUSTODY_BREAKGLASS_KUBECONFIG
    if talosconfig == "":
        talosconfig = root + "/talosconfig"

    rc = _require_talm_operator_state(ctx, root)
    if rc != 0:
        return None
    return _mint_custody_kubeconfig_from(ctx, root, talosconfig)

def _mint_custody_kubeconfig_from(ctx, root, talosconfig):
    rc = checked_spawn(
        ctx,
        "bazelisk",
        [
            "run",
            TALM_TARGET,
            "--",
            "talosconfig",
            "--root",
            root,
            "--talosconfig",
            talosconfig,
        ],
        cwd = ws_path(ctx),
        label = "talm talosconfig guardian-mgmt",
    )
    if rc != 0:
        return None

    rc = checked_spawn(
        ctx,
        "bazelisk",
        [
            "run",
            TALM_TARGET,
            "--",
            "kubeconfig",
            "--root",
            root,
            "--talosconfig",
            talosconfig,
            "--nodes",
            _first_csv_value(ctx.args.nodes),
            "--endpoints",
            ctx.args.endpoints,
            "--merge=false",
            "--force",
        ],
        cwd = ws_path(ctx),
        label = "talm kubeconfig guardian-mgmt",
    )
    if rc != 0:
        return None

    kubeconfig = root + "/kubeconfig"
    kubectl = _kubectl_path(ctx)
    if kubectl == None:
        return None
    server = _capture_stdout(
        ctx,
        kubectl,
        ["--kubeconfig", kubeconfig, "config", "view", "--minify", "--output=jsonpath={.clusters[0].cluster.server}"],
        cwd = ws_path(ctx),
        label = "kubectl inspect generated guardian-mgmt kubeconfig",
    )
    if server == None:
        return None
    if not _contains(EXPECTED_KUBE_APIS, server):
        ctx.std.io.stderr.write("ERROR: generated kubeconfig points at " + server + "; expected guardian-mgmt API endpoint from src/infrastructure/bootstrap/guardian-mgmt/main.tf\n")
        return None

    ctx.std.io.stderr.write("wrote guardian-mgmt kubeconfig to " + kubeconfig + " (" + server + ")\n")
    return kubeconfig

def _install_kubeconfig(ctx, kubectl, source):
    target = ctx.args.install_path
    if target == "":
        target = "~/.kube/config"
    target = _expand_operator_path(ctx, target)
    if target == None:
        return 1
    if target == source:
        ctx.std.io.stderr.write("guardian-mgmt kubeconfig already installed at " + target + "\n")
        return 0

    target_dir = _capture_stdout(ctx, "dirname", [target], label = "dirname " + target)
    if target_dir == None:
        return 1
    rc = checked_spawn(ctx, "mkdir", ["-p", target_dir], label = "mkdir -p " + target_dir)
    if rc != 0:
        return rc

    backup = ""
    if ctx.std.fs.exists(target):
        stamp = _capture_stdout(ctx, "date", ["+%Y%m%d%H%M%S"], label = "date kubeconfig backup stamp")
        if stamp == None:
            return 1
        backup = target + ".backup-" + stamp
        rc = checked_spawn(ctx, "cp", [target, backup], label = "backup existing kubeconfig")
        if rc != 0:
            return rc

    rc = checked_spawn(ctx, "cp", [source, target], label = "install guardian-mgmt kubeconfig")
    if rc != 0:
        return rc
    rc = checked_spawn(ctx, "chmod", ["600", target], label = "chmod 600 guardian-mgmt kubeconfig")
    if rc != 0:
        return rc
    rc = _capture_success(ctx, kubectl, ["--kubeconfig", target, "config", "use-context", "admin@guardian-mgmt"], cwd = ws_path(ctx), label = "kubectl select guardian-mgmt context")
    if rc != 0:
        return rc

    message = "installed guardian-mgmt kubeconfig at " + target
    if backup != "":
        message = message + " (backup: " + backup + ")"
    ctx.std.io.stderr.write(message + "\n")
    return 0

def _custody_impl(ctx):
    restic = bazel_output_file(ctx, RESTIC_TARGET)
    if restic == "":
        return 1
    custody_args = [
        ctx.args.action,
        "--restic",
        restic,
        "--talm-root",
        ws_path(ctx, GUARDIAN_MGMT_TALM_ROOT),
    ]
    if ctx.args.repo != "":
        repo = _expand_operator_path(ctx, ctx.args.repo)
        if repo == None:
            return 1
        custody_args.extend(["--repo", repo])
    if ctx.args.yes:
        custody_args.append("--yes")
    if ctx.args.read_data:
        custody_args.append("--read-data")
    if ctx.args.env_key != "":
        custody_args.extend(["--env-key", ctx.args.env_key])
    return checked_spawn(
        ctx,
        "bazelisk",
        ["run", CUSTODY_TARGET, "--"] + custody_args,
        cwd = ws_path(ctx),
        label = "custody " + ctx.args.action,
    )

def _talos_impl(ctx):
    talosctl = _tool_path(ctx, TALOSCTL_TARGET)
    if talosctl == None:
        return 1

    addresses = _talosctl_capture(
        ctx,
        talosctl,
        ["get", "addresses"],
        "talosctl get addresses",
    )
    if addresses == None:
        return 1
    for node in GUARDIAN_MGMT_TALOS_NODES:
        rc = _assert_contains(ctx, addresses, node, "talos addresses")
        if rc != 0:
            return rc

    rc = _talosctl_success(
        ctx,
        talosctl,
        ["get", "routes"],
        "talosctl get routes",
    )
    if rc != 0:
        return rc

    kubespan = _talosctl_capture(
        ctx,
        talosctl,
        ["get", "kubespanpeerstatuses", "-o", "jsonpath={.items}"],
        "talosctl get kubespanpeerstatuses",
    )
    if kubespan == None:
        return 1
    if kubespan != "" and kubespan != "[]":
        rc = _assert_equals(ctx, kubespan, "[]", "kubespan peer statuses")
        if rc != 0:
            return rc

    ctx.std.io.stderr.write("guardian-mgmt Talos L2 checks passed\n")
    return 0

def _upgrade_cozystack_impl(ctx):
    return _upgrade_cozystack_with_kubeconfig(ctx, ctx.args.kubeconfig, ctx.args.wait_timeout)

def _upgrade_cozystack_with_kubeconfig(ctx, kubeconfig, wait_timeout):
    helm = _tool_path(ctx, HELM_TARGET)
    if helm == None:
        return 1

    args = []
    if kubeconfig != "":
        args.extend(["--kubeconfig", _workspace_path_if_relative(ctx, kubeconfig)])
    args.extend([
        "upgrade",
        "--install",
        "cozystack",
        COZYSTACK_INSTALLER_CHART,
        "--version",
        COZYSTACK_INSTALLER_VERSION,
        "--namespace",
        "cozy-system",
        "--create-namespace",
        "--wait",
        "--timeout",
        wait_timeout,
        "--set",
        "cozystackOperator.variant=talos",
        "--set",
        "cozystackOperator.disableTelemetry=true",
    ])

    return checked_spawn(
        ctx,
        helm,
        args,
        cwd = ws_path(ctx),
        label = "helm upgrade cozystack installer " + COZYSTACK_INSTALLER_VERSION,
    )

def _bootstrap_impl(ctx):
    endpoint = _tofu_backend_endpoint(ctx, ctx.args.tofu_backend_endpoint)
    if endpoint == None:
        return 1
    rc = _tofu_backend_init(ctx, [(GUARDIAN_MGMT_ROOT, "guardian-mgmt")], endpoint)
    if rc != 0:
        return rc

    rc = _tofu_root(
        ctx,
        GUARDIAN_MGMT_ROOT,
        ["output", "-json"],
        "tofu output -json guardian-mgmt",
    )
    if rc != 0:
        return rc

    rc = _validate_impl(ctx)
    if rc != 0:
        return rc

    rc = _kubeconfig_impl(ctx)
    if rc != 0:
        return rc

    rc = _talos_impl(ctx)
    if rc != 0:
        return rc

    live_kubeconfig = ctx.args.kubeconfig
    if live_kubeconfig == "":
        live_kubeconfig = ws_path(ctx, ctx.args.root) + "/kubeconfig"

    rc = _upgrade_cozystack_with_kubeconfig(ctx, live_kubeconfig, ctx.args.cozystack_upgrade_timeout)
    if rc != 0:
        return rc

    return 0

def _node_outage_drill_impl(ctx):
    if ctx.args.node == "":
        ctx.std.io.stderr.write("ERROR: --node is required\n")
        return 1
    if ctx.args.confirm_node != ctx.args.node:
        ctx.std.io.stderr.write("ERROR: --confirm-node must exactly match --node before running this disruptive drill\n")
        return 1

    kubectl = _kubectl_path(ctx)
    if kubectl == None:
        return 1

    rc = _check_live_context(ctx, kubectl)
    if rc != 0:
        return rc
    if ctx.args.revision != "":
        rc = _check_flux_revision(ctx, kubectl, ctx.args.revision)
        if rc != 0:
            return rc

    drill_args = [
        "--kubectl",
        kubectl,
        "--node",
        ctx.args.node,
        "--confirm-node",
        ctx.args.confirm_node,
        "--request-timeout",
        ctx.args.request_timeout,
        "--drain-timeout",
        ctx.args.drain_timeout,
        "--wait-timeout",
        ctx.args.wait_timeout,
        "--openbao-namespace",
        ctx.args.openbao_namespace,
        "--openbao-statefulset",
        ctx.args.openbao_statefulset,
    ]
    if ctx.args.kubeconfig != "":
        drill_args.extend(["--kubeconfig", _kubeconfig_path(ctx)])

    return checked_spawn(
        ctx,
        "bazelisk",
        ["run", NODE_OUTAGE_DRILL_TARGET, "--"] + drill_args,
        cwd = ws_path(ctx),
        label = "cozystack node outage drill",
    )

def _load_http_impl(ctx):
    if ctx.args.require_live != "true" and ctx.args.require_live != "false":
        ctx.std.io.stderr.write("ERROR: --require-live must be true or false\n")
        return 1

    k6 = _tool_path(ctx, K6_TARGET)
    if k6 == None:
        return 1

    kubectl = _kubectl_path(ctx)
    if kubectl == None:
        return 1

    if ctx.args.require_live == "true":
        rc = _check_live_context(ctx, kubectl)
        if rc != 0:
            return rc
        if ctx.args.revision != "":
            rc = _check_flux_revision(ctx, kubectl, ctx.args.revision)
            if rc != 0:
                return rc

    load_args = [
        "--k6",
        k6,
        "--script",
        ws_path(ctx, "src/infrastructure/load/http-smoke.js"),
        "--kubectl",
        kubectl,
        "--stage",
        ctx.args.stage,
        "--surface",
        ctx.args.surface,
        "--request-timeout",
        ctx.args.request_timeout,
        "--wait-timeout",
        ctx.args.wait_timeout,
        "--vus",
        ctx.args.vus,
        "--duration",
        ctx.args.duration,
        "--http-failed-threshold",
        ctx.args.http_failed_threshold,
        "--sleep-seconds",
        ctx.args.sleep_seconds,
        "--port-forward-ready-timeout",
        ctx.args.port_forward_ready_timeout,
    ]
    if ctx.args.kubeconfig != "":
        load_args.extend(["--kubeconfig", _kubeconfig_path(ctx)])
    if ctx.args.url != "":
        load_args.extend(["--url", ctx.args.url])
    if ctx.args.expected_statuses != "":
        load_args.extend(["--expected-statuses", ctx.args.expected_statuses])
    if ctx.args.host_overrides != "":
        load_args.extend(["--host-overrides", ctx.args.host_overrides])

    return checked_spawn(
        ctx,
        "bazelisk",
        ["run", HTTP_LOAD_TARGET, "--"] + load_args,
        cwd = ws_path(ctx),
        label = "cozystack http load",
    )

def _edge_health_impl(ctx):
    return checked_spawn(
        ctx,
        "bazelisk",
        ["run", EDGE_HEALTH_TARGET],
        cwd = ws_path(ctx),
        label = "guardian edge health",
    )

def _edge_failover_drill_impl(ctx):
    if ctx.args.confirm_node_ip != ctx.args.node_ip:
        ctx.std.io.stderr.write("ERROR: --confirm-node-ip must exactly match --node-ip before rebooting a node\n")
        return 1

    k6 = _tool_path(ctx, K6_TARGET)
    if k6 == None:
        return 1
    kubectl = _kubectl_path(ctx)
    if kubectl == None:
        return 1
    talosctl = _tool_path(ctx, TALOSCTL_TARGET)
    if talosctl == None:
        return 1

    rc = _check_live_context_for(ctx, kubectl, ctx.args.kubeconfig, ctx.args.kube_api_server)
    if rc != 0:
        return rc
    if ctx.args.revision != "":
        rc = _check_flux_revision_for(ctx, kubectl, ctx.args.kubeconfig, ctx.args.revision, ctx.args.kube_api_server)
        if rc != 0:
            return rc

    drill_args = [
        "--k6",
        k6,
        "--script",
        ws_path(ctx, "src/infrastructure/load/edge-failover.js"),
        "--kubectl",
        kubectl,
        "--talosctl",
        talosctl,
        "--talosconfig",
        _talosconfig_path(ctx),
        "--talos-endpoint",
        ctx.args.talos_endpoint,
        "--node-name",
        ctx.args.node_name,
        "--node-ip",
        ctx.args.node_ip,
        "--confirm-node-ip",
        ctx.args.confirm_node_ip,
        "--url",
        ctx.args.url,
        "--expected-statuses",
        ctx.args.expected_statuses,
        "--duration",
        ctx.args.duration,
        "--warmup",
        ctx.args.warmup,
        "--cooldown",
        ctx.args.cooldown,
        "--sample-interval-ms",
        ctx.args.sample_interval_ms,
        "--request-timeout",
        ctx.args.request_timeout,
        "--k6-dns",
        ctx.args.k6_dns,
        "--kube-timeout",
        ctx.args.kube_timeout,
        "--report",
        ctx.args.report,
    ]
    if ctx.args.kubeconfig != "":
        drill_args.extend(["--kubeconfig", _kubeconfig_path(ctx)])
    if ctx.args.kube_api_server != "":
        drill_args.extend(["--kube-api-server", ctx.args.kube_api_server])

    return checked_spawn(
        ctx,
        "bazelisk",
        ["run", EDGE_FAILOVER_DRILL_TARGET, "--"] + drill_args,
        cwd = ws_path(ctx),
        label = "guardian edge failover drill",
    )

