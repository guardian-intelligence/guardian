def _derive_union_lock(ctx, out_path):
    return checked_spawn(
        ctx,
        "bazelisk",
        [
            "run",
            IMAGESET_TARGET,
            "--",
            "--declared",
            ws_path(ctx, DECLARED_LOCK_PATH),
            "--repo-root",
            ws_path(ctx),
            "--dark-mirror-values",
            ws_path(ctx, TALM_VALUES_PATH),
            "--out",
            out_path,
        ],
        cwd = ws_path(ctx),
        label = "derive union images lock (declared + rendered)",
    )

def _project_manifest(ctx, union_lock, out_path, skip_digests_in = None):
    project_args = [
        "run",
        BUNDLE_TARGET,
        "--",
        "--images-lock",
        union_lock,
        "--hauler-manifest-out",
        out_path,
    ]
    if skip_digests_in != None:
        project_args.extend(["--skip-digests-in", skip_digests_in])
    return checked_spawn(
        ctx,
        "bazelisk",
        project_args,
        cwd = ws_path(ctx),
        label = "project union lock into hauler manifest",
    )

def _bundle_impl(ctx):
    out_dir = _workspace_path_if_relative(ctx, ctx.args.out_dir)
    resuming = ctx.std.fs.exists(out_dir)
    if resuming and not ctx.args.resume:
        ctx.std.io.stderr.write("ERROR: " + out_dir + " already exists. Syncing into an existing store can carry artifacts that are no longer in the union lock into the haul. Remove it for a clean build, or pass --resume to continue an interrupted sync of the SAME lock (verified by union comparison).\n")
        return 1

    # The recorded revision must actually describe the union that gets
    # derived, projected, synced, and hashed; a dirty union input would make
    # the bundle manifest's provenance false. --ignored matters: the
    # extractor walks the on-disk trees, so a gitignored YAML file changes
    # the union without ever showing in plain porcelain output.
    lock_status = _capture_stdout(
        ctx,
        "git",
        ["status", "--porcelain", "--ignored", "--"] + UNION_LOCK_INPUTS,
        cwd = ws_path(ctx),
        label = "git status of union lock inputs",
    )
    if lock_status == None:
        return 1
    dirty = []
    for line in lock_status.split("\n"):
        if line == "":
            continue
        if not line.startswith("!!"):
            dirty.append(line)
        elif line.endswith(".yaml") or line.endswith(".yml"):
            dirty.append(line + "  (gitignored YAML still feeds the extractor)")
    if dirty:
        ctx.std.io.stderr.write("ERROR: union lock inputs (declared lock, manifest trees, or extractor sources) differ from the committed revision; the bundle manifest would attribute the haul to a revision whose inventory differs. Resolve first:\n" + "\n".join(dirty) + "\n")
        return 1

    rc = checked_spawn(
        ctx,
        "bazelisk",
        ["test"] + BUNDLE_PRECONDITION_TESTS,
        cwd = ws_path(ctx),
        label = "bundle preconditions: union lock derivation + projection contract",
    )
    if rc != 0:
        return rc

    revision = _capture_stdout(
        ctx,
        "git",
        ["rev-parse", "HEAD"],
        cwd = ws_path(ctx),
        label = "git rev-parse HEAD",
    )
    if revision == None:
        return 1

    union_lock = out_dir + "/images.lock"
    hauler_manifest = out_dir + "/hauler-manifest.yaml"
    sync_manifest = hauler_manifest
    if resuming:
        if not ctx.std.fs.exists(union_lock) or not ctx.std.fs.exists(hauler_manifest):
            ctx.std.io.stderr.write("ERROR: " + out_dir + " exists but holds no images.lock + hauler-manifest.yaml pair — it is not an interrupted bundle (or was interrupted before projection). Remove the directory and build fresh.\n")
            return 1
        fresh = union_lock + ".fresh"
        rc = _derive_union_lock(ctx, fresh)
        if rc != 0:
            return rc

        # A resume is only safe when the interrupted bundle was built from
        # the same inventory: the derivation is deterministic, so
        # byte-compare the union.
        if _capture_success(ctx, "cmp", ["-s", union_lock, fresh], label = "compare derived union with the interrupted bundle's") != 0:
            _capture_success(ctx, "rm", ["-f", fresh], label = "drop comparison copy")
            ctx.std.io.stderr.write("ERROR: the union lock inputs changed since the bundle in " + out_dir + " was started; its store may hold refs no longer in the inventory. Remove the directory and build fresh.\n")
            return 1
        rc = _capture_success(ctx, "rm", [fresh], label = "drop comparison copy")
        if rc != 0:
            return rc

        # The stored hauler manifest must equal what the CURRENT projection
        # code derives from that same union — a cmd/bundle change landed
        # mid-interruption would otherwise sync the rest of the store under
        # one projection while the drive records another.
        manifest_fresh = hauler_manifest + ".fresh"
        rc = _project_manifest(ctx, union_lock, manifest_fresh)
        if rc != 0:
            return rc
        if _capture_success(ctx, "cmp", ["-s", hauler_manifest, manifest_fresh], label = "compare projected manifest with the interrupted bundle's") != 0:
            _capture_success(ctx, "rm", ["-f", manifest_fresh], label = "drop comparison copy")
            ctx.std.io.stderr.write("ERROR: the hauler projection of this union no longer matches the interrupted bundle's hauler-manifest.yaml (projection code changed?). Remove " + out_dir + " and build fresh.\n")
            return 1
        rc = _capture_success(ctx, "rm", [manifest_fresh], label = "drop comparison copy")
        if rc != 0:
            return rc

        # Hauler re-fetches every listed ref's manifest from upstream even
        # when the blobs are already local, and anonymous docker.io requests
        # are scarce — so a real resume must sync only the refs the store is
        # missing. Project the residual manifest against the store index.
        store_index = out_dir + "/store/index.json"
        if ctx.std.fs.exists(store_index):
            sync_manifest = out_dir + "/hauler-manifest.resume.yaml"
            rc = _project_manifest(ctx, union_lock, sync_manifest, skip_digests_in = store_index)
            if rc != 0:
                return rc
    else:
        rc = _derive_union_lock(ctx, union_lock)
        if rc != 0:
            return rc
        rc = _project_manifest(ctx, union_lock, hauler_manifest)
        if rc != 0:
            return rc

    rc = checked_spawn(
        ctx,
        "bazelisk",
        [
            "run",
            HAULER_TARGET,
            "--",
            "store",
            "sync",
            "--store=" + out_dir + "/store",
            "--filename=" + sync_manifest,
        ],
        cwd = ws_path(ctx),
        label = "hauler store sync (pulls every locked artifact; needs network)",
    )
    if rc != 0:
        return rc
    if sync_manifest != hauler_manifest:
        rc = _capture_success(ctx, "rm", [sync_manifest], label = "drop residual resume manifest")
        if rc != 0:
            return rc

    rc = checked_spawn(
        ctx,
        "bazelisk",
        [
            "run",
            HAULER_TARGET,
            "--",
            "store",
            "save",
            "--store=" + out_dir + "/store",
            "--filename=" + out_dir + "/haul.tar.zst",
        ],
        cwd = ws_path(ctx),
        label = "hauler store save",
    )
    if rc != 0:
        return rc

    # The sync can run for hours; re-derive and byte-compare so an inventory
    # edit made mid-sync cannot produce a bundle manifest describing a union
    # the haul was not synced from.
    verify = union_lock + ".verify"
    rc = _derive_union_lock(ctx, verify)
    if rc != 0:
        return rc
    if _capture_success(ctx, "cmp", ["-s", union_lock, verify], label = "verify union lock inputs unchanged across the sync") != 0:
        _capture_success(ctx, "rm", ["-f", verify], label = "drop verification copy")
        ctx.std.io.stderr.write("ERROR: the union lock inputs changed while the bundle was building; the haul does not match the current inventory. Remove " + out_dir + " and build fresh.\n")
        return 1
    rc = _capture_success(ctx, "rm", [verify], label = "drop verification copy")
    if rc != 0:
        return rc

    rc = checked_spawn(
        ctx,
        "bazelisk",
        [
            "run",
            BUNDLE_TARGET,
            "--",
            "--images-lock",
            union_lock,
            "--haul-path",
            out_dir + "/haul.tar.zst",
            "--revision",
            revision,
            "--bundle-manifest-out",
            out_dir + "/bundle-manifest.yaml",
        ],
        cwd = ws_path(ctx),
        label = "write bundle manifest (revision + digests)",
    )
    if rc != 0:
        return rc

    # Supply-chain gate: the drive must carry CI's signature over the exact
    # union lock this haul was synced from. Fetch the signature bundle keyed
    # by the union's sha256 (published by the images-lock-sign workflow on
    # main, which derives the identical union from the same revision), verify
    # it against the pinned identity and Sigstore root, then run the same
    # offline verification the operator repeats at dark bring-up.
    oras = _tool_path(ctx, ORAS_TARGET)
    if oras == None:
        return 1
    cosign = _tool_path(ctx, COSIGN_TARGET)
    if cosign == None:
        return 1
    lockhash = _capture_stdout(
        ctx,
        "sha256sum",
        [union_lock],
        label = "hash the union lock for the signature lookup",
    )
    if lockhash == None:
        return 1
    lockhash = lockhash.split(" ")[0]
    rc = checked_spawn(
        ctx,
        oras,
        [
            "pull",
            SUPPLY_CHAIN_REPO + ":images.lock-" + lockhash,
            "--output",
            out_dir,
        ],
        cwd = ws_path(ctx),
        label = "fetch CI signature bundle for images.lock",
    )
    if rc != 0:
        ctx.std.io.stderr.write("ERROR: could not fetch the CI signature bundle for union lock sha256 " + lockhash + ". Most common cause: this exact union has not been signed by the images-lock-sign workflow on main (merge the inventory change or dispatch the workflow). Also check that the local docker config is authenticated to ghcr.io — the supply-chain package is private.\n")
        return 1
    rc = checked_spawn(
        ctx,
        cosign,
        [
            "verify-blob",
            "--bundle",
            out_dir + "/images.lock.sigbundle",
            "--certificate-identity",
            IMAGES_LOCK_SIGN_IDENTITY,
            "--certificate-oidc-issuer",
            SIGSTORE_OIDC_ISSUER,
            "--trusted-root",
            ws_path(ctx, SIGSTORE_TRUSTED_ROOT_PATH),
            union_lock,
        ],
        cwd = ws_path(ctx),
        label = "verify union lock signature (pinned identity + Sigstore root)",
    )
    if rc != 0:
        # Do not leave a drive dir that looks complete with a signature that
        # failed verification.
        _capture_success(ctx, "rm", ["-f", out_dir + "/images.lock.sigbundle"], label = "drop unverifiable signature bundle")
        ctx.std.io.stderr.write("ERROR: the fetched signature bundle did not verify against the pinned identity + Sigstore root; removed it from " + out_dir + ". The drive is NOT complete.\n")
        return rc

    return checked_spawn(
        ctx,
        "bazelisk",
        [
            "run",
            BUNDLE_TARGET,
            "--",
            "--verify",
            "--bundle-dir",
            out_dir,
            "--images-lock",
            union_lock,
            "--revision",
            revision,
        ],
        cwd = ws_path(ctx),
        label = "bundle --verify (lock, haul, and hauler-manifest hash bindings)",
    )

def _converged_impl(ctx):
    kubectl = _kubectl_path(ctx)
    if kubectl == None:
        return 1

    proof_args = [
        "--kubectl",
        kubectl,
        "--flux-namespace",
        ctx.args.flux_namespace,
        "--request-timeout",
        ctx.args.request_timeout,
    ]
    if ctx.args.expected_revision != "":
        proof_args.extend(["--expected-revision", ctx.args.expected_revision])
    if ctx.args.kube_api_server != "":
        proof_args.extend(["--kube-api-server", ctx.args.kube_api_server])
    if ctx.args.kubeconfig != "":
        proof_args.extend(["--kubeconfig", _kubeconfig_path(ctx)])
    if ctx.args.required_kustomizations != "":
        proof_args.extend(["--required-kustomizations", ctx.args.required_kustomizations])

    return checked_spawn(
        ctx,
        "bazelisk",
        ["run", CONVERGED_TARGET, "--"] + proof_args,
        cwd = ws_path(ctx),
        label = "guardian converged proof",
    )

def _watch_impl(ctx):
    watch_args = []
    env = {}
    if ctx.args.mode == "status":
        kubectl = _kubectl_path(ctx)
        if kubectl == None:
            return 1
        env["KUBECTL"] = kubectl
        if ctx.args.kubeconfig != "":
            env["KUBECONFIG"] = _kubeconfig_path(ctx)
        watch_args.extend(["--status", "--interval", ctx.args.interval])
    elif ctx.args.mode == "stream":
        watch_args.append("--stream")
    elif ctx.args.mode == "convergence":
        watch_args.append("--convergence")
    else:
        ctx.std.io.stderr.write("ERROR: --mode must be status, stream, or convergence\n")
        return 1

    if ctx.args.mode != "status":
        watch_args.extend(["--since", ctx.args.since])
        if ctx.args.grep != "":
            watch_args.extend(["--grep", ctx.args.grep])
    elif ctx.args.grep != "":
        ctx.std.io.stderr.write("ERROR: --grep only applies to --mode=stream or --mode=convergence\n")
        return 1

    return checked_spawn(
        ctx,
        ws_path(ctx, "tools/ops/cluster-watch"),
        watch_args,
        cwd = ws_path(ctx),
        env = env,
        label = "cluster-watch " + ctx.args.mode,
    )


def _auth_impl(ctx):
    if ctx.args.platform_agent == ctx.args.platform_admin:
        ctx.std.io.stderr.write("ERROR: pass exactly one of --platform-agent or --platform-admin\n")
        return 1

    target = ctx.args.install_path
    if target == "":
        target = "~/.kube/config"
    target = _expand_operator_path(ctx, target)
    if target == None:
        return 1

    kubectl = _kubectl_path(ctx)
    if kubectl == None:
        return 1

    target_dir = _capture_stdout(ctx, "dirname", [target], label = "dirname " + target)
    if target_dir == None:
        return 1
    rc = checked_spawn(ctx, "mkdir", ["-p", target_dir], label = "mkdir -p " + target_dir)
    if rc != 0:
        return rc

    if ctx.args.platform_agent:
        return _auth_platform_agent(ctx, kubectl, target)
    return _auth_platform_admin(ctx, kubectl, target)

def _auth_platform_agent(ctx, kubectl, target):
    ca = ws_path(ctx, CLUSTER_CA_PATH)
    if not ctx.std.fs.exists(ca):
        ctx.std.io.stderr.write("ERROR: missing " + CLUSTER_CA_PATH + "; the committed cluster CA is required to bootstrap the OIDC context\n")
        return 1

    bin_dir = install_bazel_tool_shims(ctx, [("kubectl-oidc_login", KUBELOGIN_TARGET)], ".guardian/tools/bin")
    if bin_dir == "":
        return 1
    kubelogin = bin_dir + "/kubectl-oidc_login"

    home = ctx.std.env.var("HOME") or ""
    if home == "":
        ctx.std.io.stderr.write("ERROR: HOME is not set\n")
        return 1
    cache_dir = home + "/.kube/cache/oidc-login-platform-agent"
    server = "https://" + PUBLIC_TALOS_KUBECONFIG_NODE + ":6443"

    # set-credentials appends --exec-arg values to an existing user, so drop
    # any previous entry to keep reruns idempotent.
    rc = checked_spawn(
        ctx,
        "sh",
        ["-c", "'" + kubectl + "' --kubeconfig '" + target + "' config unset users.platform-agent >/dev/null 2>&1 || true"],
        label = "kubeconfig reset platform-agent user",
    )
    if rc != 0:
        return rc

    steps = [
        (["config", "set-cluster", "guardian-mgmt", "--server=" + server, "--certificate-authority=" + ca, "--embed-certs=true"], "kubeconfig set-cluster guardian-mgmt"),
        ([
            "config",
            "set-credentials",
            "platform-agent",
            "--exec-api-version=client.authentication.k8s.io/v1beta1",
            "--exec-command=" + kubelogin,
            "--exec-arg=get-token",
            "--exec-arg=--oidc-issuer-url=" + PLATFORM_OIDC_ISSUER,
            "--exec-arg=--oidc-client-id=" + PLATFORM_OIDC_CLIENT_ID,
            "--exec-arg=--token-cache-dir=" + cache_dir,
        ], "kubeconfig set-credentials platform-agent"),
        (["config", "set-context", "platform-agent@guardian-mgmt", "--cluster=guardian-mgmt", "--user=platform-agent"], "kubeconfig set-context platform-agent@guardian-mgmt"),
        (["config", "use-context", "platform-agent@guardian-mgmt"], "kubeconfig use-context platform-agent@guardian-mgmt"),
    ]
    for step_args, label in steps:
        rc = checked_spawn(ctx, kubectl, ["--kubeconfig", target] + step_args, label = label)
        if rc != 0:
            return rc
    rc = checked_spawn(ctx, "chmod", ["600", target], label = "chmod 600 " + target)
    if rc != 0:
        return rc

    ctx.std.io.stderr.write("selected platform-agent@guardian-mgmt in " + target + "; verifying (first login opens a browser)\n")
    return checked_spawn(ctx, kubectl, ["--kubeconfig", target, "auth", "whoami"], label = "kubectl auth whoami")

def _auth_platform_admin(ctx, kubectl, target):
    reason = ctx.args.reason.strip()
    if reason == "":
        ctx.std.io.stderr.write("ERROR: --reason is required: breakglass escalation to system:masters is audit-logged\n")
        return 1

    minted = _mint_custody_kubeconfig(ctx)
    if minted == None:
        return 1

    backup = ""
    if ctx.std.fs.exists(target):
        stamp = _capture_stdout(ctx, "date", ["+%Y%m%d%H%M%S"], label = "date kubeconfig backup stamp")
        if stamp == None:
            return 1
        backup = target + ".backup-" + stamp
        rc = checked_spawn(ctx, "cp", [target, backup], label = "backup existing kubeconfig")
        if rc != 0:
            return rc

    # Merge rather than replace: fresh admin credentials win on conflict
    # (minted file listed first), every other context survives.
    tmp = target + ".merge-tmp"
    rc = checked_spawn(
        ctx,
        "sh",
        ["-c", "umask 077 && '" + kubectl + "' config view --flatten --raw > '" + tmp + "' && mv '" + tmp + "' '" + target + "'"],
        env = {"KUBECONFIG": minted + ":" + target},
        label = "merge breakglass admin context into " + target,
    )
    # The merge is the only consumer of the minted kubeconfig; shred the staged
    # bundle-path copy now (its cert is already in target regardless of what
    # follows). No-op on the tree path.
    _shred_staged_breakglass_kubeconfig(ctx)
    if rc != 0:
        return rc
    rc = checked_spawn(ctx, kubectl, ["--kubeconfig", target, "config", "use-context", "admin@guardian-mgmt"], label = "kubeconfig use-context admin@guardian-mgmt")
    if rc != 0:
        return rc
    rc = checked_spawn(ctx, "chmod", ["600", target], label = "chmod 600 " + target)
    if rc != 0:
        return rc

    rc = _breakglass_audit(ctx, kubectl, target, reason)
    if rc != 0:
        return rc

    message = "breakglass: admin@guardian-mgmt (system:masters) selected in " + target
    if backup != "":
        message = message + " (backup: " + backup + ")"
    ctx.std.io.stderr.write(message + "\n")
    return 0

def _breakglass_audit(ctx, kubectl, target, reason):
    stamp = _capture_stdout(ctx, "date", ["-u", "+%Y-%m-%dT%H:%M:%SZ"], label = "date breakglass stamp")
    if stamp == None:
        return 1
    user = ctx.std.env.var("USER") or "unknown"
    host = _capture_stdout(ctx, "hostname", [], label = "hostname")
    if host == None:
        host = "unknown"
    entry = stamp + " user=" + user + " host=" + host + " reason=" + reason

    # Local ledger next to the custody state that minted the credentials.
    # This is the only leg allowed to fail the escalation: it has no network
    # or cluster dependency, so if it fails something is wrong locally.
    log_path = ws_path(ctx, ctx.args.root) + "/breakglass.log"
    rc = checked_spawn(
        ctx,
        "sh",
        ["-c", "printf '%s\\n' \"$BREAKGLASS_ENTRY\" >> '" + log_path + "'"],
        env = {"BREAKGLASS_ENTRY": entry},
        label = "append breakglass ledger " + log_path,
    )
    if rc != 0:
        return rc

    # Page the operations topic. Best-effort: breakglass exists precisely for
    # moments when infrastructure is broken, so a failed page must not block
    # the escalation.
    curl = bazel_output_file(ctx, CURL_TARGET)
    paged = False
    if curl != "":
        rc = _capture_success(
            ctx,
            curl,
            [
                "-fsS",
                "-m",
                "10",
                "-H",
                "Title: BREAKGLASS: guardian-mgmt system:masters minted",
                "-H",
                "Priority: urgent",
                "-H",
                "Tags: rotating_light",
                "-d",
                entry,
                ctx.args.audit_ntfy_url,
            ],
            label = "page " + ctx.args.audit_ntfy_url,
        )
        paged = rc == 0
    if not paged:
        ctx.std.io.stderr.write("WARN: could not page " + ctx.args.audit_ntfy_url + "; the escalation is recorded in " + log_path + " — notify the operator manually\n")

    # In-cluster ledger. Best-effort for the same reason: the cluster may be
    # exactly what is broken.
    key = "bg-" + stamp.replace(":", ".")
    escaped = entry.replace("\\", "\\\\").replace("\"", "\\\"")
    payload = "{\"data\":{\"" + key + "\":\"" + escaped + "\"}}"
    script = (
        "'" + kubectl + "' --kubeconfig '" + target + "' -n " + BREAKGLASS_LEDGER_NAMESPACE +
        " create configmap " + BREAKGLASS_LEDGER_CONFIGMAP + " --dry-run=client -o yaml | " +
        "'" + kubectl + "' --kubeconfig '" + target + "' apply -f - >/dev/null && " +
        "'" + kubectl + "' --kubeconfig '" + target + "' -n " + BREAKGLASS_LEDGER_NAMESPACE +
        " patch configmap " + BREAKGLASS_LEDGER_CONFIGMAP + " --type=merge -p \"$BREAKGLASS_PATCH\""
    )
    rc = checked_spawn(
        ctx,
        "sh",
        ["-c", script],
        env = {"BREAKGLASS_PATCH": payload},
        label = "append in-cluster breakglass ledger " + BREAKGLASS_LEDGER_NAMESPACE + "/" + BREAKGLASS_LEDGER_CONFIGMAP,
    )
    if rc != 0:
        ctx.std.io.stderr.write("WARN: could not write the in-cluster breakglass ledger; the escalation is recorded in " + log_path + "\n")
    return 0

