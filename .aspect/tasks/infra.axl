openbao_reinit = task(
    implementation = _openbao_reinit_impl,
    name = "openbao-reinit",
    group = ["infra"],
    summary = "Execute the OpenBao reinit (raft-reset re-seed) unattended: preconditions (guardian-system Ready at origin/main, tenant-guardian privileged Pod Security label with auto-remediation, custody import env file), raft reset with one-shot dirty-state recovery, raft membership drill, custody re-import, scoped re-relay of the in-cluster-generated values, then a cluster-wide secret-store and ExternalSecret force-sync until everything reports Ready. Prepare /dev/shm/guardian-custody/import.env per the static-seal runbook first and wipe custody after.",
    args = {
        "env_file": args.string(default = "/dev/shm/guardian-custody/import.env", description = "Custody import env file (absolute path). Built per the runbook's Bootstrap Secret Import recipe; the importer deletes it after a verified import."),
        "expected_revision": args.string(default = "", description = "origin/main HEAD the cluster and checkout must both be at. Defaults to git ls-remote origin refs/heads/main."),
        "kube_api_server": args.string(default = "", description = "Optional Kubernetes API server override for off-VLAN runs."),
        "kubeconfig": args.string(default = "", description = "Kubeconfig for guardian-mgmt. Defaults to KUBECONFIG/current context."),
        "namespace": args.string(default = "tenant-guardian", description = "OpenBao namespace."),
        "pod_wait_timeout": args.string(default = "10m", description = "Timeout for the raft members to reach Running/Ready after the reset."),
        "replicas": args.string(default = "0", description = "Raft member count to restore after the reset. 0 reads the live StatefulSet spec (the source of truth for the PVC set and scale-back); a non-zero value must match it and is required only when an interrupted reset left the StatefulSet at 0."),
        "request_timeout": args.string(default = "15s", description = "kubectl API request timeout."),
        "statefulset": args.string(default = "guardian-openbao", description = "OpenBao StatefulSet name."),
        "sync_timeout": args.string(default = "10m", description = "Timeout for every ExternalSecret to report synced after the force-sync."),
    },
)

openbao_observability_drill = task(
    implementation = _openbao_observability_drill_impl,
    name = "openbao-observability-drill",
    group = ["infra"],
    summary = "Verify OpenBao metrics, audit tailing, and VictoriaLogs ingestion.",
    args = {
        "kube_api_server": args.string(default = "", description = "Optional Kubernetes API server override for off-VLAN proof runs."),
        "kubeconfig": args.string(default = "", description = "Kubeconfig for guardian-mgmt. Defaults to KUBECONFIG/current context."),
        "monitoring_namespace": args.string(default = "tenant-root", description = "Cozystack monitoring namespace hosting vmselect/vlselect."),
        "namespace": args.string(default = "tenant-guardian", description = "OpenBao namespace."),
        "poll_interval": args.string(default = "10s", description = "Interval for VictoriaMetrics and VictoriaLogs polling."),
        "poll_timeout": args.string(default = "5m", description = "Timeout waiting for VictoriaMetrics and VictoriaLogs ingestion."),
        "port_forward_ready_timeout": args.string(default = "10s", description = "Timeout for VictoriaMetrics/VictoriaLogs port-forward readiness."),
        "request_timeout": args.string(default = "15s", description = "kubectl API request timeout."),
        "revision": args.string(default = "", description = "Optional expected Flux-reconciled commit SHA to check before the drill."),
        "stage": args.string(default = "root", description = "Guardian bootstrap stage: root."),
        "statefulset": args.string(default = "guardian-openbao", description = "OpenBao StatefulSet name."),
        "wait_timeout": args.string(default = "10m", description = "Timeout for OpenBao and monitoring readiness waits."),
    },
)

node_outage_drill = task(
    implementation = _node_outage_drill_impl,
    name = "node-outage-drill",
    group = ["infra"],
    summary = "Cordon, drain, outage-check, uncordon, and recovery-check one guardian-mgmt Kubernetes node.",
    args = {
        "confirm_node": args.string(default = "", description = "Must exactly match --node before the task mutates the cluster."),
        "drain_timeout": args.string(default = "10m", description = "kubectl drain timeout."),
        "kubeconfig": args.string(default = "", description = "Kubeconfig for guardian-mgmt. Defaults to KUBECONFIG/current context."),
        "node": args.string(default = "", description = "Kubernetes node name to cordon and drain."),
        "openbao_namespace": args.string(default = "tenant-guardian", description = "OpenBao namespace."),
        "openbao_statefulset": args.string(default = "guardian-openbao", description = "OpenBao StatefulSet name."),
        "request_timeout": args.string(default = "15s", description = "kubectl API request timeout."),
        "revision": args.string(default = "", description = "Optional expected Flux-reconciled commit SHA to check before the drill."),
        "wait_timeout": args.string(default = "15m", description = "Timeout for outage-phase and recovery readiness waits."),
    },
)
