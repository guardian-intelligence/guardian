def _observability_drill_impl(ctx):
    kubectl = _kubectl_path(ctx)
    if kubectl == None:
        return 1

    rc = _check_live_context(ctx, kubectl)
    if rc != 0:
        return rc
    if ctx.args.revision != "":
        rc = _check_flux_revision(ctx, kubectl, ctx.args.revision)
        if rc != 0:
            return rc

    drill_args = [
        "--kubectl",
        kubectl,
        "--stage",
        ctx.args.stage,
        "--application",
        ctx.args.application,
        "--request-timeout",
        ctx.args.request_timeout,
        "--wait-timeout",
        ctx.args.wait_timeout,
        "--poll-timeout",
        ctx.args.poll_timeout,
        "--poll-interval",
        ctx.args.poll_interval,
        "--port-forward-ready-timeout",
        ctx.args.port_forward_ready_timeout,
        "--ttl-seconds-after-finished",
        ctx.args.ttl_seconds_after_finished,
        "--pgbench-scale",
        ctx.args.pgbench_scale,
        "--pgbench-clients",
        ctx.args.pgbench_clients,
        "--pgbench-jobs",
        ctx.args.pgbench_jobs,
        "--pgbench-duration-seconds",
        ctx.args.pgbench_duration_seconds,
    ]
    if ctx.args.kubeconfig != "":
        drill_args.extend(["--kubeconfig", _kubeconfig_path(ctx)])
    if ctx.args.name != "":
        drill_args.extend(["--name", ctx.args.name])
    if ctx.args.skip_load == "true":
        drill_args.append("--skip-load=true")
    elif ctx.args.skip_load != "false":
        ctx.std.io.stderr.write("ERROR: --skip-load must be true or false\n")
        return 1

    return checked_spawn(
        ctx,
        "bazelisk",
        ["run", OBSERVABILITY_DRILL_TARGET, "--"] + drill_args,
        cwd = ws_path(ctx),
        label = "cozystack observability drill",
    )

def _openbao_drill_impl(ctx):
    kubectl = _kubectl_path(ctx)
    if kubectl == None:
        return 1

    rc = _check_live_context_for(ctx, kubectl, ctx.args.kubeconfig, ctx.args.kube_api_server)
    if rc != 0:
        return rc
    if ctx.args.revision != "":
        rc = _check_flux_revision_for(ctx, kubectl, ctx.args.kubeconfig, ctx.args.revision, ctx.args.kube_api_server)
        if rc != 0:
            return rc

    drill_args = [
        "--kubectl",
        kubectl,
        "--namespace",
        ctx.args.namespace,
        "--statefulset",
        ctx.args.statefulset,
        "--request-timeout",
        ctx.args.request_timeout,
    ]
    if ctx.args.kube_api_server != "":
        drill_args.extend(["--kube-api-server", ctx.args.kube_api_server])
    if ctx.args.kubeconfig != "":
        drill_args.extend(["--kubeconfig", _kubeconfig_path(ctx)])

    return checked_spawn(
        ctx,
        "bazelisk",
        ["run", OPENBAO_DRILL_TARGET, "--"] + drill_args,
        cwd = ws_path(ctx),
        label = "cozystack openbao drill",
    )

def _openbao_reinit_impl(ctx):
    kubectl = _kubectl_path(ctx)
    if kubectl == None:
        return 1

    rc = _check_live_context_for(ctx, kubectl, ctx.args.kubeconfig, ctx.args.kube_api_server)
    if rc != 0:
        return rc

    expected = ctx.args.expected_revision
    if expected == "":
        ls_remote = _capture_stdout(
            ctx,
            "git",
            ["ls-remote", "origin", "refs/heads/main"],
            cwd = ws_path(ctx),
            label = "git ls-remote origin refs/heads/main",
        )
        if ls_remote == None:
            return 1
        expected = ls_remote.split("\t")[0].strip()
    if expected == "":
        ctx.std.io.stderr.write("ERROR: could not determine origin/main HEAD; pass --expected-revision\n")
        return 1
    local = _capture_stdout(
        ctx,
        "git",
        ["rev-parse", "HEAD"],
        cwd = ws_path(ctx),
        label = "git rev-parse HEAD",
    )
    if local == None:
        return 1

    # HEAD == origin/main is not enough: bazel builds the importer from the
    # WORKING TREE, so an uncommitted edit to the import plan would pass the
    # revision gate and re-seed the whole KV from unreviewed code. Require a
    # clean tree before building. (The Go tool re-checks via --repo-root.)
    tree_status = _capture_stdout(
        ctx,
        "git",
        ["status", "--porcelain"],
        cwd = ws_path(ctx),
        label = "git status --porcelain",
    )
    if tree_status == None:
        return 1
    if tree_status != "":
        ctx.std.io.stderr.write(
            "ERROR: the working tree is dirty; the importer is built from the working tree, " +
            "so uncommitted changes would re-seed OpenBao from unreviewed code. Commit, stash, " +
            "or clean these first:\n" + tree_status + "\n",
        )
        return 1

    # The importer binary embeds the DR re-seed plan; build it from this
    # checkout (the tool refuses to run unless the checkout IS origin/main).
    importer = bazel_output_file(ctx, OPENBAO_SECRET_IMPORT_TARGET)
    if importer == "":
        return 1

    reinit_args = [
        "--kubectl",
        kubectl,
        "--importer",
        importer,
        "--repo-root",
        ws_path(ctx),
        "--env-file",
        ctx.args.env_file,
        "--expected-revision",
        expected,
        "--local-revision",
        local,
        "--namespace",
        ctx.args.namespace,
        "--statefulset",
        ctx.args.statefulset,
        "--replicas",
        ctx.args.replicas,
        "--request-timeout",
        ctx.args.request_timeout,
        "--pod-wait-timeout",
        ctx.args.pod_wait_timeout,
        "--sync-timeout",
        ctx.args.sync_timeout,
    ]
    if ctx.args.kubeconfig != "":
        reinit_args.extend(["--kubeconfig", _kubeconfig_path(ctx)])
    if ctx.args.kube_api_server != "":
        reinit_args.extend(["--kube-api-server", ctx.args.kube_api_server])

    return checked_spawn(
        ctx,
        "bazelisk",
        ["run", OPENBAO_REINIT_TARGET, "--"] + reinit_args,
        cwd = ws_path(ctx),
        label = "guardian openbao reinit",
    )

