def _secret_store_checks(label, namespace, store, role, service_account):
    return [
        (label + " secret store server", ["-n", namespace, "get", "secretstores.external-secrets.io/" + store, "-o", "jsonpath={.spec.provider.vault.server}"], OPENBAO_INTERNAL_URL),
        (label + " secret store engine", ["-n", namespace, "get", "secretstores.external-secrets.io/" + store, "-o", "jsonpath={.spec.provider.vault.path}"], "kv"),
        (label + " secret store engine version", ["-n", namespace, "get", "secretstores.external-secrets.io/" + store, "-o", "jsonpath={.spec.provider.vault.version}"], "v2"),
        (label + " secret store auth mount", ["-n", namespace, "get", "secretstores.external-secrets.io/" + store, "-o", "jsonpath={.spec.provider.vault.auth.kubernetes.mountPath}"], "kubernetes"),
        (label + " secret store auth role", ["-n", namespace, "get", "secretstores.external-secrets.io/" + store, "-o", "jsonpath={.spec.provider.vault.auth.kubernetes.role}"], role),
        (label + " secret store service account", ["-n", namespace, "get", "secretstores.external-secrets.io/" + store, "-o", "jsonpath={.spec.provider.vault.auth.kubernetes.serviceAccountRef.name}"], service_account),
        (label + " secret store audience", ["-n", namespace, "get", "secretstores.external-secrets.io/" + store, "-o", "jsonpath={.spec.provider.vault.auth.kubernetes.serviceAccountRef.audiences[0]}"], "openbao"),
    ]

def _openbao_secret_store_checks(stage, namespace, cnpg_role, clickhouse_role):
    return (
        _secret_store_checks(stage + " cnpg backup", namespace, "openbao", cnpg_role, "guardian-external-secrets") +
        _secret_store_checks(stage + " clickhouse backup", namespace, "openbao-clickhouse-backup", clickhouse_role, "guardian-clickhouse-external-secrets")
    )

