load_http = task(
    implementation = _load_http_impl,
    name = "load-http",
    group = ["infra"],
    summary = "Run a standard k6 HTTP load test against a Guardian management-cluster surface.",
    args = {
        "duration": args.string(default = "30s", description = "k6 test duration."),
        "expected_statuses": args.string(default = "", description = "Comma-separated acceptable HTTP status codes. Defaults depend on the surface."),
        "http_failed_threshold": args.string(default = "rate<0.01", description = "k6 threshold for http_req_failed."),
        "kubeconfig": args.string(default = "", description = "Kubeconfig for guardian-mgmt. Defaults to KUBECONFIG/current context."),
        "port_forward_ready_timeout": args.string(default = "10s", description = "Timeout for OpenBao port-forward readiness."),
        "request_timeout": args.string(default = "15s", description = "kubectl API request timeout."),
        "require_live": args.string(default = "true", description = "Set false only for local custom-URL k6 smoke checks."),
        "revision": args.string(default = "", description = "Optional merged Git commit SHA that source-controller must have applied before the load test."),
        "sleep_seconds": args.string(default = "1", description = "Sleep seconds between requests in each k6 VU."),
        "stage": args.string(default = "dev", description = "Guardian stage: root, dev, gamma, or prod."),
        "surface": args.string(default = "company-site", description = "HTTP surface: company-site, harbor, dashboard, openbao, or custom with --url."),
        "url": args.string(default = "", description = "Explicit URL to load; overrides surface target mapping."),
        "vus": args.string(default = "1", description = "k6 virtual users."),
    },
)

load_db = task(
    implementation = _load_db_impl,
    name = "load-db",
