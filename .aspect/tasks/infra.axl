    ("gamma clickhouse backup external secret", ["-n", "tenant-gamma", "wait", "--for=condition=Ready", "externalsecrets.external-secrets.io/guardian-clickhouse-backup-creds"]),
    ("prod postgres app", ["-n", "tenant-prod", "wait", "--for=condition=Ready", "postgreses.apps.cozystack.io/guardian"]),
    ("prod postgres workloads", ["-n", "tenant-prod", "wait", "--for=condition=WorkloadsReady", "postgreses.apps.cozystack.io/guardian"]),
    ("prod harbor app", ["-n", "tenant-prod", "wait", "--for=condition=Ready", "harbors.apps.cozystack.io/guardian"]),
    ("prod harbor workloads", ["-n", "tenant-prod", "wait", "--for=condition=WorkloadsReady", "harbors.apps.cozystack.io/guardian"]),
    ("prod clickhouse app", ["-n", "tenant-prod", "wait", "--for=condition=Ready", "clickhouses.apps.cozystack.io/guardian"]),
    ("prod clickhouse workloads", ["-n", "tenant-prod", "wait", "--for=condition=WorkloadsReady", "clickhouses.apps.cozystack.io/guardian"]),
    ("prod cnpg backup secret store", ["-n", "tenant-prod", "wait", "--for=condition=Ready", "secretstores.external-secrets.io/openbao"]),
    ("prod cnpg backup external secret", ["-n", "tenant-prod", "wait", "--for=condition=Ready", "externalsecrets.external-secrets.io/guardian-cnpg-backup-creds"]),
    ("prod clickhouse backup secret store", ["-n", "tenant-prod", "wait", "--for=condition=Ready", "secretstores.external-secrets.io/openbao-clickhouse-backup"]),
    ("prod clickhouse backup external secret", ["-n", "tenant-prod", "wait", "--for=condition=Ready", "externalsecrets.external-secrets.io/guardian-clickhouse-backup-creds"]),
    ("dashboard console deployment", ["-n", "cozy-dashboard", "wait", "--for=condition=Available", "deployment/cozy-dashboard-console"]),
    ("dashboard gatekeeper deployment", ["-n", "cozy-dashboard", "wait", "--for=condition=Available", "deployment/incloud-web-gatekeeper"]),
    ("dev company deployment", ["-n", "tenant-dev", "wait", "--for=condition=Available", "deployment/company-site"]),
    ("gamma company deployment", ["-n", "tenant-gamma", "wait", "--for=condition=Available", "deployment/company-site"]),
    ("prod company deployment", ["-n", "tenant-prod", "wait", "--for=condition=Available", "deployment/company-site"]),
] + _harbor_child_waits(
    "root",
    "tenant-root",
) + _harbor_child_waits(
    "dev",
    "tenant-dev",
) + _harbor_child_waits(
    "gamma",
    "tenant-gamma",
) + _harbor_child_waits(
    "prod",
    "tenant-prod",
) + _postgres_child_waits(
    "root",
    "tenant-root",
) + _postgres_child_waits(
    "dev",
    "tenant-dev",
) + _postgres_child_waits(
    "gamma",
    "tenant-gamma",
) + _postgres_child_waits(
    "prod",
    "tenant-prod",
) + _clickhouse_child_waits(
    "root",
    "tenant-root",
) + _clickhouse_child_waits(
    "dev",
    "tenant-dev",
) + _clickhouse_child_waits(
    "gamma",
    "tenant-gamma",
) + _clickhouse_child_waits(
    "prod",
    "tenant-prod",
)
LIVE_COMPANY_SITE_SPREADS = [
    ("dev company pod placement", "tenant-dev", "dev"),
    ("gamma company pod placement", "tenant-gamma", "gamma"),
    ("prod company pod placement", "tenant-prod", "prod"),
]

def _capture_stdout(ctx, program, args, cwd = None, label = None, auth_hint = "kubernetes"):
    label_str = label if label != None else program
    cmd = ctx.std.process.command(program).args(args)
    if cwd != None:
        cmd = cmd.current_dir(cwd)
    if ctx.std.io.stderr.is_tty:
        ctx.std.io.stderr.write("$ " + label_str + "\n")
    r = cmd.stdout("piped").stderr("piped").spawn().wait_with_output()
    if r.status.code != 0:
        ctx.std.io.stderr.write("ERROR: " + label_str + " failed\n")
        if r.stdout != "":
            ctx.std.io.stderr.write(r.stdout)
        if r.stderr != "":
            ctx.std.io.stderr.write(r.stderr)
            _write_auth_hint(ctx, r.stderr, auth_hint)
        return None
    return r.stdout.strip()

def _capture_success(ctx, program, args, cwd = None, label = None, auth_hint = "kubernetes"):
    label_str = label if label != None else program
    cmd = ctx.std.process.command(program).args(args)
    if cwd != None:
        cmd = cmd.current_dir(cwd)
    if ctx.std.io.stderr.is_tty:
        ctx.std.io.stderr.write("$ " + label_str + "\n")
    r = cmd.stdout("piped").stderr("piped").spawn().wait_with_output()
    if r.status.code != 0:
        ctx.std.io.stderr.write("ERROR: " + label_str + " failed\n")
        if r.stdout != "":
            ctx.std.io.stderr.write(r.stdout)
        if r.stderr != "":
            ctx.std.io.stderr.write(r.stderr)
            _write_auth_hint(ctx, r.stderr, auth_hint)
        return 1
    return 0

def _write_auth_hint(ctx, stderr, auth_hint):
    if stderr.find("tls: failed to verify certificate") == -1:
        return
    if stderr.find("x509:") == -1:
        return
    if auth_hint == "talos":
        ctx.std.io.stderr.write(
            "ERROR: Talos rejected the local talosconfig credentials. Refresh "
            + "the guardian-mgmt Talos operator state from the current cluster "
            + "before running Talos L2 validation; do not use insecure TLS flags "
            + "for management-plane validation.\n",
        )
        return
    ctx.std.io.stderr.write(
        "ERROR: Kubernetes rejected the local cluster credentials. Refresh the "
        + "guardian-mgmt kubeconfig/Talos operator state from the current cluster "
        + "with `aspect infra kubeconfig` when the local Talm state is current; "
        + "do not use insecure TLS flags for source-controller validation.\n",
    )

def _tofu_root(ctx, root, args, label):
    return checked_spawn(
        ctx,
        "bazelisk",
        ["run", TOFU_TARGET, "--", "-chdir=" + ws_path(ctx, root)] + args,
        cwd = ws_path(ctx),
        label = label,
    )

def _kubectl_path(ctx):
    rc = checked_spawn(
        ctx,
        "bazelisk",
        ["build", KUBECTL_FILE_TARGET],
        cwd = ws_path(ctx),
        label = "bazelisk build " + KUBECTL_FILE_TARGET,
    )
    if rc != 0:
        return None
    output_base = _capture_stdout(
        ctx,
        "bazelisk",
        ["info", "output_base"],
        cwd = ws_path(ctx),
        label = "bazelisk info output_base",
    )
    if output_base == None:
        return None
    return output_base + "/external/+http_file+kubectl_linux_amd64/file/kubectl"

def _k6_path(ctx):
    rc = checked_spawn(
        ctx,
        "bazelisk",
        ["build", K6_FILE_TARGET],
        cwd = ws_path(ctx),
        label = "bazelisk build " + K6_FILE_TARGET,
    )
    if rc != 0:
        return None
    output_base = _capture_stdout(
        ctx,
        "bazelisk",
        ["info", "output_base"],
        cwd = ws_path(ctx),
        label = "bazelisk info output_base",
    )
    if output_base == None:
        return None
    return output_base + "/external/+http_archive+k6_linux_amd64/k6"

def _talosctl_path(ctx):
    rc = checked_spawn(
        ctx,
        "bazelisk",
        ["build", TALOSCTL_FILE_TARGET],
        cwd = ws_path(ctx),
        label = "bazelisk build " + TALOSCTL_FILE_TARGET,
    )
    if rc != 0:
        return None
    output_base = _capture_stdout(
        ctx,
        "bazelisk",
        ["info", "output_base"],
        cwd = ws_path(ctx),
        label = "bazelisk info output_base",
    )
    if output_base == None:
        return None
    return output_base + "/external/+http_file+talosctl_linux_amd64/file/talosctl"

def _kubectl_args(ctx, args):
    out = []
    if ctx.args.kubeconfig != "":
        out.extend(["--kubeconfig", ctx.args.kubeconfig])
    if ctx.args.request_timeout != "":
        out.append("--request-timeout=" + ctx.args.request_timeout)
    out.extend(args)
    return out

def _talosctl_args(ctx, args):
    out = [
        "--talosconfig",
        ctx.args.talosconfig,
        "--endpoints",
        ctx.args.endpoints,
        "--nodes",
        ctx.args.nodes,
    ]
    out.extend(args)
    return out

def _kubectl_capture(ctx, kubectl, args, label):
    return _capture_stdout(
        ctx,
        kubectl,
        _kubectl_args(ctx, args),
        cwd = ws_path(ctx),
        label = label,
    )

def _talosctl_capture(ctx, talosctl, args, label):
    return _capture_stdout(
        ctx,
        talosctl,
        _talosctl_args(ctx, args),
        cwd = ws_path(ctx),
        label = label,
        auth_hint = "talos",
    )

def _kubectl_success(ctx, kubectl, args, label):
    return _capture_success(
        ctx,
        kubectl,
        _kubectl_args(ctx, args),
        cwd = ws_path(ctx),
        label = label,
    )

def _talosctl_success(ctx, talosctl, args, label):
    return _capture_success(
        ctx,
        talosctl,
        _talosctl_args(ctx, args),
        cwd = ws_path(ctx),
        label = label,
        auth_hint = "talos",
    )

def _contains(items, needle):
    for item in items:
        if item == needle:
            return True
    return False

def _unique_non_empty_lines(value):
    out = []
    for line in value.split("\n"):
        item = line.strip()
        if item == "":
            continue
        if not _contains(out, item):
            out.append(item)
    return out

def _expected_revision(ctx):
    if ctx.args.revision == "":
        ctx.std.io.stderr.write("ERROR: --revision is required; pass the merged main commit SHA that source-controller must have applied\n")
        return None
    return ctx.args.revision

def _line_count(s):
    count = 0
    for line in s.split("\n"):
        if line.strip() != "":
            count = count + 1
    return count

def _assert_contains(ctx, value, needle, label):
    if value.find(needle) == -1:
        ctx.std.io.stderr.write("ERROR: " + label + " = " + value + "; expected it to contain " + needle + "\n")
        return 1
    return 0

def _assert_equals(ctx, value, expected, label):
    if value != expected:
        ctx.std.io.stderr.write("ERROR: " + label + " = " + value + "; expected " + expected + "\n")
        return 1
    return 0

def _check_live_context(ctx, kubectl):
    server = _kubectl_capture(
        ctx,
        kubectl,
        ["config", "view", "--minify", "--output=jsonpath={.clusters[0].cluster.server}"],
        "kubectl current cluster server",
    )
    if server == None:
        return 1
    if _contains(EXCLUDED_KUBE_APIS, server):
        ctx.std.io.stderr.write("ERROR: refusing to validate against excluded cluster API " + server + "\n")
        return 1
    if not _contains(EXPECTED_KUBE_APIS, server):
        ctx.std.io.stderr.write("ERROR: kubeconfig points at " + server + "; expected guardian-mgmt API endpoint from src/infrastructure/bootstrap/guardian-mgmt/main.tf\n")
        return 1

    nodes = _kubectl_capture(ctx, kubectl, ["get", "nodes", "-o", "name"], "kubectl get nodes")
    if nodes == None:
        return 1
    if _line_count(nodes) != 3:
        ctx.std.io.stderr.write("ERROR: guardian-mgmt should have exactly 3 nodes; kubectl reported:\n" + nodes + "\n")
        return 1

    node_details = _kubectl_capture(ctx, kubectl, ["get", "nodes", "-o", "wide"], "kubectl get nodes -o wide")
    if node_details == None:
        return 1
    return _assert_contains(ctx, node_details, "10.8.0.", "node InternalIP addresses")

def _check_flux_revision(ctx, kubectl, revision):
    checks = [
        ("guardian GitRepository artifact revision", ["-n", "cozy-fluxcd", "get", "gitrepositories.source.toolkit.fluxcd.io/guardian", "-o", "jsonpath={.status.artifact.revision}"]),
        ("guardian-mgmt-base last applied revision", ["-n", "cozy-fluxcd", "get", "kustomizations.kustomize.toolkit.fluxcd.io/guardian-mgmt-base", "-o", "jsonpath={.status.lastAppliedRevision}"]),
        ("guardian-mgmt-tenant-apps last applied revision", ["-n", "cozy-fluxcd", "get", "kustomizations.kustomize.toolkit.fluxcd.io/guardian-mgmt-tenant-apps", "-o", "jsonpath={.status.lastAppliedRevision}"]),
    ]
    for label, kubectl_args in checks:
        value = _kubectl_capture(ctx, kubectl, kubectl_args, "kubectl read " + label)
        if value == None:
            return 1
        rc = _assert_contains(ctx, value, revision, label)
        if rc != 0:
            return rc
    return 0

def _check_company_site_spread(ctx, kubectl):
    for label, namespace, stage in LIVE_COMPANY_SITE_SPREADS:
        node_names = _kubectl_capture(
            ctx,
            kubectl,
            [
                "-n",
                namespace,
                "get",
                "pods",
                "-l",
                "app.kubernetes.io/name=company-site,guardian.dev/stage=" + stage,
                "-o",
                "jsonpath={range .items[*]}{.spec.nodeName}{\"\\n\"}{end}",
            ],
            "kubectl read " + label,
        )
        if node_names == None:
            return 1
        unique_nodes = _unique_non_empty_lines(node_names)
        if len(unique_nodes) != 3:
            ctx.std.io.stderr.write(
                "ERROR: "
                + label
                + " is scheduled on "
                + str(len(unique_nodes))
                + " unique nodes, expected 3; nodes:\n"
                + node_names
                + "\n",
            )
            return 1
    return 0

def _render_kustomizations(ctx):
    kubectl = _kubectl_path(ctx)
    if kubectl == None:
        return 1
    for path in [
        "src/infrastructure/base",
        "src/infrastructure/environments",
    ]:
        rc = _capture_success(
            ctx,
            kubectl,
            ["kustomize", path],
            cwd = ws_path(ctx),
            label = "kubectl kustomize " + path,
        )
        if rc != 0:
            return rc
    return 0

def _validate_impl(ctx):
    for root, label in [
        (GUARDIAN_MGMT_ROOT, "guardian-mgmt"),
        (GUARDIAN_MGMT_OPENBAO_ROOT, "guardian-mgmt-openbao"),
    ]:
        rc = _tofu_root(ctx, root, ["fmt", "-check"], "tofu fmt -check " + label)
        if rc != 0:
            return rc
        rc = _tofu_root(ctx, root, ["init", "-backend=false", "-input=false", "-reconfigure"], "tofu init -backend=false " + label)
        if rc != 0:
            return rc
        rc = _tofu_root(ctx, root, ["validate"], "tofu validate " + label)
        if rc != 0:
            return rc
    rc = checked_spawn(
        ctx,
        "bazelisk",
        ["build"] + INFRA_FILEGROUPS,
        cwd = ws_path(ctx),
        label = "bazelisk build infra filegroups",
    )
    if rc != 0:
        return rc
    rc = checked_spawn(
        ctx,
        "bazelisk",
        ["test"] + INFRA_TESTS,
        cwd = ws_path(ctx),
        label = "bazelisk test infra invariants",
    )
    if rc != 0:
        return rc
    return _render_kustomizations(ctx)

def _topology_impl(ctx):
    tofu_args = ["output", "-json"]
    if ctx.args.name != "":
        tofu_args.append(ctx.args.name)
    return _tofu_root(
        ctx,
        GUARDIAN_MGMT_ROOT,
        tofu_args,
        "tofu output -json guardian-mgmt",
    )

def _kubeconfig_impl(ctx):
    root = ws_path(ctx, ctx.args.root)
    talosconfig = ctx.args.talosconfig
    if talosconfig == "":
        talosconfig = root + "/talosconfig"

    rc = checked_spawn(
        ctx,
        "bazelisk",
        [
            "run",
            TALM_TARGET,
            "--",
            "talosconfig",
            "--root",
            root,
            "--talosconfig",
            talosconfig,
        ],
        cwd = root,
        label = "talm talosconfig guardian-mgmt",
    )
    if rc != 0:
        return rc

    rc = checked_spawn(
        ctx,
        "bazelisk",
        [
            "run",
            TALM_TARGET,
            "--",
            "kubeconfig",
            "--root",
            root,
            "--talosconfig",
            talosconfig,
            "--nodes",
            ctx.args.nodes,
            "--endpoints",
            ctx.args.endpoints,
            "--merge=false",
            "--force",
        ],
        cwd = root,
        label = "talm kubeconfig guardian-mgmt",
    )
    if rc != 0:
        return rc

    ctx.std.io.stderr.write("wrote guardian-mgmt kubeconfig to " + root + "/kubeconfig\n")
    return 0

def _talos_impl(ctx):
    talosctl = _talosctl_path(ctx)
    if talosctl == None:
        return 1

    addresses = _talosctl_capture(
        ctx,
        talosctl,
        ["get", "addresses"],
        "talosctl get addresses",
    )
    if addresses == None:
        return 1
    for node in GUARDIAN_MGMT_TALOS_NODES:
        rc = _assert_contains(ctx, addresses, node, "talos addresses")
        if rc != 0:
            return rc

    rc = _talosctl_success(
        ctx,
        talosctl,
        ["get", "routes"],
        "talosctl get routes",
    )
    if rc != 0:
        return rc

    kubespan = _talosctl_capture(
        ctx,
        talosctl,
        ["get", "kubespanpeerstatuses", "-o", "jsonpath={.items}"],
        "talosctl get kubespanpeerstatuses",
    )
    if kubespan == None:
        return 1
    rc = _assert_equals(ctx, kubespan, "[]", "kubespan peer statuses")
    if rc != 0:
        return rc

    ctx.std.io.stderr.write("guardian-mgmt Talos L2 checks passed\n")
    return 0

def _live_impl(ctx):
    revision = _expected_revision(ctx)
    if revision == None:
        return 1
    kubectl = _kubectl_path(ctx)
    if kubectl == None:
        return 1

    rc = _check_live_context(ctx, kubectl)
    if rc != 0:
        return rc

    for label, kubectl_args in LIVE_WAITS:
        rc = _kubectl_success(
            ctx,
            kubectl,
            kubectl_args + ["--timeout=" + ctx.args.wait_timeout],
            "kubectl wait " + label,
        )
        if rc != 0:
            return rc

    rc = _check_flux_revision(ctx, kubectl, revision)
    if rc != 0:
        return rc

    for label, kubectl_args in LIVE_GETS:
        rc = _kubectl_success(ctx, kubectl, kubectl_args, "kubectl get " + label)
        if rc != 0:
            return rc

    for label, kubectl_args, expected in LIVE_VALUE_CHECKS:
        value = _kubectl_capture(ctx, kubectl, kubectl_args, "kubectl read " + label)
        if value == None:
            return 1
        rc = _assert_equals(ctx, value, expected, label)
        if rc != 0:
            return rc

    rc = _check_company_site_spread(ctx, kubectl)
    if rc != 0:
        return rc

    ctx.std.io.stderr.write("guardian-mgmt source-controller has reconciled " + revision + "\n")
    return 0

def _backup_drill_impl(ctx):
    kubectl = _kubectl_path(ctx)
    if kubectl == None:
        return 1

    rc = _check_live_context(ctx, kubectl)
    if rc != 0:
        return rc

    if ctx.args.allow_in_place_restore != "" and ctx.args.allow_in_place_restore != "true" and ctx.args.allow_in_place_restore != "false":
        ctx.std.io.stderr.write("ERROR: --allow-in-place-restore must be true or false\n")
        return 1

    drill_args = [
        "--kubectl",
        kubectl,
        "--stage",
        ctx.args.stage,
        "--component",
        ctx.args.component,
        "--application",
        ctx.args.application,
        "--request-timeout",
        ctx.args.request_timeout,
        "--wait-timeout",
        ctx.args.wait_timeout,
    ]
    if ctx.args.kubeconfig != "":
        drill_args.extend(["--kubeconfig", ctx.args.kubeconfig])
    if ctx.args.name != "":
        drill_args.extend(["--name", ctx.args.name])
    if ctx.args.restore_target != "":
        drill_args.extend(["--restore-target", ctx.args.restore_target])
    if ctx.args.allow_in_place_restore == "true":
        drill_args.append("--allow-in-place-restore=true")

    return checked_spawn(
        ctx,
        "bazelisk",
        ["run", BACKUP_DRILL_TARGET, "--"] + drill_args,
        cwd = ws_path(ctx),
        label = "cozystack backup drill",
    )

def _node_outage_drill_impl(ctx):
    if ctx.args.node == "":
        ctx.std.io.stderr.write("ERROR: --node is required\n")
        return 1
    if ctx.args.confirm_node != ctx.args.node:
        ctx.std.io.stderr.write("ERROR: --confirm-node must exactly match --node before running this disruptive drill\n")
        return 1

    kubectl = _kubectl_path(ctx)
    if kubectl == None:
        return 1

    rc = _check_live_context(ctx, kubectl)
    if rc != 0:
        return rc

    drill_args = [
        "--kubectl",
        kubectl,
        "--node",
        ctx.args.node,
        "--confirm-node",
        ctx.args.confirm_node,
        "--request-timeout",
        ctx.args.request_timeout,
        "--drain-timeout",
        ctx.args.drain_timeout,
        "--wait-timeout",
        ctx.args.wait_timeout,
    ]
    if ctx.args.kubeconfig != "":
        drill_args.extend(["--kubeconfig", ctx.args.kubeconfig])

    return checked_spawn(
        ctx,
        "bazelisk",
        ["run", NODE_OUTAGE_DRILL_TARGET, "--"] + drill_args,
        cwd = ws_path(ctx),
        label = "cozystack node outage drill",
    )

def _load_http_impl(ctx):
    if ctx.args.require_live != "true" and ctx.args.require_live != "false":
        ctx.std.io.stderr.write("ERROR: --require-live must be true or false\n")
        return 1

    k6 = _k6_path(ctx)
    if k6 == None:
        return 1

    kubectl = _kubectl_path(ctx)
    if kubectl == None:
        return 1

    if ctx.args.require_live == "true":
        rc = _check_live_context(ctx, kubectl)
        if rc != 0:
            return rc
        if ctx.args.revision != "":
            rc = _check_flux_revision(ctx, kubectl, ctx.args.revision)
            if rc != 0:
                return rc

    load_args = [
        "--k6",
        k6,
        "--script",
        ws_path(ctx, "src/infrastructure/load/http-smoke.js"),
        "--kubectl",
        kubectl,
        "--stage",
        ctx.args.stage,
        "--surface",
        ctx.args.surface,
        "--request-timeout",
        ctx.args.request_timeout,
        "--vus",
        ctx.args.vus,
        "--duration",
        ctx.args.duration,
        "--http-failed-threshold",
        ctx.args.http_failed_threshold,
        "--sleep-seconds",
        ctx.args.sleep_seconds,
        "--port-forward-ready-timeout",
        ctx.args.port_forward_ready_timeout,
    ]
    if ctx.args.kubeconfig != "":
        load_args.extend(["--kubeconfig", ctx.args.kubeconfig])
    if ctx.args.url != "":
        load_args.extend(["--url", ctx.args.url])
    if ctx.args.expected_statuses != "":
        load_args.extend(["--expected-statuses", ctx.args.expected_statuses])

    return checked_spawn(
        ctx,
        "bazelisk",
        ["run", HTTP_LOAD_TARGET, "--"] + load_args,
        cwd = ws_path(ctx),
        label = "cozystack http load",
    )

def _load_db_impl(ctx):
    kubectl = _kubectl_path(ctx)
    if kubectl == None:
        return 1

    rc = _check_live_context(ctx, kubectl)
    if rc != 0:
        return rc
    if ctx.args.revision != "":
        rc = _check_flux_revision(ctx, kubectl, ctx.args.revision)
        if rc != 0:
            return rc

    load_args = [
        "--kubectl",
        kubectl,
        "--stage",
        ctx.args.stage,
        "--component",
        ctx.args.component,
        "--application",
        ctx.args.application,
        "--request-timeout",
        ctx.args.request_timeout,
        "--wait-timeout",
        ctx.args.wait_timeout,
        "--ttl-seconds-after-finished",
        ctx.args.ttl_seconds_after_finished,
        "--pgbench-scale",
        ctx.args.pgbench_scale,
        "--pgbench-clients",
        ctx.args.pgbench_clients,
        "--pgbench-jobs",
        ctx.args.pgbench_jobs,
        "--pgbench-duration-seconds",
        ctx.args.pgbench_duration_seconds,
        "--clickhouse-concurrency",
        ctx.args.clickhouse_concurrency,
        "--clickhouse-iterations",
        ctx.args.clickhouse_iterations,
        "--clickhouse-duration-seconds",
        ctx.args.clickhouse_duration_seconds,
        "--clickhouse-query",
        ctx.args.clickhouse_query,
    ]
    if ctx.args.kubeconfig != "":
        load_args.extend(["--kubeconfig", ctx.args.kubeconfig])
    if ctx.args.name != "":
        load_args.extend(["--name", ctx.args.name])

    return checked_spawn(
        ctx,
        "bazelisk",
        ["run", DB_LOAD_TARGET, "--"] + load_args,
        cwd = ws_path(ctx),
        label = "cozystack db load",
    )

